      color: #a78bfa;
      border: 1px solid #a78bfa;
      padding: 10px 20px;
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
      transition: all 0.3s;
      cursor: pointer;
    }

    .btn-signin:hover {
      background: rgba(167, 139, 250, 0.2);
    }

    .hero {
