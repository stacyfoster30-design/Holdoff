      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
      transition: var(--transition);
      text-align: left;
    }

    .feature-card:hover {
      border-color: var(--primary);
      transform: translateY(-8px);
      box-shadow: 0 12px 40px rgba(139, 92, 246, 0.2);
    }

