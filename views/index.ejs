      text-align: center;
      max-width: 900px;
      margin: 0 auto;
    }

    h1 {
      font-size: 52px;
      font-weight: 800;
      margin-bottom: 20px;
      line-height: 1.2;
      color: #ffffff;
    }

    .highlight {
      background: linear-gradient(135deg, #a78bfa 0%, #f472b6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
