  <script>
    /**
     * Verdict-based theme detection
     * Listens for user input and shifts the page theme based on detected emotional state
     */
    
    let verdictTimeout;
    
    // Try to detect verdict from message if we have an input field
    document.addEventListener('DOMContentLoaded', () => {
      const messageInput = document.querySelector('textarea, input[type="text"][placeholder*="message" i]');
      
      if (messageInput) {
        messageInput.addEventListener('input', () => {
          clearTimeout(verdictTimeout);
          verdictTimeout = setTimeout(() => {
            detectAndApplyVerdict(messageInput.value);
          }, 500);
        });
      }
    });
    
    async function detectAndApplyVerdict(text) {
      if (!text || text.trim().length < 3) {
        // Clear verdict if text is too short
        document.body.removeAttribute('data-verdict');
        return;
      }
      
      try {
        const response = await fetch('/api/verdict', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ outgoingMessage: text })
        });
        
        if (!response.ok) throw new Error('Verdict detection failed');
        
        const data = await response.json();
        
        // Use themeCode from backend, fallback to attachmentPattern
        const themeCode = data.themeCode || data.attachmentPattern || 'SEC';
        
        // Apply theme
        document.body.setAttribute('data-verdict', themeCode);
      } catch (error) {
        console.log('Verdict detection unavailable:', error);
        document.body.removeAttribute('data-verdict');
      }
    }
  </script>
