      --bg-card: #1A2847;
      --text-primary: #F1F5F9;
      --text-muted: #CBD5E1;
      --text-dim: #94A3B8;
      --border: #334155;
      --glow-primary: rgba(139, 92, 246, 0.1);
      --radius: 12px;
      --transition: all 0.3s ease;
    }

    html, body {
