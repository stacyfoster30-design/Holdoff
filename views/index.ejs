  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #8B5CF6;
      --primary-dark: #6D28D9;
      --accent: #3B82F6;
      --accent-dark: #1E40AF;
      --rose: #EC4899;
      --green-safe: #10B981;
      --yellow-warn: #F59E0B;
      --red-danger: #EF4444;
      --bg-dark: #0F172A;
      --bg-darker: #09101F;
      --bg-card: #1A2847;
      --text-primary: #F1F5F9;
      --text-muted: #CBD5E1;
      --text-dim: #94A3B8;
      --border: #334155;
      --glow-primary: rgba(139, 92, 246, 0.1);
      --radius: 12px;
      --transition: all 0.3s ease;
    }

    html, body {
      width: 100%;
      min-height: 100vh;
      background: linear-gradient(135deg, var(--bg-darker) 0%, #1a1f3a 100%);
      color: var(--text-primary);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      line-height: 1.6;
    }

    a { color: var(--primary); text-decoration: none; transition: var(--transition); }
    a:hover { color: var(--primary-dark); }

    /* NAV */
    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(15, 23, 42, 0.95);
      backdrop-filter: blur(10px);
    }

    .nav-logo {
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--primary);
      letter-spacing: -0.5px;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      align-items: center;
    }

    .nav-link {
      color: var(--text-muted);
      font-size: 0.95rem;
      transition: var(--transition);
    }

    .nav-link:hover {
      color: var(--primary);
    }

    /* BUTTONS */
    .btn {
      display: inline-block;
      padding: 12px 28px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: var(--transition);
      border: none;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(139, 92, 246, 0.3);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }

    .btn-ghost:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    /* HERO */
    .hero {
      text-align: center;
      padding: 100px 40px 120px;
      background: linear-gradient(180deg, rgba(107, 40, 215, 0.1) 0%, transparent 100%);
      max-width: 1000px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      display: inline-block;
      padding: 8px 16px;
      background: var(--glow-primary);
      border: 1px solid var(--primary);
      border-radius: 20px;
      color: var(--primary);
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 24px;
    }

    .hero h1 {
      font-size: 3.5rem;
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: 16px;
      color: var(--text-primary);
    }

    .hero .highlight {
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      color: var(--text-muted);
      font-size: 1.25rem;
      margin: 0 auto 40px;
      max-width: 700px;
      line-height: 1.7;
    }

    .hero-ctas {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* SOCIAL PROOF */
    .social-proof {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px 40px;
      text-align: center;
      margin-top: 60px;
      display: inline-block;
      margin-left: auto;
      margin-right: auto;
    }

    .social-proof p {
      color: var(--text-dim);
      font-size: 0.9rem;
      margin: 0;
    }

    /* BENEFITS GRID */
    .benefits {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 32px;
      max-width: 1200px;
      margin: 100px auto;
      padding: 0 40px;
    }

    .benefit-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 40px 32px;
      transition: var(--transition);
      text-align: left;
    }

    .benefit-card:hover {
      border-color: var(--primary);
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
    }

    .benefit-icon {
      font-size: 2.5rem;
      margin-bottom: 20px;
      display: block;
    }

    .benefit-card h3 {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-primary);
    }

    .benefit-card p {
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.7;
    }

    /* HOW IT WORKS */
    .how-it-works {
      background: var(--bg-card);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 80px 40px;
      margin-top: 80px;
    }

    .how-it-works .section-title {
      font-size: 2.5rem;
      font-weight: 800;
      text-align: center;
      margin-bottom: 60px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 40px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .step {
      position: relative;
      padding-left: 60px;
    }

    .step-number {
      position: absolute;
      left: 0;
      top: 0;
      width: 48px;
      height: 48px;
      background: var(--primary);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.2rem;
    }

    .step h4 {
      font-size: 1.2rem;
      margin-bottom: 8px;
      color: var(--text-primary);
    }

    .step p {
      color: var(--text-muted);
      font-size: 0.95rem;
    }

    /* CTA SECTION */
    .cta-section {
      text-align: center;
      padding: 80px 40px;
      background: linear-gradient(180deg, transparent 0%, rgba(107, 40, 215, 0.08) 100%);
    }

    .cta-section h2 {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 24px;
      color: var(--text-primary);
    }

    .cta-section p {
      font-size: 1.1rem;
      color: var(--text-muted);
      margin-bottom: 40px;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border);
      padding: 40px;
      text-align: center;
      color: var(--text-dim);
      font-size: 0.9rem;
    }

    @media (max-width: 768px) {
      .hero h1 {
        font-size: 2.5rem;
      }

      .hero p {
        font-size: 1.05rem;
      }

      .nav {
        padding: 16px 24px;
      }

      .nav-links {
        gap: 16px;
      }

      .hero, .benefits, .how-it-works, .cta-section {
        padding-left: 24px;
        padding-right: 24px;
      }
    }
  </style>
</head>
