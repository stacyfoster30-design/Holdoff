<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat with <%= character.name %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      background: linear-gradient(135deg, #1a0033 0%, #2d1b4e 50%, #1a1a3e 100%);
      min-height: 100vh;
      color: #e8dcc8;
    }

    .companion-container {
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
      height: 100vh;
      display: flex;
      flex-direction: column;
      padding: 20px;
    }

    .companion-header {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 20px;
      background: rgba(45, 27, 78, 0.4);
      border-radius: 12px;
      margin-bottom: 20px;
      backdrop-filter: blur(10px);
    }

    .character-avatar {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: transparent;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }
    .character-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      border-radius: 50%;
    }

    .character-info h2 {
      font-size: 24px;
      margin-bottom: 4px;
      color: #f0e6d2;
    }

    .character-info p {
      font-size: 14px;
      color: #b8a89f;
      font-style: italic;
    }

    .chat-history {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 15px;
      margin-bottom: 20px;
      padding-right: 10px;
    }

    .message {
      display: flex;
      gap: 10px;
      animation: slideIn 0.3s ease-out;
    }

    .message-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      overflow: hidden;
      flex-shrink: 0;
      align-self: flex-end;
      background: rgba(45, 27, 78, 0.6);
      border: 1px solid rgba(139, 92, 246, 0.4);
    }

    .message-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      display: block;
    }

    .message-avatar .avatar-emoji {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .message.user {
      justify-content: flex-end;
    }

    .message-bubble {
      max-width: 550px;
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.5;
    }

    .message.user .message-bubble {
      background: linear-gradient(135deg, #6b4b9f 0%, #8b5cf6 100%);
      color: #fff;
      border-radius: 12px 4px 12px 12px;
    }

    .message.assistant .message-bubble {
      background: rgba(45, 27, 78, 0.6);
      color: #e8dcc8;
      border-radius: 4px 12px 12px 12px;
      border-left: 3px solid #8b5cf6;
    }

    .typing-indicator {
      display: flex;
      gap: 4px;
      align-items: center;
      padding: 12px 16px;
    }

    .typing-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #8b5cf6;
      animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes typing {
      0%, 60%, 100% {
        opacity: 0.5;
      }
      30% {
        opacity: 1;
      }
    }

    .chat-input-area {
      display: flex;
      gap: 10px;
      padding: 15px;
      background: rgba(45, 27, 78, 0.4);
      border-radius: 12px;
      backdrop-filter: blur(10px);
    }

    .chat-input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 8px;
      background: rgba(26, 26, 62, 0.5);
      color: #e8dcc8;
      font-size: 14px;
      font-family: inherit;
    }

    .chat-input::placeholder {
      color: #8b7d93;
    }

    .chat-input:focus {
      outline: none;
      border-color: #8b5cf6;
      background: rgba(26, 26, 62, 0.8);
    }

    .send-btn {
      padding: 12px 24px;
      background: linear-gradient(135deg, #6b4b9f 0%, #8b5cf6 100%);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .send-btn:hover {
      opacity: 0.9;
    }

    .send-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      background: rgba(139, 92, 246, 0.2);
      color: #8b5cf6;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      margin-bottom: 15px;
      text-decoration: none;
    }

    .back-btn:hover {
      background: rgba(139, 92, 246, 0.3);
    }

    ::-webkit-scrollbar {
      width: 8px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: rgba(139, 92, 246, 0.3);
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: rgba(139, 92, 246, 0.5);
    }

    /* Attachment style picker */
    .style-picker {
      background: rgba(26, 14, 46, 0.55);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 12px;
      padding: 12px 14px;
      margin-bottom: 14px;
      backdrop-filter: blur(10px);
    }
    .style-picker-label {
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #b8a8d6;
      margin-bottom: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .style-picker-label .help {
      text-transform: none;
      letter-spacing: 0;
      font-size: 11px;
      color: #8b7d93;
      font-style: italic;
    }
    .style-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .style-pill {
      background: rgba(45, 27, 78, 0.5);
      border: 1px solid rgba(139, 92, 246, 0.3);
      color: #e8dcc8;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.15s ease;
    }
    .style-pill:hover {
      background: rgba(139, 92, 246, 0.2);
      border-color: rgba(139, 92, 246, 0.6);
    }
    .style-pill.active {
      background: linear-gradient(135deg, #6b4b9f 0%, #8b5cf6 100%);
      border-color: #8b5cf6;
      color: #fff;
      box-shadow: 0 0 0 1px rgba(139, 92, 246, 0.5);
    }
    .style-pill .core {
      font-size: 10px;
      opacity: 0.8;
      margin-left: 6px;
    }
    .style-blurb {
      font-size: 12px;
      color: #c9b8e6;
      margin-top: 10px;
      font-style: italic;
      line-height: 1.45;
      min-height: 1em;
    }
  </style>
</head>
<body>
  <div class="companion-container">
    <a href="/story" class="back-btn">← Back to story</a>

    <div class="companion-header">
      <div class="character-avatar">
        <img src="<%= character.image %>" alt="<%= character.name %>" onerror="this.style.display='none';this.parentNode.insertAdjacentHTML('beforeend','<span style=\'font-size:28px\'><%= character.emoji %></span>')">
      </div>
      <div class="character-info">
        <h2><%= character.name %></h2>
        <p><%= character.tagline %></p>
      </div>
    </div>

    <div class="style-picker" id="stylePicker">
      <div class="style-picker-label">
        <span>Attachment state · how <%= character.name %> shows up</span>
        <span class="help">same 4 styles for both souls</span>
      </div>
      <div class="style-pills" id="stylePills"></div>
      <div class="style-blurb" id="styleBlurb"></div>
    </div>

    <div class="chat-history" id="chatHistory">
      <div class="message assistant">
        <div class="message-avatar">
          <img src="<%= character.image %>" alt="<%= character.name %>"
               onerror="this.style.display='none';this.insertAdjacentHTML('afterend','<span class=\'avatar-emoji\'><%= character.emoji %></span>')">
        </div>
        <div class="message-bubble">
          <%= character.greeting %>
        </div>
      </div>
    </div>

    <div class="chat-input-area">
      <input 
        type="text" 
        class="chat-input" 
        id="messageInput" 
        placeholder="Ask <%= character.name %>..."
        autocomplete="off"
      >
      <button class="send-btn" id="sendBtn">Send</button>
    </div>
  </div>

  <script>
    const character = <%- JSON.stringify(character) %>;
    const userContext = <%- JSON.stringify(userContext) %>;

    // Canonical soul name (server accepts legacy Stacy/Danny but uses Sadie/Dan internally).
    const SOUL_NAME = (character.name === 'Stacy') ? 'Sadie'
                    : (character.name === 'Danny') ? 'Dan'
                    : character.name;
    const CORE_STYLE = (SOUL_NAME === 'Sadie') ? 'fearful_avoidant' : 'dismissive_avoidant';

    let conversationHistory = [];
    let currentStyle = CORE_STYLE;
    let stylesByKey = {};

    async function loadStyles() {
      try {
        const r = await fetch('/api/companion/styles?soul=' + encodeURIComponent(SOUL_NAME));
        const data = await r.json();
        const pills = document.getElementById('stylePills');
        pills.innerHTML = '';
        (data.styles || []).forEach((s) => {
          stylesByKey[s.key] = s;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'style-pill' + (s.key === currentStyle ? ' active' : '');
          btn.dataset.key = s.key;
          btn.innerHTML = escapeHtml(s.label) +
            (s.key === CORE_STYLE ? '<span class="core">· core</span>' : '');
          btn.addEventListener('click', () => selectStyle(s.key));
          pills.appendChild(btn);
        });
        renderBlurb();
      } catch (e) {
        console.error('Failed to load styles', e);
      }
    }

    function selectStyle(key) {
      currentStyle = key;
      document.querySelectorAll('.style-pill').forEach((el) => {
        el.classList.toggle('active', el.dataset.key === key);
      });
      renderBlurb();
    }

    function renderBlurb() {
      const s = stylesByKey[currentStyle];
      const el = document.getElementById('styleBlurb');
      if (!s) { el.textContent = ''; return; }
      el.textContent = s.blurb || '';
    }

    loadStyles();

    function scrollToBottom() {
      const chatHistory = document.getElementById('chatHistory');
      chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    function addMessage(role, content) {
      const chatHistory = document.getElementById('chatHistory');
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${role}`;

      if (role === 'assistant') {
        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'message-avatar';
        const img = document.createElement('img');
        img.src = character.image || '';
        img.alt = character.name;
        img.onerror = function () {
          this.style.display = 'none';
          const fallback = document.createElement('span');
          fallback.className = 'avatar-emoji';
          fallback.textContent = character.emoji || '?';
          avatarDiv.appendChild(fallback);
        };
        avatarDiv.appendChild(img);
        messageDiv.appendChild(avatarDiv);
      }

      const bubble = document.createElement('div');
      bubble.className = 'message-bubble';
      bubble.textContent = content;
      messageDiv.appendChild(bubble);

      chatHistory.appendChild(messageDiv);
      
      if (role === 'user') {
        conversationHistory.push({ role: 'user', content });
      }
      
      scrollToBottom();
    }

    function showTyping() {
      const chatHistory = document.getElementById('chatHistory');
      const typingDiv = document.createElement('div');
      typingDiv.className = 'message assistant';
      typingDiv.id = 'typingIndicator';
      typingDiv.innerHTML = `
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      `;
      chatHistory.appendChild(typingDiv);
      scrollToBottom();
    }

    function removeTyping() {
      const typingIndicator = document.getElementById('typingIndicator');
      if (typingIndicator) {
        typingIndicator.remove();
      }
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function sendMessage() {
      const input = document.getElementById('messageInput');
      const message = input.value.trim();

      if (!message) return;

      input.value = '';
      document.getElementById('sendBtn').disabled = true;

      addMessage('user', message);
      showTyping();

      try {
        const response = await fetch('/api/companion/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            soulName: SOUL_NAME,
            characterName: character.name, // legacy field, still accepted
            attachmentStyle: currentStyle,
            message,
            conversationHistory,
          }),
        });

        removeTyping();

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const data = await response.json();
        addMessage('assistant', data.reply);
        conversationHistory.push({ role: 'assistant', content: data.reply });
      } catch (error) {
        removeTyping();
        addMessage('assistant', `Sorry, I couldn't respond right now. Try again in a moment.`);
        console.error('Chat error:', error);
      } finally {
        document.getElementById('sendBtn').disabled = false;
        document.getElementById('messageInput').focus();
      }
    }

    document.getElementById('sendBtn').addEventListener('click', sendMessage);
    document.getElementById('messageInput').addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    document.getElementById('messageInput').focus();
  </script>
</body>
</html>
