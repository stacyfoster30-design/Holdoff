<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat with <%= character.name %></title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      background: linear-gradient(135deg, #1a0033 0%, #2d1b4e 50%, #1a1a3e 100%);
      min-height: 100vh;
      color: #e8dcc8;
    }

    .companion-container {
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      padding: 20px;
    }

    .companion-header {
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 22px;
      background: rgba(45, 27, 78, 0.4);
      border-radius: 12px;
      margin-bottom: 20px;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .character-avatar {
      position: relative;
      width: 148px;
      min-width: 148px;
      height: 180px;
      border-radius: 22px;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      background:
        radial-gradient(circle at top, var(--character-accent-soft) 0%, rgba(26, 26, 62, 0) 62%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(26, 26, 62, 0.92) 100%);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12), 0 18px 40px rgba(11, 5, 24, 0.38);
      isolation: isolate;
    }

    .character-avatar::before {
      content: '';
      position: absolute;
      inset: 12px;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      pointer-events: none;
    }

    .character-avatar::after {
      content: '';
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 12px;
      height: 18px;
      border-radius: 999px;
      background: rgba(10, 7, 22, 0.5);
      filter: blur(10px);
      transform-origin: center;
      animation: shadowPulse 4s ease-in-out infinite;
    }

    .character-avatar[data-state="thinking"] .character-portrait {
      animation: characterFloat 1.8s ease-in-out infinite, characterThink 1s ease-in-out infinite;
    }

    .character-avatar[data-state="thinking"]::after {
      animation-duration: 1.8s;
      transform: scaleX(0.92);
    }

    .character-avatar[data-state="speaking"] .character-portrait {
      animation: characterFloat 2.6s ease-in-out infinite, characterSpeak 0.45s ease-in-out infinite;
    }

    .character-portrait {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center bottom;
      padding: 10px 8px 0;
      filter: drop-shadow(0 20px 22px rgba(0, 0, 0, 0.32));
      animation: characterFloat 4s ease-in-out infinite;
    }

    @keyframes characterFloat {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-7px);
      }
    }

    @keyframes characterThink {
      0%, 100% {
        transform: translateY(0) rotate(0deg);
      }
      35% {
        transform: translateY(-6px) rotate(-1.5deg);
      }
      70% {
        transform: translateY(-2px) rotate(1.5deg);
      }
    }

    @keyframes characterSpeak {
      0%, 100% {
        transform: translateY(0) scale(1);
      }
      50% {
        transform: translateY(-5px) scale(1.02);
      }
    }

    @keyframes shadowPulse {
      0%, 100% {
        opacity: 0.55;
        transform: scaleX(1);
      }
      50% {
        opacity: 0.82;
        transform: scaleX(0.88);
      }
    }

    .character-info h2 {
      font-size: 24px;
      margin-bottom: 4px;
      color: #f0e6d2;
    }

    .character-info p {
      font-size: 14px;
      color: #b8a89f;
      font-style: italic;
    }

    .character-status {
      margin-top: 10px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: #dcd1ff;
      font-style: normal;
    }

    .character-status::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--character-accent);
      box-shadow: 0 0 16px var(--character-accent-soft);
    }

    .chat-history {
      flex: 1;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 15px;
      margin-bottom: 20px;
      padding-right: 10px;
    }

    .message {
      display: flex;
      gap: 10px;
      animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .message.user {
      justify-content: flex-end;
    }

    .message-bubble {
      max-width: 550px;
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.5;
    }

    .message.user .message-bubble {
      background: linear-gradient(135deg, #6b4b9f 0%, #8b5cf6 100%);
      color: #fff;
      border-radius: 12px 4px 12px 12px;
    }

    .message.assistant .message-bubble {
      background: rgba(45, 27, 78, 0.6);
      color: #e8dcc8;
      border-radius: 4px 12px 12px 12px;
      border-left: 3px solid var(--character-accent);
    }

    .typing-indicator {
      display: flex;
      gap: 4px;
      align-items: center;
      padding: 12px 16px;
    }

    .typing-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--character-accent);
      animation: typing 1.4s infinite;
    }

    .typing-dot:nth-child(2) {
      animation-delay: 0.2s;
    }

    .typing-dot:nth-child(3) {
      animation-delay: 0.4s;
    }

    @keyframes typing {
      0%, 60%, 100% {
        opacity: 0.5;
      }
      30% {
        opacity: 1;
      }
    }

    .chat-input-area {
      display: flex;
      gap: 10px;
      padding: 15px;
      background: rgba(45, 27, 78, 0.4);
      border-radius: 12px;
      backdrop-filter: blur(10px);
    }

    .chat-input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 8px;
      background: rgba(26, 26, 62, 0.5);
      color: #e8dcc8;
      font-size: 14px;
      font-family: inherit;
    }

    .chat-input::placeholder {
      color: #8b7d93;
    }

    .chat-input:focus {
      outline: none;
      border-color: #8b5cf6;
      background: rgba(26, 26, 62, 0.8);
    }

    .send-btn {
      padding: 12px 24px;
      background: linear-gradient(135deg, #6b4b9f 0%, #8b5cf6 100%);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .send-btn:hover {
      opacity: 0.9;
    }

    .send-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      background: rgba(139, 92, 246, 0.2);
      color: #8b5cf6;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      margin-bottom: 15px;
      text-decoration: none;
    }

    .back-btn:hover {
      background: rgba(139, 92, 246, 0.3);
    }

    @media (max-width: 640px) {
      .companion-container {
        padding: 16px;
      }

      .companion-header {
        flex-direction: column;
        align-items: stretch;
      }

      .character-avatar {
        width: 100%;
        min-width: 0;
        height: 220px;
      }

      .message-bubble {
        max-width: 100%;
      }

      .chat-input-area {
        position: sticky;
        bottom: 0;
      }
    }

    ::-webkit-scrollbar {
      width: 8px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: rgba(139, 92, 246, 0.3);
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: rgba(139, 92, 246, 0.5);
    }
  </style>
</head>
<body>
  <div
    class="companion-container"
    style="--character-accent: <%= character.accentColor %>; --character-accent-soft: <%= character.accentSoft %>;"
  >
    <a href="/story" class="back-btn">← Back to story</a>

    <div class="companion-header">
      <div class="character-avatar" id="characterAvatar" data-state="idle">
        <img
          src="<%= character.portrait %>"
          alt="<%= character.name %>"
          class="character-portrait"
        >
      </div>
      <div class="character-info">
        <h2><%= character.name %></h2>
        <p><%= character.tagline %></p>
        <p class="character-status" id="characterStatus">Ready to listen</p>
      </div>
    </div>

    <div class="chat-history" id="chatHistory">
      <div class="message assistant">
        <div class="message-bubble">
          <%= character.greeting %>
        </div>
      </div>
    </div>

    <div class="chat-input-area">
      <input 
        type="text" 
        class="chat-input" 
        id="messageInput" 
        placeholder="Ask <%= character.name %>..."
        autocomplete="off"
      >
      <button class="send-btn" id="sendBtn">Send</button>
    </div>
  </div>

  <script>
    const character = <%- JSON.stringify(character) %>;
    const userContext = <%- JSON.stringify(userContext) %>;
    const characterAvatar = document.getElementById('characterAvatar');
    const characterStatus = document.getElementById('characterStatus');

    let conversationHistory = [];
    let speakingTimer = null;

    function setCharacterState(state, statusText) {
      if (characterAvatar) {
        characterAvatar.dataset.state = state;
      }

      if (characterStatus && statusText) {
        characterStatus.textContent = statusText;
      }
    }

    function showSpeakingState() {
      window.clearTimeout(speakingTimer);
      setCharacterState('speaking', `${character.name} is here with you`);
      speakingTimer = window.setTimeout(() => {
        setCharacterState('idle', 'Ready to listen');
      }, 1800);
    }

    function scrollToBottom() {
      const chatHistory = document.getElementById('chatHistory');
      chatHistory.scrollTop = chatHistory.scrollHeight;
    }

    function addMessage(role, content) {
      const chatHistory = document.getElementById('chatHistory');
      const messageDiv = document.createElement('div');
      messageDiv.className = `message ${role}`;
      messageDiv.innerHTML = `<div class="message-bubble">${escapeHtml(content)}</div>`;
      chatHistory.appendChild(messageDiv);
      
      if (role === 'user') {
        conversationHistory.push({ role: 'user', content });
      }
      
      scrollToBottom();
    }

    function showTyping() {
      setCharacterState('thinking', `${character.name} is thinking...`);
      const chatHistory = document.getElementById('chatHistory');
      const typingDiv = document.createElement('div');
      typingDiv.className = 'message assistant';
      typingDiv.id = 'typingIndicator';
      typingDiv.innerHTML = `
        <div class="typing-indicator">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      `;
      chatHistory.appendChild(typingDiv);
      scrollToBottom();
    }

    function removeTyping() {
      const typingIndicator = document.getElementById('typingIndicator');
      if (typingIndicator) {
        typingIndicator.remove();
      }
      setCharacterState('idle', 'Ready to listen');
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function sendMessage() {
      const input = document.getElementById('messageInput');
      const message = input.value.trim();

      if (!message) return;

      input.value = '';
      document.getElementById('sendBtn').disabled = true;
      setCharacterState('thinking', 'Listening to you...');

      addMessage('user', message);
      showTyping();

      try {
        const response = await fetch('/api/companion/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            characterName: character.name,
            message,
            conversationHistory,
          }),
        });

        removeTyping();

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const data = await response.json();
        addMessage('assistant', data.reply);
        conversationHistory.push({ role: 'assistant', content: data.reply });
        showSpeakingState();
      } catch (error) {
        removeTyping();
        addMessage('assistant', `Sorry, I couldn't respond right now. Try again in a moment.`);
        setCharacterState('idle', 'Ready to listen');
        console.error('Chat error:', error);
      } finally {
        document.getElementById('sendBtn').disabled = false;
        document.getElementById('messageInput').focus();
      }
    }

    document.getElementById('sendBtn').addEventListener('click', sendMessage);
    document.getElementById('messageInput').addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    document.getElementById('messageInput').focus();
  </script>
</body>
</html>
