<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HoldOff - Inbox</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, #0a001f 0%, #1a0033 50%, #0d1a3a 100%);
      color: #e0e0e0;
      min-height: 100vh;
      padding: 20px;
    }
    
    .container {
      max-width: 600px;
      margin: 0 auto;
    }
    
    .header {
      text-align: center;
      margin-bottom: 30px;
    }
    
    .header h1 {
      font-size: 28px;
      margin-bottom: 20px;
      color: #b794f6;
      font-weight: 600;
    }
    
    .button-row {
      display: flex;
      gap: 12px;
      margin-bottom: 30px;
    }
    
    .btn {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid #6b5b95;
      border-radius: 8px;
      background: #2d1b69;
      color: #e0e0e0;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    
    .btn:hover {
      background: #3d2b79;
      border-color: #8b7ab8;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #7c5dfa 0%, #6b4dee 100%);
      border-color: #7c5dfa;
      flex: 2;
    }
    
    .btn-primary:hover {
      background: linear-gradient(135deg, #8b6dff 0%, #7a5dff 100%);
    }
    
    .search-box {
      margin-bottom: 20px;
    }
    
    .search-box input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #6b5b95;
      border-radius: 8px;
      background: rgba(45, 27, 105, 0.6);
      color: #e0e0e0;
      font-size: 14px;
    }
    
    .search-box input::placeholder {
      color: #8b7ab8;
    }
    
    .section {
      margin-bottom: 30px;
    }
    
    .section-title {
      font-size: 14px;
      font-weight: 600;
      color: #b794f6;
      margin-bottom: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .contacts-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    
    .contact-card {
      padding: 12px 16px;
      border: 1px solid #6b5b95;
      border-radius: 8px;
      background: rgba(45, 27, 105, 0.5);
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: all 0.2s;
      cursor: pointer;
    }
    
    .contact-card:hover {
      background: rgba(45, 27, 105, 0.8);
      border-color: #8b7ab8;
    }
    
    .contact-info {
      flex: 1;
    }
    
    .contact-name {
      font-weight: 500;
      color: #e0e0e0;
      font-size: 14px;
    }
    
    .contact-meta {
      font-size: 12px;
      color: #8b7ab8;
      margin-top: 4px;
    }
    
    .contact-actions {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    
    .icon-btn {
      background: none;
      border: none;
      color: #8b7ab8;
      cursor: pointer;
      font-size: 16px;
      padding: 4px 8px;
      transition: color 0.2s;
    }
    
    .icon-btn:hover {
      color: #b794f6;
    }
    
    .empty-state {
      text-align: center;
      padding: 40px 20px;
      border: 1px dashed #6b5b95;
      border-radius: 8px;
      color: #8b7ab8;
    }
    
    .empty-state svg {
      width: 48px;
      height: 48px;
      margin-bottom: 12px;
      opacity: 0.5;
    }
    
    .empty-state p {
      font-size: 14px;
      margin-bottom: 12px;
    }
    
    .sync-button {
      background: #7c5dfa;
      border: none;
      color: white;
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }
    
    .sync-button:hover {
      background: #8b6dff;
    }
    
    .loading {
      text-align: center;
      color: #8b7ab8;
      padding: 20px;
    }
    
    .error {
      background: rgba(255, 0, 0, 0.1);
      border: 1px solid #cc3333;
      border-radius: 8px;
      padding: 12px 16px;
      color: #ff6b6b;
      font-size: 13px;
      margin-bottom: 16px;
    }
    
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
      margin-left: 8px;
    }
    
    .badge-risk-high {
      background: rgba(255, 107, 107, 0.3);
      color: #ff6b6b;
    }
    
    .badge-risk-med {
      background: rgba(255, 180, 76, 0.3);
      color: #ffb44c;
    }
    
    .badge-spam {
      background: rgba(200, 100, 100, 0.3);
      color: #e08080;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>HoldOff</h1>
    </div>
    
    <div class="button-row">
      <a href="/compose" class="btn btn-primary">✍️ Compose</a>
      <a href="/settings" class="btn">⚙️ Settings</a>
    </div>
    
    <div class="search-box">
      <input 
        type="text" 
        id="searchBar" 
        placeholder="🔍 Search names, numbers, messages..."
      >
    </div>
    
    <div id="errorContainer"></div>
    
    <!-- SMS & Messengers Section -->
    <div class="section">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
        <h2 class="section-title">📱 SMS & Messengers</h2>
        <button class="sync-button" onclick="syncMessengers()">🔄 Sync</button>
      </div>
      <div id="contactsList" class="contacts-list">
        <div class="loading">Loading contacts...</div>
      </div>
    </div>
    
    <!-- Recent Conversations -->
    <div class="section" id="threadsSection" style="display: none;">
      <h2 class="section-title">💬 Recent Conversations</h2>
      <div id="threadsList" class="contacts-list"></div>
    </div>
  </div>

  <script>
    // State
    let contacts = [];
    let threads = [];
    let filteredContacts = [];

    // Initialize on page load
    window.addEventListener('DOMContentLoaded', async () => {
      await loadData();
      setupSearchListener();
    });

    async function loadData() {
      try {
        showError(null);
        
        // Load contacts
        const contactsRes = await fetch('/api/messaging/contacts', {
          credentials: 'include'
        });
        
        if (!contactsRes.ok) {
          throw new Error(`Contacts API error: ${contactsRes.status}`);
        }
        
        const contactsData = await contactsRes.json();
        contacts = contactsData.contacts || [];

        // Load threads
        try {
          const threadsRes = await fetch('/api/messaging/threads', {
            credentials: 'include'
          });
          
          if (threadsRes.ok) {
            const threadsData = await threadsRes.json();
            threads = threadsData.threads || [];
          }
        } catch (e) {
          console.warn('Threads load error:', e.message);
        }

        // Render UI
        renderContacts(contacts);
        renderThreads(threads);
        
      } catch (err) {
        console.error('Load error:', err);
        showError(
          'Unable to load contacts. ' +
          (err.message.includes('401') ? 'Please log in again.' : 'Please try again.')
        );
        renderEmpty();
      }
    }

    function renderContacts(list) {
      const container = document.getElementById('contactsList');
      
      if (!list || list.length === 0) {
        renderEmpty();
        return;
      }

      filteredContacts = list;
      const html = list.map(contact => `
        <div class="contact-card" onclick="openContact('${contact.id}')">
          <div class="contact-info">
            <div class="contact-name">
              ${contact.name || 'Unknown'}
              ${contact.is_spam ? '<span class="badge badge-spam">🚫 Spam</span>' : ''}
              ${contact.risk_level === 'high' ? '<span class="badge badge-risk-high">⚠️ High Risk</span>' : ''}
            </div>
            <div class="contact-meta">
              ${contact.phone_number || 'No number'}
              ${contact.last_messaged_at ? ' • ' + formatTime(contact.last_messaged_at) : ''}
            </div>
          </div>
          <div class="contact-actions">
            <button class="icon-btn" onclick="event.stopPropagation(); toggleFavorite('${contact.id}')">
              ${contact.is_favorited ? '⭐' : '☆'}
            </button>
            <span style="color: #8b7ab8;">→</span>
          </div>
        </div>
      `).join('');
      
      container.innerHTML = html;
    }

    function renderThreads(list) {
      const section = document.getElementById('threadsSection');
      const container = document.getElementById('threadsList');
      
      if (!list || list.length === 0) {
        section.style.display = 'none';
        return;
      }

      section.style.display = 'block';
      const html = list.map(thread => `
        <div class="contact-card" onclick="openThread('${thread.id}')">
          <div class="contact-info">
            <div class="contact-name">${thread.contact_name || thread.contact_phone || 'Conversation'}</div>
            <div class="contact-meta">Last message: ${formatTime(thread.last_message_at)}</div>
          </div>
          <span style="color: #8b7ab8;">→</span>
        </div>
      `).join('');
      
      container.innerHTML = html;
    }

    function renderEmpty() {
      document.getElementById('contactsList').innerHTML = `
        <div class="empty-state">
          <div style="font-size: 32px; margin-bottom: 8px;">📭</div>
          <p>No contacts yet</p>
          <p style="font-size: 12px; color: #6b5b95;">Connect your first messenger or message someone to get started</p>
          <button class="sync-button" onclick="syncMessengers()" style="margin-top: 12px;">
            🔄 Sync Your Messengers
          </button>
        </div>
      `;
      document.getElementById('threadsSection').style.display = 'none';
    }

    function setupSearchListener() {
      const searchBar = document.getElementById('searchBar');
      searchBar.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase();
        if (!query) {
          renderContacts(contacts);
          return;
        }
        
        const filtered = contacts.filter(c => 
          (c.name && c.name.toLowerCase().includes(query)) ||
          (c.phone_number && c.phone_number.includes(query))
        );
        renderContacts(filtered);
      });
    }

    async function syncMessengers() {
      alert('Messenger sync coming soon! For now, SMS threads are automatically synced.');
    }

    async function toggleFavorite(contactId) {
      try {
        const res = await fetch(`/api/messaging/contacts/${contactId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ isFavorited: !contacts.find(c => c.id == contactId)?.is_favorited })
        });
        
        if (res.ok) {
          await loadData();
        }
      } catch (err) {
        console.error('Favorite toggle error:', err);
      }
    }

    function openContact(contactId) {
      window.location.href = `/thread/${contactId}`;
    }

    function openThread(threadId) {
      window.location.href = `/thread/${threadId}`;
    }

    function formatTime(date) {
      if (!date) return '';
      const d = new Date(date);
      const now = new Date();
      const diffMs = now - d;
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      const diffDays = Math.floor(diffMs / 86400000);
      
      if (diffMins < 1) return 'just now';
      if (diffMins < 60) return `${diffMins}m ago`;
      if (diffHours < 24) return `${diffHours}h ago`;
      if (diffDays < 7) return `${diffDays}d ago`;
      
      return d.toLocaleDateString();
    }

    function showError(msg) {
      const container = document.getElementById('errorContainer');
      if (!msg) {
        container.innerHTML = '';
        return;
      }
      container.innerHTML = `<div class="error">${msg}</div>`;
    }

    // Auto-refresh every 30 seconds
    setInterval(loadData, 30000);
  </script>
</body>
</html>
