<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HoldOff - Inbox</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
      background: linear-gradient(135deg, #0f0a1f 0%, #1a0d2e 50%, #0d1b2a 100%);
      min-height: 100vh;
      color: #e0e0e0;
    }

    .header {
      background: rgba(15, 10, 31, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(139, 92, 246, 0.3);
      padding: 1.5rem;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-content {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header h1 {
      font-size: 24px;
      font-weight: 600;
      background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .header-actions {
      display: flex;
      gap: 1rem;
    }

    .btn {
      padding: 0.6rem 1.2rem;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-primary {
      background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%);
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(139, 92, 246, 0.4);
    }

    .btn-secondary {
      background: rgba(139, 92, 246, 0.1);
      color: #8B5CF6;
      border: 1px solid rgba(139, 92, 246, 0.3);
    }

    .btn-secondary:hover {
      background: rgba(139, 92, 246, 0.2);
      border-color: rgba(139, 92, 246, 0.5);
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .inbox-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }

    .inbox-header h2 {
      font-size: 18px;
      color: #e0e0e0;
    }

    .search-bar {
      width: 100%;
      padding: 0.8rem 1rem;
      margin-bottom: 2rem;
      background: rgba(139, 92, 246, 0.1);
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 8px;
      color: #e0e0e0;
      font-size: 14px;
    }

    .search-bar::placeholder {
      color: rgba(224, 224, 224, 0.5);
    }

    .search-bar:focus {
      outline: none;
      background: rgba(139, 92, 246, 0.15);
      border-color: rgba(139, 92, 246, 0.6);
      box-shadow: 0 0 12px rgba(139, 92, 246, 0.2);
    }

    .contacts-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .contact-item {
      padding: 1rem;
      background: rgba(26, 13, 46, 0.5);
      border: 1px solid rgba(139, 92, 246, 0.2);
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
      color: inherit;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .contact-item:hover {
      background: rgba(139, 92, 246, 0.15);
      border-color: rgba(139, 92, 246, 0.4);
      transform: translateX(4px);
    }

    .contact-item.unread {
      border-left: 4px solid #8B5CF6;
      background: rgba(139, 92, 246, 0.08);
    }

    .contact-info {
      flex: 1;
      min-width: 0;
    }

    .contact-name {
      font-weight: 600;
      font-size: 15px;
      margin-bottom: 0.3rem;
      color: #e0e0e0;
    }

    .contact-preview {
      font-size: 13px;
      color: rgba(224, 224, 224, 0.6);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .contact-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
      white-space: nowrap;
    }

    .contact-time {
      font-size: 12px;
      color: rgba(224, 224, 224, 0.5);
    }

    .unread-badge {
      background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%);
      color: white;
      padding: 0.3rem 0.6rem;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      min-width: 24px;
      text-align: center;
    }

    .flag {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      margin-right: 0.5rem;
    }

    .flag.green {
      background: #4ade80;
    }

    .flag.yellow {
      background: #facc15;
    }

    .flag.red {
      background: #ef4444;
    }

    .empty-state {
      text-align: center;
      padding: 4rem 2rem;
      color: rgba(224, 224, 224, 0.5);
    }

    .empty-state svg {
      width: 80px;
      height: 80px;
      margin-bottom: 1rem;
      opacity: 0.3;
    }

    .empty-state p {
      font-size: 16px;
      margin-bottom: 1rem;
    }

    @media (max-width: 600px) {
      .container {
        padding: 1rem;
      }

      .header-content {
        flex-direction: column;
        gap: 1rem;
      }

      .header-actions {
        width: 100%;
      }

      .btn {
        flex: 1;
        justify-content: center;
      }

      .contact-meta {
        flex-direction: row;
        align-items: center;
        gap: 1rem;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="header-content">
      <h1>HoldOff</h1>
      <div class="header-actions">
        <a href="/compose" class="btn btn-primary">✍️ Compose</a>
        <button id="nativeSyncBtn" class="btn btn-secondary" type="button" style="display:none;">📲 Sync phone</button>
        <a href="/settings" class="btn btn-secondary">⚙️ Settings</a>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="inbox-header">
      <h2>Your SMS Threads</h2>
    </div>

    <input 
      type="text" 
      class="search-bar" 
      id="searchBar" 
      placeholder="🔍 Search names, numbers, messages..."
    >

    <div class="contacts-list" id="contactsList">
      <!-- Populated by JavaScript -->
    </div>

    <div id="emptyState" class="empty-state" style="display: none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
      <p>No SMS threads yet. Tap Sync phone in the APK or start a protected message.</p>
    </div>
  </div>

  <script>
    let threads = [];
    const isNativeAndroid = !!(window.Android && (typeof window.Android.getQueuedSms === 'function' || typeof window.Android.getDeviceContacts === 'function'));
    const syncBtn = document.getElementById('nativeSyncBtn');

    if (isNativeAndroid && syncBtn) {
      syncBtn.style.display = 'inline-flex';
      syncBtn.addEventListener('click', function() { syncNativeAndroid(true); });
    }

    async function syncNativeAndroid(showStatus) {
      if (!isNativeAndroid) return null;
      const payload = { contacts: [], messages: [] };

      try {
        if (window.Android && typeof window.Android.getDeviceContacts === 'function') {
          payload.contacts = JSON.parse(window.Android.getDeviceContacts() || '[]');
        }
      } catch (err) {
        payload.contacts = [];
      }

      try {
        if (window.Android && typeof window.Android.getQueuedSms === 'function') {
          payload.messages = JSON.parse(window.Android.getQueuedSms() || '[]');
        }
      } catch (err) {
        payload.messages = [];
      }

      if (!payload.contacts.length && !payload.messages.length) {
        if (showStatus) showInlineStatus('No new phone data yet. If Android asks, approve SMS/Contacts permission and tap Sync again.');
        return null;
      }

      const res = await fetch('/api/messaging/native-sync', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Sync failed');
      const result = await res.json();
      if (payload.messages.length && window.Android && typeof window.Android.clearQueuedSms === 'function') {
        window.Android.clearQueuedSms();
      }
      if (showStatus) {
        const sync = result.sync || {};
        showInlineStatus('Synced ' + (sync.contactsImported || 0) + ' contacts and ' + (sync.messagesImported || 0) + ' SMS messages.');
      }
      return result;
    }

    function showInlineStatus(text) {
      const list = document.getElementById('contactsList');
      const note = document.createElement('div');
      note.style.cssText = 'padding:.8rem 1rem;margin-bottom:.75rem;border-radius:10px;background:rgba(139,92,246,.12);border:1px solid rgba(139,92,246,.25);color:#d8ccff;font-size:13px;';
      note.textContent = text;
      list.prepend(note);
      setTimeout(function() { note.remove(); }, 4500);
    }

    async function loadThreads() {
      try {
        await syncNativeAndroid(false).catch(function() {});
        const res = await fetch('/api/messaging/threads');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        threads = data.threads || [];
        renderThreads();
      } catch (err) {
        console.error('Failed to load threads:', err);
        document.getElementById('contactsList').innerHTML =
          '<p style="color: #ef4444; text-align: center; margin: 2rem 0;">Failed to load SMS threads</p>';
      }
    }

    function renderThreads() {
      const list = document.getElementById('contactsList');
      const empty = document.getElementById('emptyState');

      if (!threads.length) {
        list.innerHTML = '';
        empty.style.display = 'block';
        return;
      }

      empty.style.display = 'none';
      list.innerHTML = threads.map(thread => {
        const name = thread.name || thread.phone_number || thread.contact_phone || 'Unknown contact';
        const phone = thread.phone_number || thread.contact_phone || '';
        const preview = thread.last_message_preview || 'No messages yet';
        return `
          <a href="/compose?threadId=${encodeURIComponent(thread.id)}" class="contact-item">
            <div class="contact-info">
              <div class="contact-name">
                <span class="flag green"></span>
                ${escapeHtml(name)}
              </div>
              <div class="contact-preview">${escapeHtml(preview)}</div>
              ${phone ? `<div class="contact-preview" style="font-size:12px;opacity:.75;">${escapeHtml(phone)}</div>` : ''}
            </div>
            <div class="contact-meta">
              <div class="contact-time">${formatTime(thread.last_message_at)}</div>
            </div>
          </a>
        `;
      }).join('');
    }

    function formatTime(timestamp) {
      if (!timestamp) return '';
      const date = new Date(timestamp);
      const now = new Date();
      const diffMs = now - date;
      const diffMins = Math.floor(diffMs / 60000);
      const diffHours = Math.floor(diffMs / 3600000);
      const diffDays = Math.floor(diffMs / 86400000);

      if (diffMins < 1) return 'now';
      if (diffMins < 60) return `${diffMins}m ago`;
      if (diffHours < 24) return `${diffHours}h ago`;
      if (diffDays < 7) return `${diffDays}d ago`;
      return date.toLocaleDateString();
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text || '';
      return div.innerHTML;
    }

    function filterThreads(query) {
      const list = document.getElementById('contactsList');
      const items = list.querySelectorAll('.contact-item');
      const q = query.toLowerCase();

      items.forEach(item => {
        const text = item.textContent.toLowerCase();
        item.style.display = text.includes(q) ? 'flex' : 'none';
      });
    }

    document.getElementById('searchBar').addEventListener('input', (e) => {
      filterThreads(e.target.value);
    });

    loadThreads();
    setInterval(loadThreads, 10000);
  </script>
</body>
</html>
