<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your HoldOff Story</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      background: linear-gradient(135deg, #1a0033 0%, #2d1b4e 50%, #1a1a3e 100%);
      min-height: 100vh;
      color: #e8dcc8;
      overflow-x: hidden;
    }

    .story-container {
      width: 100%;
      max-width: 700px;
      margin: 0 auto;
      padding: 60px 30px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .story-scene {
      opacity: 0;
      animation: fadeIn 0.8s ease-in-out forwards;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .scene-heading {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 20px;
      background: linear-gradient(135deg, #d4af9a, #c89fb0);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .scene-text {
      font-size: 18px;
      line-height: 1.8;
      color: rgba(232, 220, 200, 0.95);
      margin-bottom: 30px;
      letter-spacing: 0.3px;
    }

    .typing-cursor {
      display: inline-block;
      width: 2px;
      height: 1em;
      background: #d4af9a;
      margin-left: 3px;
      animation: blink 1s infinite;
    }

    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    .choice-button {
      display: block;
      width: 100%;
      padding: 16px 20px;
      margin-bottom: 12px;
      background: rgba(139, 107, 183, 0.3);
      border: 2px solid rgba(200, 150, 255, 0.4);
      border-radius: 8px;
      color: #e8dcc8;
      font-size: 15px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-align: left;
      animation: slideIn 0.5s ease-out forwards;
      animation-delay: 0.2s;
      opacity: 0;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .choice-button:hover {
      background: rgba(139, 107, 183, 0.5);
      border-color: rgba(200, 150, 255, 0.7);
      box-shadow: 0 0 20px rgba(139, 107, 183, 0.3);
      transform: translateX(8px);
    }

    .choice-button.selected {
      background: rgba(139, 107, 183, 0.8);
      border-color: rgba(200, 150, 255, 1);
      box-shadow: 0 0 24px rgba(139, 107, 183, 0.5);
    }

    .input-field {
      width: 100%;
      padding: 14px 16px;
      background: rgba(60, 40, 100, 0.4);
      border: 1px solid rgba(200, 150, 255, 0.3);
      border-radius: 6px;
      color: #e8dcc8;
      font-size: 15px;
      margin-bottom: 12px;
      transition: all 0.3s ease;
    }

    .input-field:focus {
      outline: none;
      background: rgba(60, 40, 100, 0.6);
      border-color: rgba(200, 150, 255, 0.6);
      box-shadow: 0 0 12px rgba(200, 150, 255, 0.2);
    }

    .input-field::placeholder {
      color: rgba(200, 150, 255, 0.3);
    }

    .progress-bar {
      height: 3px;
      background: rgba(200, 150, 255, 0.2);
      border-radius: 2px;
      margin-bottom: 40px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #8b6bb7, #6b4fa8);
      width: 0%;
      transition: width 0.3s ease;
    }

    .phase-label {
      font-size: 12px;
      text-transform: uppercase;
      color: rgba(200, 150, 255, 0.6);
      letter-spacing: 1px;
      margin-bottom: 20px;
    }

    .recap-section {
      background: rgba(139, 107, 183, 0.15);
      border: 1px solid rgba(200, 150, 255, 0.3);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 20px;
    }

    .recap-label {
      font-size: 12px;
      text-transform: uppercase;
      color: rgba(200, 150, 255, 0.6);
      margin-bottom: 8px;
    }

    .recap-value {
      font-size: 16px;
      color: #e8dcc8;
      font-weight: 500;
    }

    .submit-btn {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #8b6bb7 0%, #6b4fa8 100%);
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 10px;
    }

    .submit-btn:hover {
      background: linear-gradient(135deg, #9b7bc7 0%, #7b5fb8 100%);
      box-shadow: 0 4px 16px rgba(139, 107, 183, 0.4);
    }

    .submit-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
  </style>
</head>
<body>
  <div class="story-container">
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>

    <div id="storyContent"></div>
  </div>

  <script>
    const storyState = {
      phase: 'gender-setup', // gender-setup → stacy-story → shoes-mapping → their-story → recap
      userName: '', // Their original name (for Part 1)
      newUserName: '', // Their name change (for Part 2 shoes)
      userIdentity: null, // 'man', 'woman', 'nonbinary' (for Part 1)
      newUserIdentity: null, // 'man', 'woman', 'nonbinary' (for Part 2 shoes)
      dannyIdentity: 'man', // Danny is always a man
      stacyChoice: null,
      userPersonName: '',
      userRelationship: '',
      userSpiralTrigger: '',
      userValues: '',
      conditions: [],
      tone: 'grounded',
      language: 'direct',
      depth: 'moderate'
    };

    const stacyStory = [
      {
        heading: "I Realized My Spirals Hurt {{danny}}",
        text: "It wasn't until that Tuesday night when I watched {{danny_pronoun.possessive}} face go quiet that I finally understood. Not from a book. Not from a therapist. From {{danny_pronoun.possessive}} eyes. I'd been circling the same thought for three hours—whether {{danny_pronoun.subject}} actually wanted to be with me or if {{danny_pronoun.subject}} were just being nice. And I'd asked {{danny_pronoun.object}}, in seventeen different ways. Each time softer. Each time more desperate.",
        choices: [
          { text: "I recognized the pattern immediately", next: 'stacy-2a' },
          { text: "I tried to talk myself down first", next: 'stacy-2b' }
        ]
      },
      {
        heading: "The Pattern Became Visible",
        text: "Once you see the spiral, you can't unsee it. That loop of doubt → reassurance-seeking → temporary relief → doubt again. I was doing it in relationships, with work, in conversations. Always spiraling. Always searching for the one thing that would make the anxiety stop. But it never stopped. {{danny_pronoun.Capitalized_subject}} couldn't stop it. My therapist couldn't stop it. Only understanding it could.",
        choices: [
          { text: "I wanted to change immediately", next: 'stacy-3a' },
          { text: "I needed time to accept it first", next: 'stacy-3b' }
        ]
      },
      {
        heading: "Pausing Changed Everything",
        text: "The first time I noticed the spiral and didn't immediately ask for reassurance—even though every part of me screamed to—something shifted. It was brutal. My anxiety spiked. But then... it gradually settled. Not because {{danny_pronoun.subject}} convinced me. Because I stayed with the uncertainty. Because I tracked what triggered it. Because I chose how to respond instead of just reacting.",
        choices: [
          { text: "I'm ready to put on your shoes", next: 'shoes-mapping' }
        ]
      }
    ];

    function getPronounSet(identity) {
      const sets = {
        'man': { subject: 'he', object: 'him', possessive: 'his', Capitalized_subject: 'He' },
        'woman': { subject: 'she', object: 'her', possessive: 'her', Capitalized_subject: 'She' },
        'nonbinary': { subject: 'they', object: 'them', possessive: 'their', Capitalized_subject: 'They' }
      };
      return sets[identity] || sets['nonbinary'];
    }

    function adaptStoryText(text, userIdentity, dannyIdentity, userName) {
      const userPronouns = getPronounSet(userIdentity);
      const dannyPronouns = getPronounSet(dannyIdentity);
      
      return text
        .replace(/{{danny}}/g, 'Danny')
        .replace(/{{danny_pronoun\.subject}}/g, dannyPronouns.subject)
        .replace(/{{danny_pronoun\.object}}/g, dannyPronouns.object)
        .replace(/{{danny_pronoun\.possessive}}/g, dannyPronouns.possessive)
        .replace(/{{danny_pronoun\.Capitalized_subject}}/g, dannyPronouns.Capitalized_subject)
        .replace(/{{user}}/g, userName)
        .replace(/{{user_pronoun\.subject}}/g, userPronouns.subject)
        .replace(/{{user_pronoun\.object}}/g, userPronouns.object)
        .replace(/{{user_pronoun\.possessive}}/g, userPronouns.possessive)
        .replace(/{{user_pronoun\.Capitalized_subject}}/g, userPronouns.Capitalized_subject);
    }

    const shoesMapping = [
      {
        heading: "Put On My Shoes",
        subheading: "Now it's your turn. Let me know your story, and we'll track your patterns together.",
        questions: [
          {
            label: "What's your name?",
            input: "userName",
            placeholder: "Your name (or what you go by)"
          },
          {
            label: "How do you identify?",
            input: "userGender",
            type: "select",
            options: [
              { value: "woman", label: "Woman" },
              { value: "man", label: "Man" },
              { value: "nonbinary", label: "Non-binary" },
              { value: "other", label: "Other" }
            ]
          },
          {
            label: "Who's the person you spiral about?",
            input: "personName",
            placeholder: "Their name or how you think of them"
          },
          {
            label: "What's your relationship?",
            input: "relationship",
            placeholder: "e.g., partner, parent, friend, boss"
          },
          {
            label: "What usually triggers your spiral?",
            input: "spiralTrigger",
            placeholder: "e.g., unclear communication, perceived distance, silence"
          },
          {
            label: "What do you value most about this relationship?",
            input: "values",
            placeholder: "e.g., their honesty, stability, understanding"
          }
        ]
      }
    ];

    function render() {
      const content = document.getElementById('storyContent');
      const progress = calculateProgress();
      document.getElementById('progressFill').style.width = progress + '%';

      if (storyState.phase === 'gender-setup') {
        renderGenderSetup(content);
      } else if (storyState.phase === 'stacy-story') {
        renderStacyStory(content);
      } else if (storyState.phase === 'shoes-mapping') {
        renderShoesMapping(content);
      } else if (storyState.phase === 'their-story') {
        renderTheirStory(content);
      } else if (storyState.phase === 'recap') {
        renderRecap(content);
      }
    }

    function renderGenderSetup(content) {
      content.innerHTML = `
        <div class="phase-label">Your Story Starts Here</div>
        <div class="story-scene">
          <h2 class="scene-heading">Let's Personalize This</h2>
          <p class="scene-text" style="margin-bottom: 40px;">This story is about you spiraling about someone. Help me get the details right.</p>
          
          <div style="margin-bottom: 40px;">
            <label style="display: block; color: rgba(200, 150, 255, 0.8); font-size: 13px; text-transform: uppercase; margin-bottom: 8px;">What's your name?</label>
            <input type="text" id="userName" class="input-field" placeholder="Enter your name" style="width: 100%; padding: 12px; border: 1px solid rgba(200, 150, 255, 0.3); border-radius: 8px; background: rgba(20, 10, 30, 0.8); color: #fff;">
          </div>

          <div style="margin-bottom: 50px;">
            <label style="display: block; color: rgba(200, 150, 255, 0.8); font-size: 13px; text-transform: uppercase; margin-bottom: 20px;">How do you identify?</label>
            <div style="display: flex; gap: 15px; flex-wrap: wrap;">
              <button class="choice-button" style="flex: 1; min-width: 120px;" onclick="setGenderSetup('man', storyState.userPreference)">Man</button>
              <button class="choice-button" style="flex: 1; min-width: 120px;" onclick="setGenderSetup('woman', storyState.userPreference)">Woman</button>
              <button class="choice-button" style="flex: 1; min-width: 120px;" onclick="setGenderSetup('nonbinary', storyState.userPreference)">Non-binary</button>
            </div>
          </div>

          <div style="margin-bottom: 50px;">
            <label style="display: block; color: rgba(200, 150, 255, 0.8); font-size: 13px; text-transform: uppercase; margin-bottom: 20px;">Who are you spiraling about?</label>
            <div style="display: flex; gap: 15px; flex-wrap: wrap;">
              <button class="choice-button" style="flex: 1; min-width: 120px;" onclick="setGenderSetup(storyState.userIdentity, 'man')">Man</button>
              <button class="choice-button" style="flex: 1; min-width: 120px;" onclick="setGenderSetup(storyState.userIdentity, 'woman')">Woman</button>
              <button class="choice-button" style="flex: 1; min-width: 120px;" onclick="setGenderSetup(storyState.userIdentity, 'nonbinary')">Non-binary</button>
            </div>
          </div>

          <button class="submit-btn" style="margin-top: 40px; opacity: ${storyState.userIdentity && storyState.userPreference && document.getElementById('userName')?.value?.trim() ? '1' : '0.5'};" 
            ${storyState.userIdentity && storyState.userPreference ? 'onclick="startStacyStory()"' : 'disabled'}>
            Let's Begin
          </button>
        </div>
      `;
    }

    function setGenderSetup(identity, preference) {
      if (identity) storyState.userIdentity = identity;
      if (preference) storyState.dannyIdentity = preference;
      render();
    }

    function startStacyStory() {
      const userNameInput = document.getElementById('userName')?.value?.trim();
      if (!userNameInput) {
        alert('Please enter your name');
        return;
      }
      if (!storyState.userIdentity) {
        alert('Please select how you identify');
        return;
      }
      if (!storyState.dannyIdentity) {
        alert('Please select who you\'re spiraling about');
        return;
      }
      storyState.userName = userNameInput;
      storyState.phase = 'stacy-story';
      render();
    }

    function renderStacyStory(content) {
      const sceneKey = storyState.stacyChoice || 'stacy-1';
      let scene;

      if (sceneKey === 'stacy-1') {
        scene = stacyStory[0];
      } else if (sceneKey === 'stacy-2a' || sceneKey === 'stacy-2b') {
        scene = stacyStory[1];
      } else if (sceneKey.startsWith('stacy-3')) {
        scene = stacyStory[2];
      }

      if (!scene) return;

      const adaptedHeading = adaptStoryText(scene.heading, storyState.userIdentity, storyState.dannyIdentity, storyState.userName);
      const adaptedText = adaptStoryText(scene.text, storyState.userIdentity, storyState.dannyIdentity, storyState.userName);

      content.innerHTML = `
        <div class="phase-label">Part 1: Your Story</div>
        <div class="story-scene">
          <h2 class="scene-heading">${adaptedHeading}</h2>
          <p class="scene-text">${adaptedText}</p>
          <div>
            ${scene.choices.map((choice, idx) => `
              <button class="choice-button" onclick="selectStacyChoice('${choice.next}')">
                ${choice.text}
              </button>
            `).join('')}
          </div>
        </div>
      `;
    }

    function renderShoesMapping(content) {
      const questions = shoesMapping[0].questions;
      content.innerHTML = `
        <div class="phase-label">Part 2: Put On My Shoes</div>
        <div class="story-scene">
          <h2 class="scene-heading">${shoesMapping[0].heading}</h2>
          <p class="scene-text" style="margin-bottom: 30px;">${shoesMapping[0].subheading}</p>
          <div>
            ${questions.map((q, idx) => `
              <div style="margin-bottom: 20px;">
                <label style="display: block; color: rgba(200, 150, 255, 0.8); font-size: 13px; text-transform: uppercase; margin-bottom: 8px;">${q.label}</label>
                ${q.type === 'select' ? `
                  <select class="input-field" id="${q.input}">
                    <option value="">Select...</option>
                    ${q.options.map(opt => `<option value="${opt.value}">${opt.label}</option>`).join('')}
                  </select>
                ` : `
                  <input type="text" class="input-field" id="${q.input}" placeholder="${q.placeholder}">
                `}
              </div>
            `).join('')}
            <button class="submit-btn" onclick="submitShoesMapping()">Continue to Your Story</button>
          </div>
        </div>
      `;
    }

    function renderTheirStory(content) {
      const { userPersonName, userRelationship, userSpiralTrigger, userValues, newUserName, newUserIdentity } = storyState;
      const userPronouns = getPronounSet(newUserIdentity);
      
      const theirStory = `
        <p class="scene-text">It started with ${userSpiralTrigger} and ${userPersonName}. You weren't sure where you stood, and the uncertainty felt impossible to sit with. So ${userPronouns.subject} spiraled—searching for signs, asking questions in a dozen different ways, looking for the one answer that would make the anxiety vanish.</p>
        <p class="scene-text">But ${userPersonName} couldn't give ${userPronouns.object} what ${userPronouns.subject} was looking for. Because what ${userPronouns.subject} was really looking for was certainty about ${userPronouns.reflexive}, not about ${userPersonName}. And that's not something anyone else can provide.</p>
        <p class="scene-text">What ${userPersonName} <strong>could</strong> do—and still can—is notice when ${userPronouns.subject}'re spiraling and help pause. To track what triggers it. To understand that the spiral isn't a character flaw. It's a pattern. And patterns can be understood.</p>
      `;

      content.innerHTML = `
        <div class="phase-label">Part 3: Your Story</div>
        <div class="story-scene">
          <h2 class="scene-heading">Your ${userRelationship} is Worth Understanding</h2>
          ${theirStory}
          <button class="submit-btn" onclick="moveToRecap()">See Your Personalized Setup</button>
        </div>
      `;
    }

    function renderRecap(content) {
      content.innerHTML = `
        <div class="phase-label">Part 4: Your HoldOff Setup</div>
        <div class="story-scene">
          <h2 class="scene-heading">Ready to Pause & Understand</h2>
          <p class="scene-text" style="margin-bottom: 30px;">You've walked through both stories. Now let's personalize how HoldOff feels to you.</p>
          
          <div class="recap-section">
            <div class="recap-label">Person of Interest</div>
            <div class="recap-value">${storyState.userPersonName}</div>
          </div>
          
          <div class="recap-section">
            <div class="recap-label">Relationship Type</div>
            <div class="recap-value">${storyState.userRelationship}</div>
          </div>

          <div class="recap-section">
            <div class="recap-label">How HoldOff Talks to You</div>
            <select id="toneSelect" class="input-field" onchange="storyState.tone = this.value">
              <option value="grounded">Grounded & practical</option>
              <option value="poetic">Poetic & reflective</option>
              <option value="direct">Direct & blunt</option>
              <option value="warm">Warm & supportive</option>
            </select>
          </div>

          <div class="recap-section">
            <div class="recap-label">Analysis Depth</div>
            <select id="depthSelect" class="input-field" onchange="storyState.depth = this.value">
              <option value="light">Light (key patterns only)</option>
              <option value="moderate">Moderate (balanced insights)</option>
              <option value="deep">Deep (detailed breakdown)</option>
            </select>
          </div>

          <div class="recap-section">
            <div class="recap-label">Mental Health Conditions to Track</div>
            <div style="display: grid; gap: 8px;">
              ${['RSD', 'Anxiety', 'Depression', 'Addiction', 'Attachment Issues', 'Autism', 'ADHD'].map(cond => `
                <label style="display: flex; align-items: center; cursor: pointer;">
                  <input type="checkbox" class="condition-check" value="${cond}" style="margin-right: 10px; cursor: pointer;">
                  <span>${cond}</span>
                </label>
              `).join('')}
            </div>
          </div>

          <div style="margin: 30px 0; padding: 20px; background: rgba(139, 92, 246, 0.1); border-radius: 12px; border-left: 3px solid #8b5cf6;">
            <p style="margin-bottom: 15px; font-size: 14px; color: #b8a89f;">Have questions? Chat with Stacy or Danny about their stories and what you're figuring out:</p>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <button class="submit-btn" style="flex: 1; min-width: 150px; background: linear-gradient(135deg, #c77dff 0%, #b8a89f 100%);" onclick="window.location.href='/companion/Stacy'">Chat with Stacy 💜</button>
              <button class="submit-btn" style="flex: 1; min-width: 150px; background: linear-gradient(135deg, #6b5bdb 0%, #5a4f9f 100%);" onclick="window.location.href='/companion/Danny'">Chat with Danny 💙</button>
            </div>
          </div>

          <button class="submit-btn" onclick="finishOnboarding()">Enter HoldOff</button>
        </div>
      `;

      // Re-attach condition listeners
      document.querySelectorAll('.condition-check').forEach(check => {
        check.addEventListener('change', (e) => {
          if (e.target.checked) {
            if (!storyState.conditions.includes(e.target.value)) {
              storyState.conditions.push(e.target.value);
            }
          } else {
            storyState.conditions = storyState.conditions.filter(c => c !== e.target.value);
          }
        });
      });
    }

    function selectStacyChoice(nextKey) {
      storyState.stacyChoice = nextKey;
      if (nextKey === 'shoes-mapping') {
        storyState.phase = 'shoes-mapping';
      }
      render();
    }

    function submitShoesMapping() {
      const newUserName = document.getElementById('userName').value.trim();
      const newUserGender = document.getElementById('userGender').value;
      const personName = document.getElementById('personName').value.trim();
      const relationship = document.getElementById('relationship').value.trim();
      const spiralTrigger = document.getElementById('spiralTrigger').value.trim();
      const values = document.getElementById('values').value.trim();

      if (!newUserName || !newUserGender || !personName || !relationship || !spiralTrigger || !values) {
        alert('Please fill in all fields');
        return;
      }

      storyState.newUserName = newUserName;
      storyState.newUserIdentity = newUserGender;
      storyState.userPersonName = personName;
      storyState.userRelationship = relationship;
      storyState.userSpiralTrigger = spiralTrigger;
      storyState.userValues = values;
      storyState.phase = 'their-story';
      render();
    }

    function moveToRecap() {
      storyState.phase = 'recap';
      render();
    }

    function getPronoun(type) {
      if (storyState.userPreference === 'women') {
        return { subject: 'she', object: 'her', possessive: 'her' }[type] || 'she';
      } else if (storyState.userPreference === 'men') {
        return { subject: 'he', object: 'him', possessive: 'his' }[type] || 'he';
      } else {
        return { subject: 'they', object: 'them', possessive: 'their' }[type] || 'they';
      }
    }

    function calculateProgress() {
      const phases = ['gender-setup', 'stacy-story', 'shoes-mapping', 'their-story', 'recap'];
      const currentPhaseIdx = phases.indexOf(storyState.phase);
      return ((currentPhaseIdx + 1) / phases.length) * 100;
    }

    function finishOnboarding() {
      const conditions = Array.from(document.querySelectorAll('.condition-check:checked')).map(c => c.value);
      storyState.conditions = conditions;

      // Save preferences and redirect to dashboard
      fetch('/api/preferences/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          personOfInterest: storyState.userPersonName,
          relationshipType: storyState.userRelationship,
          spiralTrigger: storyState.userSpiralTrigger,
          values: storyState.userValues,
          tone: storyState.tone,
          depth: storyState.depth,
          conditions: storyState.conditions
        })
      })
      .then(r => r.json())
      .then(data => {
        window.location.href = '/dashboard';
      })
      .catch(err => {
        alert('Error saving preferences. Redirecting anyway.');
        window.location.href = '/dashboard';
      });
    }

    // Initial render
    render();
  </script>
</body>
