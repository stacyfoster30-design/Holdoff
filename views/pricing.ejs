<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HoldOff Pricing — Respect Yourself</title>
  <meta name="description" content="Simple pricing. Real tools. One goal: help you stop settling.">

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: linear-gradient(135deg, #0F172A 0%, #1a1f3a 50%, #2d1b4e 100%);
      color: #e0e7ff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* ── HEADER ─────────────────────────────────────────── */
    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 2rem;
      max-width: 1400px;
      margin: 0 auto;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo { font-size: 22px; font-weight: 800; color: #c4b5fd; text-decoration: none; }

    nav { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; }

    nav a {
      color: #cbd5e1; text-decoration: none; font-size: 14px; transition: color 0.2s;
    }
    nav a:hover { color: #a78bfa; }

    .nav-user {
      font-size: 13px; color: #94a3b8;
      display: none; /* shown via JS */
    }
    .nav-user span { color: #a78bfa; font-weight: 600; }

    .btn-nav {
      padding: 8px 18px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: white; border: none; border-radius: 8px;
      cursor: pointer; font-weight: 600; font-size: 13px;
      text-decoration: none; display: inline-block; transition: all 0.2s;
    }
    .btn-nav:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(139,92,246,.35); }
    .btn-nav.outline {
      background: transparent; border: 2px solid #8b5cf6; color: #a78bfa;
    }
    .btn-nav.outline:hover { background: rgba(139,92,246,.15); }

    /* ── HERO ─────────────────────────────────────────────── */
    .hero {
      text-align: center;
      padding: 60px 2rem 30px;
      max-width: 860px;
      margin: 0 auto;
    }
    .hero h1 {
      font-size: clamp(32px, 6vw, 54px);
      font-weight: 800;
      background: linear-gradient(135deg, #a78bfa, #93c5fd);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
    }
    .hero p { font-size: 18px; color: #cbd5e1; }

    /* ── PRICING SECTION ──────────────────────────────────── */
    .pricing-section {
      max-width: 1200px;
      margin: 60px auto;
      padding: 0 2rem;
    }

    .section-title {
      text-align: center;
      font-size: 28px;
      color: #a78bfa;
      margin-bottom: 0.75rem;
    }
    .section-sub {
      text-align: center;
      color: #94a3b8;
      font-size: 15px;
      margin-bottom: 3rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(139,92,246,.2);
      border-radius: 14px;
      padding: 2rem 1.75rem;
      display: flex; flex-direction: column;
      position: relative;
      transition: all 0.3s;
    }
    .card:hover {
      border-color: rgba(139,92,246,.5);
      background: rgba(139,92,246,.08);
      transform: translateY(-6px);
    }
    .card.featured {
      border-color: #8b5cf6;
      background: rgba(139,92,246,.14);
    }
    .card.featured:hover { transform: translateY(-8px); }

    .card-badge {
      position: absolute; top: -11px; left: 18px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: #fff; padding: 3px 12px; border-radius: 20px;
      font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
    }
    .card-badge.hot { background: linear-gradient(135deg, #f59e0b, #d97706); }

    .card-name {
      font-size: 17px; font-weight: 700; color: #a78bfa;
      margin-top: 0.5rem; margin-bottom: 0.4rem;
    }
    .card-desc { font-size: 13px; color: #64748b; margin-bottom: 1.25rem; line-height: 1.5; }

    .card-price {
      font-size: 40px; font-weight: 800; color: #a78bfa; line-height: 1;
    }
    .card-period { font-size: 13px; color: #94a3b8; margin-bottom: 1.5rem; }
    .card-note { font-size: 12px; color: #10b981; font-weight: 600; margin-bottom: 1.5rem; }

    .card-features {
      list-style: none; flex-grow: 1; margin-bottom: 1.75rem;
    }
    .card-features li {
      font-size: 13px; color: #cbd5e1;
      padding: 0.6rem 0;
      border-bottom: 1px solid rgba(139,92,246,.1);
    }
    .card-features li:last-child { border-bottom: none; }
    .card-features li::before { content: "✓ "; color: #10b981; font-weight: 700; }

    .btn-card {
      width: 100%; padding: 12px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: white; border: none; border-radius: 8px;
      font-weight: 600; font-size: 14px;
      cursor: pointer; text-decoration: none;
      text-align: center; display: block;
      transition: all 0.2s;
    }
    .btn-card:hover { transform: translateY(-2px); box-shadow: 0 10px 24px rgba(139,92,246,.35); }
    .btn-card.outline {
      background: transparent; border: 2px solid #a78bfa; color: #a78bfa;
    }
    .btn-card.outline:hover { background: rgba(167,139,250,.12); }

    /* ── GIFT SECTION ─────────────────────────────────────── */
    .gift-section {
      max-width: 860px;
      margin: 0 auto 5rem;
      padding: 0 2rem;
    }
    .gift-card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(139,92,246,.3);
      border-radius: 18px;
      padding: 2.5rem 2.5rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .gift-card::before {
      content: "";
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(139,92,246,.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .gift-emoji { font-size: 40px; margin-bottom: 1rem; display: block; }
    .gift-card h2 { font-size: 26px; color: #a78bfa; margin-bottom: 1.25rem; }
    .gift-card blockquote {
      font-size: 15px; color: #cbd5e1; font-style: italic;
      line-height: 1.8; max-width: 640px; margin: 0 auto 0.75rem;
      border-left: 3px solid rgba(139,92,246,.4);
      padding-left: 1rem; text-align: left;
    }
    .gift-card cite {
      display: block; font-size: 12px; color: #64748b;
      text-align: right; margin-bottom: 2rem; margin-top: 0.5rem;
      font-style: normal;
    }
    .btn-gift {
      display: inline-block;
      padding: 14px 36px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: white; border: none; border-radius: 10px;
      font-size: 16px; font-weight: 700;
      cursor: pointer; text-decoration: none;
      transition: all 0.2s;
    }
    .btn-gift:hover { transform: translateY(-2px); box-shadow: 0 14px 28px rgba(139,92,246,.4); }
    .gift-note { font-size: 12px; color: #64748b; margin-top: 1rem; }

    /* ── ADD-ONS ──────────────────────────────────────────── */
    .addons-section {
      max-width: 860px;
      margin: 0 auto 5rem;
      padding: 0 2rem;
    }
    .addons-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }
    .addon-card {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(139,92,246,.15);
      border-radius: 10px;
      padding: 1.25rem 1rem;
      text-align: center;
    }
    .addon-name { font-size: 14px; font-weight: 600; color: #a78bfa; margin-bottom: 0.4rem; }
    .addon-price { font-size: 20px; font-weight: 800; color: #e0e7ff; margin-bottom: 0.4rem; }
    .addon-desc { font-size: 12px; color: #64748b; }

    /* ── FAQ ──────────────────────────────────────────────── */
    .faq-section {
      max-width: 760px;
      margin: 0 auto 5rem;
      padding: 0 2rem;
    }
    .faq-item {
      border: 1px solid rgba(139,92,246,.15);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 0.75rem;
      cursor: pointer;
      background: rgba(255,255,255,.02);
    }
    .faq-item h3 { font-size: 15px; color: #a78bfa; margin-bottom: 0; }
    .faq-item p { font-size: 13px; color: #94a3b8; line-height: 1.7; margin-top: 0.75rem; display: none; }
    .faq-item.open p { display: block; }
    .faq-item.open h3::after { content: " ▲"; font-size: 10px; }
    .faq-item h3::after { content: " ▼"; font-size: 10px; color: #64748b; }

    /* ── PROMO CODE ──────────────────────────────────────────── */
    .promo-section {
      max-width: 560px;
      margin: 0 auto 60px;
      padding: 0 2rem;
    }
    .promo-box {
      background: rgba(139, 92, 246, 0.08);
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 20px;
      padding: 2rem 2rem 1.75rem;
      text-align: center;
    }
    .promo-icon { font-size: 32px; margin-bottom: 0.5rem; }
    .promo-title { font-size: 22px; font-weight: 700; color: #c4b5fd; margin-bottom: 0.5rem; }
    .promo-sub { font-size: 14px; color: #94a3b8; margin-bottom: 1.5rem; }
    .promo-form {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .promo-input {
      padding: 12px 18px;
      border: 1px solid rgba(139,92,246,.4);
      border-radius: 10px;
      background: rgba(15,23,42,.6);
      color: #e0e7ff;
      font-size: 16px;
      font-family: monospace;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      width: 200px;
      outline: none;
      transition: border-color 0.2s;
    }
    .promo-input:focus { border-color: #8b5cf6; }
    .promo-input::placeholder { text-transform: none; letter-spacing: normal; color: #475569; font-family: inherit; }
    .btn-promo {
      padding: 12px 24px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-promo:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(139,92,246,.35); }
    .btn-promo:disabled { opacity: 0.6; cursor: default; transform: none; }
    .promo-msg {
      margin-top: 1rem;
      font-size: 14px;
      min-height: 20px;
      font-weight: 500;
    }

    /* ── DISCLAIMER / FOOTER ──────────────────────────────── */
    .disclaimer {
      text-align: center; padding: 2rem 2rem 1rem;
      color: #475569; font-size: 11px;
      border-top: 1px solid rgba(139,92,246,.15);
      max-width: 800px; margin: 0 auto;
      line-height: 1.7;
    }

    footer {
      text-align: center; padding: 2rem;
      color: #475569; font-size: 12px;
      border-top: 1px solid rgba(139,92,246,.1);
    }
    footer a { color: #7c3aed; text-decoration: none; margin: 0 .4rem; }
    footer a:hover { color: #a78bfa; }
  </style>
</head>
