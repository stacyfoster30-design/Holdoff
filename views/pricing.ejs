  <script>
    // ── Auth header state ─────────────────────────────────────
    (function() {
      const cookies = document.cookie.split(';').reduce((a, c) => {
        const [k, v] = c.trim().split('=');
        a[k] = decodeURIComponent(v || '');
        return a;
      }, {});

      const loggedIn = !!(cookies.auth_token || cookies.holdoff_session);
      const name = cookies.holdoff_name || cookies.display_name || '';

      if (loggedIn) {
        document.getElementById('nav-signin').style.display = 'none';
        document.getElementById('nav-subscribe').style.display = 'none';
        document.getElementById('nav-signout').style.display = 'inline-block';
        document.getElementById('nav-settings').style.display = 'inline-block';
        const userEl = document.getElementById('nav-user');
        if (name) {
          document.getElementById('nav-name').textContent = name;
          userEl.style.display = 'inline';
        }
      }
    })();

    // ── FAQ toggle ────────────────────────────────────────────
    function toggleFaq(el) {
      el.classList.toggle('open');
    }

    // ── Promo code redemption ─────────────────────────────────
    async function applyPromo() {
      const input = document.getElementById('promoInput');
      const msg   = document.getElementById('promoMsg');
      const code  = (input.value || '').trim();
      if (!code) { showPromoMsg('Please enter a promo code.', false); return; }

      const btn = document.querySelector('.btn-promo');
      btn.disabled = true;
      btn.textContent = 'Applying…';
      msg.textContent = '';

      try {
        const res  = await fetch('/api/redeem', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ code }),
        });
        const data = await res.json();
        if (data.ok) {
          showPromoMsg('✨ Code accepted! You now have free access. Welcome to HoldOff.', true);
          document.getElementById('promoForm').style.opacity = '0.5';
          document.getElementById('promoForm').style.pointerEvents = 'none';
        } else if (res.status === 401) {
          showPromoMsg('Sign in or create a free account first, then come back and enter your code.', false);
        } else {
          showPromoMsg(data.error || 'That code didn\'t work. Double-check it and try again.', false);
        }
      } catch(e) {
        showPromoMsg('Something went wrong. Please try again in a moment.', false);
      }

      btn.disabled = false;
      btn.textContent = 'Apply';
    }

    function showPromoMsg(text, success) {
      const msg = document.getElementById('promoMsg');
      msg.textContent = text;
      msg.style.color = success ? '#86efac' : '#fca5a5';
    }

    document.getElementById('promoInput').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') applyPromo();
    });

    // ── Checkout event tracking (lightweight) ─────────────────
    function trackCheckout(tier) {
      try {
        fetch('/api/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ event: 'checkout_click', tier }),
        }).catch(() => {});
      } catch(e) {}
    }
  </script>

</body>
</html>
