<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HoldOff Pricing — AI-Powered Messaging Safety</title>
  <meta name="description" content="Protect your relationships with AI-powered message analysis. From $5/month.">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #8B5CF6;
      --primary-dark: #6D28D9;
      --accent: #3B82F6;
      --accent-dark: #1E40AF;
      --rose: #EC4899;
      --green-safe: #10B981;
      --yellow-warn: #F59E0B;
      --red-danger: #EF4444;
      --bg-dark: #0F172A;
      --bg-darker: #09101F;
      --bg-card: #1A2847;
      --text-primary: #F1F5F9;
      --text-muted: #CBD5E1;
      --text-dim: #94A3B8;
      --border: #334155;
      --glow-primary: rgba(139, 92, 246, 0.1);
      --radius: 12px;
      --transition: all 0.3s ease;
    }

    html, body {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, var(--bg-darker) 0%, #1a1f3a 100%);
      color: var(--text-primary);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
      line-height: 1.6;
    }

    a { color: var(--primary); text-decoration: none; transition: var(--transition); }
    a:hover { color: var(--primary-dark); }

    .nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(15, 23, 42, 0.95);
      backdrop-filter: blur(10px);
    }

    .nav-logo {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-links {
      display: flex;
      gap: 32px;
      align-items: center;
    }

    .nav-link {
      color: var(--text-muted);
      font-size: 0.95rem;
      transition: var(--transition);
    }

    .nav-link:hover {
      color: var(--primary);
    }

    .btn {
      display: inline-block;
      padding: 10px 24px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: var(--transition);
      border: none;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(139, 92, 246, 0.3);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-muted);
      border: 1px solid var(--border);
    }

    .btn-ghost:hover {
      border-color: var(--primary);
      color: var(--primary);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* HERO SECTION */
    .hero {
      text-align: center;
      padding: 80px 24px;
      background: linear-gradient(180deg, var(--bg-darker) 0%, rgba(107, 40, 215, 0.05) 50%, transparent 100%);
    }

    .hero-eyebrow {
      display: inline-block;
      padding: 8px 16px;
      background: var(--glow-primary);
      border: 1px solid var(--primary);
      border-radius: 20px;
      color: var(--primary);
      font-size: 0.85rem;
      font-weight: 600;
      margin-bottom: 24px;
    }

    .hero h1 {
      font-size: 3.5rem;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 50%, var(--rose) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 1.2rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto 40px;
      line-height: 1.6;
    }

    .hero-ctas {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* FEATURES GRID */
    .features-section {
      padding: 80px 24px;
      background: var(--bg-dark);
    }

    .section-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .section-header h2 {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 12px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 28px;
      margin-bottom: 60px;
    }

    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px;
      transition: var(--transition);
    }

    .feature-card:hover {
      border-color: var(--primary);
      transform: translateY(-8px);
      box-shadow: 0 12px 40px rgba(139, 92, 246, 0.2);
    }

    .feature-icon {
      font-size: 2.5rem;
      margin-bottom: 16px;
      display: block;
    }

    .feature-card h3 {
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-primary);
    }

    .feature-card p {
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .feature-bullets {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .bullet {
      display: flex;
      gap: 8px;
      align-items: flex-start;
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    .bullet-check {
      color: var(--green-safe);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* PRICING SECTION */
    .pricing-section {
      padding: 80px 24px;
      background: linear-gradient(135deg, var(--bg-darker) 0%, rgba(59, 130, 246, 0.05) 100%);
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 32px;
      max-width: 1000px;
      margin: 0 auto;
    }

    .pricing-card {
      background: var(--bg-card);
      border: 2px solid var(--border);
      border-radius: var(--radius);
      padding: 40px;
      position: relative;
      transition: var(--transition);
    }

    .pricing-card.popular {
      border-color: var(--primary);
      transform: scale(1.05);
      box-shadow: 0 20px 60px rgba(139, 92, 246, 0.3);
    }

    .pricing-card:hover {
      border-color: var(--primary);
    }

    .price-badge {
      display: inline-block;
      background: var(--glow-primary);
      border: 1px solid var(--primary);
      color: var(--primary);
      padding: 4px 12px;
      border-radius: 16px;
      font-size: 0.75rem;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .price-badge.popular {
      background: rgba(139, 92, 246, 0.2);
    }

    .pricing-card h3 {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--text-primary);
    }

    .pricing-card-desc {
      color: var(--text-muted);
      font-size: 0.9rem;
      margin-bottom: 24px;
    }

    .price-amount {
      font-size: 2.5rem;
      font-weight: 900;
      color: var(--primary);
      margin-bottom: 4px;
    }

    .price-period {
      color: var(--text-dim);
      font-size: 0.9rem;
      margin-bottom: 24px;
    }

    .price-cta {
      width: 100%;
      padding: 14px 24px;
      margin-bottom: 32px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--primary);
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }

    .price-cta:hover {
      background: var(--glow-primary);
      border-color: var(--primary);
    }

    .pricing-card.popular .price-cta {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
    }

    .pricing-card.popular .price-cta:hover {
      background: var(--primary-dark);
    }

    .features-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .feature-item {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    .check {
      color: var(--green-safe);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .cross {
      color: var(--text-dim);
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* FAQ SECTION */
    .faq-section {
      padding: 80px 24px;
      background: var(--bg-dark);
    }

    .faq-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      max-width: 1000px;
      margin: 0 auto;
    }

    .faq-item {
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .faq-item:last-child {
      border-bottom: none;
    }

    .faq-question {
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .faq-answer {
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* FOOTER */
    footer {
      text-align: center;
      padding: 40px 24px;
      border-top: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 0.9rem;
    }

    .footer-links {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 20px;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .nav {
        padding: 16px 20px;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .hero-sub {
        font-size: 1rem;
      }

      .hero-ctas {
        flex-direction: column;
      }

      .hero-ctas > * {
        width: 100%;
      }

      .features-grid {
        grid-template-columns: 1fr;
      }

      .pricing-grid {
        grid-template-columns: 1fr;
      }

      .pricing-card.popular {
        transform: scale(1);
      }

      .faq-grid {
        grid-template-columns: 1fr;
      }

      .section-header h2 {
        font-size: 1.8rem;
      }
    }

    /* ===== LIVELY ANIMATIONS ===== */
    /* Floating aurora background */
    .aurora {
      position: fixed;
      inset: 0;
      z-index: -2;
      overflow: hidden;
      pointer-events: none;
    }
    .aurora span {
      position: absolute;
      display: block;
      border-radius: 50%;
      filter: blur(90px);
      opacity: 0.45;
      mix-blend-mode: screen;
      animation: drift 22s ease-in-out infinite alternate;
    }
    .aurora .a1 { width: 480px; height: 480px; top: -120px; left: -100px;
      background: radial-gradient(circle, #6D28D9, transparent 70%); animation-delay: 0s; }
    .aurora .a2 { width: 560px; height: 560px; top: 20%; right: -160px;
      background: radial-gradient(circle, #1E40AF, transparent 70%); animation-delay: -6s; }
    .aurora .a3 { width: 420px; height: 420px; bottom: -140px; left: 25%;
      background: radial-gradient(circle, #8B5CF6, transparent 70%); animation-delay: -12s; }
    @keyframes drift {
      0%   { transform: translate(0,0) scale(1); }
      50%  { transform: translate(60px,-50px) scale(1.15); }
      100% { transform: translate(-40px,40px) scale(0.95); }
    }

    /* Animated gradient text shimmer */
    .hero h1, .section-header h2 {
      background-size: 220% auto;
      animation: shimmer 6s linear infinite;
    }
    @keyframes shimmer {
      to { background-position: 220% center; }
    }

    /* Hero entrance */
    .hero-eyebrow { animation: fadeUp 0.7s ease both; }
    .hero h1 { animation: fadeUp 0.8s ease 0.1s both, shimmer 6s linear infinite; }
    .hero-sub { animation: fadeUp 0.8s ease 0.25s both; }
    .hero-ctas { animation: fadeUp 0.8s ease 0.4s both; }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Pulsing primary CTA glow */
    .hero-ctas .btn-primary {
      position: relative;
      animation: pulseGlow 2.6s ease-in-out infinite;
    }
    @keyframes pulseGlow {
      0%,100% { box-shadow: 0 0 0 0 rgba(139,92,246,0.45); }
      50%     { box-shadow: 0 0 28px 6px rgba(139,92,246,0.55); }
    }

    /* Eyebrow soft float */
    .hero-eyebrow { will-change: transform; }
    .hero-eyebrow::after { content: ""; }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.7s cubic-bezier(.2,.7,.2,1), transform 0.7s cubic-bezier(.2,.7,.2,1);
      will-change: opacity, transform;
    }
    .reveal.in { opacity: 1; transform: translateY(0); }

    /* Card hover lift already exists — add icon bounce */
    .feature-card:hover .feature-icon { animation: bounce 0.6s ease; }
    @keyframes bounce {
      0%,100% { transform: translateY(0); }
      30% { transform: translateY(-8px) scale(1.12); }
      60% { transform: translateY(0) scale(1); }
    }

    /* Popular pricing card subtle breathe */
    .pricing-card.popular { animation: breathe 4s ease-in-out infinite; }
    @keyframes breathe {
      0%,100% { box-shadow: 0 0 0 1px var(--primary), 0 18px 50px rgba(139,92,246,0.18); }
      50%     { box-shadow: 0 0 0 1px var(--primary), 0 22px 60px rgba(139,92,246,0.34); }
    }

    @media (prefers-reduced-motion: reduce) {
      *, .aurora span, .hero h1, .hero-eyebrow, .hero-sub, .hero-ctas,
      .hero-ctas .btn-primary, .pricing-card.popular, .reveal {
        animation: none !important;
        transition: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
    }
  </style>
</head>
<body>
