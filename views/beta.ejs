<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Join the HoldOff Beta — Be First</title>
  <meta name="description" content="Sign up to be an early tester for HoldOff — the app that helps you pause before you send. Get early access before public launch.">
  <meta property="og:title" content="Join the HoldOff Beta">
  <meta property="og:description" content="Be one of the first to try HoldOff. Sign up for early Android access.">
  <meta property="og:image" content="https://shouldiholdoff.live/og-image.png">

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: linear-gradient(135deg, #0F172A 0%, #1a1f3a 50%, #2d1b4e 100%);
      color: #e0e7ff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .logo { font-size: 24px; font-weight: 700; color: #c4b5fd; text-decoration: none; }
    nav a {
      color: #cbd5e1;
      text-decoration: none;
      margin: 0 1rem;
      font-size: 14px;
      transition: color 0.2s;
    }
    nav a:hover { color: #a78bfa; }

    .hero {
      text-align: center;
      padding: 60px 2rem 20px;
      max-width: 700px;
      margin: 0 auto;
    }

    .badge {
      display: inline-block;
      background: rgba(139, 92, 246, 0.2);
      border: 1px solid rgba(139, 92, 246, 0.5);
      color: #a78bfa;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 20px;
      margin-bottom: 1.5rem;
    }

    .hero h1 {
      font-size: 52px;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.2rem;
      background: linear-gradient(135deg, #c4b5fd, #93c5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 18px;
      color: #94a3b8;
      max-width: 540px;
      margin: 0 auto 1rem;
    }

    .perks {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
      margin: 2rem auto 0;
      max-width: 600px;
    }

    .perk {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 13px;
      color: #a78bfa;
      font-weight: 600;
    }

    .perk .icon { font-size: 16px; }

    .form-wrap {
      max-width: 560px;
      width: 100%;
      margin: 40px auto 60px;
      padding: 0 1.5rem;
    }

    .form-card {
      background: rgba(15, 23, 42, 0.7);
      border: 1px solid rgba(139, 92, 246, 0.3);
      border-radius: 16px;
      padding: 2.5rem;
      backdrop-filter: blur(10px);
    }

    .form-card h2 {
      font-size: 22px;
      font-weight: 700;
      color: #e0e7ff;
      margin-bottom: 0.4rem;
    }

    .form-card .sub {
      font-size: 14px;
      color: #64748b;
      margin-bottom: 2rem;
    }

    .form-group { margin-bottom: 1.25rem; }

    .form-group label {
      display: block;
      margin-bottom: 0.4rem;
      font-size: 13px;
      font-weight: 600;
      color: #a78bfa;
      letter-spacing: 0.5px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 12px 14px;
      background: rgba(30, 41, 59, 0.6);
      border: 1px solid rgba(139, 92, 246, 0.2);
      border-radius: 8px;
      color: #e0e7ff;
      font-family: inherit;
      font-size: 15px;
      transition: border-color 0.2s;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder { color: #475569; }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #8b5cf6;
      background: rgba(30, 41, 59, 0.9);
    }

    .form-group select option { background: #1a1f3a; }

    .form-group textarea { resize: vertical; min-height: 80px; }

    .submit-btn {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.25s;
      margin-top: 0.5rem;
      letter-spacing: 0.3px;
    }

    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(139, 92, 246, 0.4);
    }

    .submit-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }

    .note {
      font-size: 12px;
      color: #475569;
      text-align: center;
      margin-top: 1rem;
    }

    /* Success state */
    .success-card {
      display: none;
      text-align: center;
      padding: 2rem;
    }

    .success-card .check {
      font-size: 56px;
      margin-bottom: 1rem;
    }

    .success-card h2 {
      font-size: 26px;
      font-weight: 700;
      color: #c4b5fd;
      margin-bottom: 0.75rem;
    }

    .success-card p {
      font-size: 15px;
      color: #94a3b8;
      margin-bottom: 1.5rem;
    }

    .install-link {
      display: inline-block;
      background: linear-gradient(135deg, #8b5cf6, #6d28d9);
      color: white;
      text-decoration: none;
      padding: 12px 28px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 15px;
      transition: all 0.25s;
    }

    .install-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
    }

    .error-msg {
      display: none;
      background: rgba(239, 68, 68, 0.15);
      border: 1px solid rgba(239, 68, 68, 0.4);
      color: #fca5a5;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 14px;
      margin-bottom: 1rem;
      text-align: center;
    }

    footer {
      margin-top: auto;
      padding: 2rem;
      text-align: center;
      border-top: 1px solid rgba(139, 92, 246, 0.1);
      color: #475569;
      font-size: 13px;
    }

    footer a { color: #a78bfa; text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 36px; }
      .hero { padding: 40px 1.5rem 10px; }
      .form-card { padding: 1.75rem 1.25rem; }
      header { flex-direction: column; gap: 0.75rem; }
    }
  </style>
</head>
<body>
  <header>
    <a class="logo" href="/">HoldOff</a>
    <nav>
      <a href="/">Home</a>
      <a href="/pricing">Pricing</a>
    </nav>
  </header>

  <section class="hero">
    <div class="badge">🚀 Early Access</div>
    <h1>Be the First to Try HoldOff</h1>
    <p>Join the Android beta and get access before public launch. Shape the app with your feedback.</p>
    <div class="perks">
      <div class="perk"><span class="icon">📱</span> Android Early Access</div>
      <div class="perk"><span class="icon">✨</span> Free During Beta</div>
      <div class="perk"><span class="icon">💬</span> Your Feedback Shapes It</div>
    </div>
  </section>

  <div class="form-wrap">
    <div class="form-card" id="formCard">
      <h2>Join the Beta</h2>
      <p class="sub">Takes 30 seconds. You'll get an install link once you're approved — usually within 24 hours.</p>

      <div class="error-msg" id="errorMsg"></div>

      <form id="betaForm">
        <div class="form-group">
          <label for="name">Your Name *</label>
          <input type="text" id="name" name="name" required placeholder="First name is fine" autocomplete="name">
        </div>

        <div class="form-group">
          <label for="email">Email Address *</label>
          <input type="email" id="email" name="email" required placeholder="The Gmail you use on your Android"
            autocomplete="email">
          <div style="font-size:11px; color:#475569; margin-top:4px;">⚠️ Must be the Google account on your Android device</div>
        </div>

        <div class="form-group">
          <label for="device">Your Android Device</label>
          <input type="text" id="device" name="device" placeholder="e.g. Samsung Galaxy S24, Pixel 8…">
        </div>

        <div class="form-group">
          <label for="why">Why do you want early access? (optional)</label>
          <textarea id="why" name="why" placeholder="Tell us a little about yourself…"></textarea>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">Request Beta Access →</button>
        <p class="note">No spam, ever. We'll only email you your install link and important app updates.</p>
      </form>
    </div>

    <!-- Success state (shown after submit) -->
    <div class="form-card success-card" id="successCard">
      <div class="check">🎉</div>
      <h2>You're on the list!</h2>
      <p>We'll send your install link to your email within 24 hours. In the meantime, you can try the web version now.</p>
      <a href="https://play.google.com/apps/internaltest/4698784940461224188" class="install-link" target="_blank">
        Open Play Store Invite →
      </a>
      <p style="font-size:12px; color:#475569; margin-top:1rem;">
        Link only works once your email is added. Check back after 24 hrs if it shows "not available."
      </p>
    </div>
  </div>

  <footer>
    <p>&copy; 2026 HoldOff &nbsp;|&nbsp; <a href="/privacy">Privacy</a> &nbsp;|&nbsp; <a href="/terms">Terms</a></p>
  </footer>

  <script>
    document.getElementById('betaForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      const errEl = document.getElementById('errorMsg');
      errEl.style.display = 'none';

      btn.disabled = true;
      btn.textContent = 'Submitting…';

      const body = {
        name: document.getElementById('name').value.trim(),
        email: document.getElementById('email').value.trim(),
        device: document.getElementById('device').value.trim(),
        why: document.getElementById('why').value.trim(),
      };

      try {
        const res = await fetch('/api/beta-signup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();

        if (res.ok && data.ok) {
          document.getElementById('formCard').style.display = 'none';
          document.getElementById('successCard').style.display = 'block';
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          errEl.textContent = data.error || 'Something went wrong. Please try again.';
          errEl.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Request Beta Access →';
        }
      } catch (err) {
        errEl.textContent = 'Network error. Please check your connection and try again.';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Request Beta Access →';
      }
    });
  </script>
  <script src="/js/floating-companions.js" defer></script>
</body>
</html>
