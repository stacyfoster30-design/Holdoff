<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Settings — HoldOff</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#0E0C0B">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body{background:#0E0C0B;color:#F2EDE5;font-family:'DM Sans',sans-serif;min-height:100vh;}
    .snav{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:1px solid #2E2924;position:sticky;top:0;background:#0E0C0B;z-index:10;}
    .snav a{color:#9E948E;text-decoration:none;font-size:.88rem;}
    .snav__title{font-family:'Fraunces',serif;font-size:1.05rem;color:#F2EDE5;}
    .smain{max-width:480px;margin:0 auto;padding:1.5rem 1.25rem 3rem;}
    .section{margin-bottom:1.5rem;}
    .section__label{font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#9E948E;margin-bottom:.6rem;padding:0 .2rem;}
    .card{background:#1A1714;border:1px solid #2E2924;border-radius:14px;overflow:hidden;}
    .row{display:flex;align-items:center;justify-content:space-between;padding:.9rem 1.1rem;border-bottom:1px solid #2E2924;}
    .row:last-child{border:none;}
    .row__label{font-size:.9rem;color:#F2EDE5;}
    .row__sub{font-size:.75rem;color:#9E948E;margin-top:.15rem;}
    .row__right{display:flex;align-items:center;gap:.5rem;}
    .toggle{width:44px;height:24px;background:#2E2924;border-radius:999px;position:relative;cursor:pointer;border:none;transition:.2s;flex-shrink:0;}
    .toggle.on{background:#C97B5D;}
    .toggle::after{content:'';position:absolute;top:3px;left:3px;width:18px;height:18px;background:#fff;border-radius:50%;transition:.2s;}
    .toggle.on::after{left:23px;}
    .row__val{font-size:.85rem;color:#9E948E;}
    .row--link{cursor:pointer;text-decoration:none;display:flex;}
    .row--link:hover .row__label{color:#C97B5D;}
    .chevron{color:#9E948E;font-size:.8rem;}
    select.row__select{background:none;border:none;color:#9E948E;font-family:'DM Sans',sans-serif;font-size:.85rem;text-align:right;cursor:pointer;outline:none;}
    select.row__select option{background:#1A1714;color:#F2EDE5;}
    .flash{padding:.75rem 1rem;border-radius:8px;margin-bottom:1rem;font-size:.85rem;display:none;}
    .flash--ok{background:rgba(76,175,80,.12);border:1px solid rgba(76,175,80,.25);color:#4CAF50;}
    .flash--err{background:rgba(244,67,54,.12);border:1px solid rgba(244,67,54,.25);color:#F44336;}
    .spinner{width:20px;height:20px;border:2px solid #2E2924;border-top-color:#C97B5D;border-radius:50%;animation:spin .7s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg);}}
  </style>
</head>
<body>
  <nav class="snav">
    <a href="/profile">← Profile</a>
    <span class="snav__title">Settings</span>
    <a href="/filter">Filter</a>
  </nav>
  <main class="smain">
    <div class="flash" id="flash"></div>

    <!-- Account -->
    <div class="section">
      <div class="section__label">Account</div>
      <div class="card">
        <div class="row">
          <div><div class="row__label">Email</div><div class="row__sub" id="settingsEmail">Loading…</div></div>
        </div>
        <a href="/upgrade" class="row row--link">
          <div><div class="row__label">Subscription</div><div class="row__sub" id="settingsPlan">Loading…</div></div>
          <span class="chevron">›</span>
        </a>
        <a href="/quiz" class="row row--link">
          <div class="row__label">Attachment Style Quiz</div>
          <span class="chevron">›</span>
        </a>
        <a href="/reset-password" class="row row--link">
          <div class="row__label">Change Password</div>
          <span class="chevron">›</span>
        </a>
      </div>
    </div>

    <!-- Verdict Style -->
    <div class="section">
      <div class="section__label">Verdict Style</div>
      <div class="card">
        <div class="row">
          <div><div class="row__label">Tone</div><div class="row__sub">How HoldOff speaks to you</div></div>
          <select class="row__select" id="verdictStyleSelect">
            <option value="blunt">Blunt</option>
            <option value="gentle">Gentle</option>
            <option value="default">Balanced</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Notifications -->
    <div class="section">
      <div class="section__label">Notifications</div>
      <div class="card">
        <div class="row">
          <div><div class="row__label">Push Notifications</div><div class="row__sub">Daily check-in reminders</div></div>
          <button class="toggle" id="pushToggle" aria-label="Toggle push notifications"></button>
        </div>
        <div class="row">
          <div><div class="row__label">Reminder Time</div><div class="row__sub">Morning nudge to check in</div></div>
          <select class="row__select" id="reminderTime">
            <option value="08:00">8 AM</option>
            <option value="09:00">9 AM</option>
            <option value="20:00">8 PM</option>
            <option value="21:00">9 PM</option>
            <option value="22:00">10 PM</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Privacy -->
    <div class="section">
      <div class="section__label">Privacy</div>
      <div class="card">
        <div class="row">
          <div><div class="row__label">Save Verdict History</div><div class="row__sub">Store your holds and sends</div></div>
          <button class="toggle on" id="historyToggle"></button>
        </div>
        <div class="row">
          <div><div class="row__label">Anonymous Community Posts</div><div class="row__sub">Your name is always hidden</div></div>
          <div class="row__val">Always on</div>
        </div>
        <a href="/privacy" class="row row--link">
          <div class="row__label">Privacy Policy</div>
          <span class="chevron">›</span>
        </a>
      </div>
    </div>

    <!-- App -->
    <div class="section">
      <div class="section__label">App</div>
      <div class="card">
        <a href="/detox" class="row row--link">
          <div><div class="row__label">5-Day Detox</div><div class="row__sub">Reset your texting habits</div></div>
          <span class="chevron">›</span>
        </a>
        <a href="/referrals" class="row row--link">
          <div><div class="row__label">Refer Friends</div><div class="row__sub">Get rewards for sharing</div></div>
          <span class="chevron">›</span>
        </a>
        <a href="/affiliates" class="row row--link">
          <div><div class="row__label">Affiliate Program</div><div class="row__sub">Earn commissions</div></div>
          <span class="chevron">›</span>
        </a>
        <a href="/download" class="row row--link">
          <div><div class="row__label">Get the App</div><div class="row__sub">Install on your home screen</div></div>
          <span class="chevron">›</span>
        </a>
        <a href="/terms" class="row row--link">
          <div class="row__label">Terms of Service</div>
          <span class="chevron">›</span>
        </a>
      </div>
    </div>

    <!-- Danger zone -->
    <div class="section">
      <div class="section__label">Account Actions</div>
      <div class="card">
        <button class="row" id="logoutBtn" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;">
          <div class="row__label" style="color:#F44336;">Log Out</div>
        </button>
        <button class="row" id="deleteBtn" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;border-top:1px solid #2E2924;">
          <div><div class="row__label" style="color:#F44336;">Delete Account</div><div class="row__sub">Permanently removes all your data</div></div>
        </button>
      </div>
    </div>
  </main>

  <script>
    function flash(msg,type='ok'){
      const el=document.getElementById('flash');
      el.textContent=msg;el.className=`flash flash--${type}`;el.style.display='block';
      setTimeout(()=>el.style.display='none',3000);
    }
    function save(key,val){localStorage.setItem('holdoff_setting_'+key,val);}
    function load(key,def){return localStorage.getItem('holdoff_setting_'+key)||def;}

    // Load user info
    fetch('/api/auth/me').then(r=>r.ok?r.json():{}).then(me=>{
      document.getElementById('settingsEmail').textContent=me?.email||'Not logged in';
      document.getElementById('settingsPlan').textContent=me?.subscription_status==='active'?`Pro · ${me.subscription_plan||'Monthly'}`:'Free';
    }).catch(()=>{});

    // Verdict style
    const vs=document.getElementById('verdictStyleSelect');
    vs.value=load('verdict_style','default');
    vs.addEventListener('change',()=>{
      save('verdict_style',vs.value);
      fetch('/api/users/preferences',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({verdict_style:vs.value})}).catch(()=>{});
      flash('Verdict style saved');
    });

    // Push toggle
    const pt=document.getElementById('pushToggle');
    if(load('push_enabled','')=='1')pt.classList.add('on');
    pt.addEventListener('click',async()=>{
      if(pt.classList.contains('on')){
        pt.classList.remove('on');save('push_enabled','0');flash('Notifications off');
      } else {
        if('Notification' in window){
          const p=await Notification.requestPermission();
          if(p==='granted'){pt.classList.add('on');save('push_enabled','1');flash('Notifications on');}
          else flash('Notifications blocked by browser','err');
        }
      }
    });

    // History toggle
    const ht=document.getElementById('historyToggle');
    if(load('save_history','1')!='0')ht.classList.add('on');
    ht.addEventListener('click',()=>{
      ht.classList.toggle('on');
      save('save_history',ht.classList.contains('on')?'1':'0');
      flash(ht.classList.contains('on')?'History saving on':'History saving off');
    });

    // Reminder time
    const rt=document.getElementById('reminderTime');
    rt.value=load('reminder_time','09:00');
    rt.addEventListener('change',()=>{save('reminder_time',rt.value);flash('Reminder time saved');});

    // Logout
    document.getElementById('logoutBtn').addEventListener('click',()=>{
      fetch('/api/auth/logout',{method:'POST'}).then(()=>window.location.href='/');
    });

    // Delete
    document.getElementById('deleteBtn').addEventListener('click',()=>{
      if(confirm('Delete your account? This cannot be undone.')){
        fetch('/api/auth/delete-account',{method:'DELETE'}).then(r=>{
          if(r.ok)window.location.href='/';
          else flash('Delete failed. Email holdoff@shouldiholdoff.live.','err');
        }).catch(()=>flash('Delete failed. Email holdoff@shouldiholdoff.live.','err'));
      }
    });
  </script>
</body>
</html>
