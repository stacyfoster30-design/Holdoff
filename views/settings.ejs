<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings — HoldOff</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="HoldOff">
  <meta name="theme-color" content="#0F172A">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #8B5CF6;
      --primary-dark: #6D28D9;
      --accent: #3B82F6;
      --accent-dark: #1E40AF;
      --rose: #EC4899;
      --green-safe: #10B981;
      --yellow-warn: #F59E0B;
      --red-danger: #EF4444;
      --bg-dark: #0F172A;
      --bg-darker: #09101F;
      --bg-card: #1A2847;
      --text-primary: #F1F5F9;
      --text-muted: #CBD5E1;
      --text-dim: #94A3B8;
      --border: #334155;
      --glow-primary: rgba(139, 92, 246, 0.1);
      --radius: 12px;
      --transition: all 0.3s ease;
    }

    body {
      background: linear-gradient(135deg, var(--bg-darker) 0%, var(--bg-dark) 100%);
      color: var(--text-primary);
      font-family: 'DM Sans', sans-serif;
      line-height: 1.6;
      min-height: 100vh;
      padding: 20px;
    }

    .settings-container {
      max-width: 500px;
      margin: 0 auto;
      padding-top: 20px;
    }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 40px;
    }

    .header h1 {
      font-size: 28px;
      font-weight: 600;
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .back-btn {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--bg-card);
      border: 1px solid var(--border);
      color: var(--text-primary);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      transition: var(--transition);
    }

    .back-btn:hover {
      background: var(--primary);
      border-color: var(--primary);
    }

    .section {
      margin-bottom: 40px;
    }

    .section-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-icon {
      font-size: 18px;
    }

    /* Conditions */
    .conditions-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .condition-card {
      padding: 14px 12px;
      border-radius: var(--radius);
      border: 1.5px solid var(--border);
      background: var(--bg-card);
      cursor: pointer;
      transition: var(--transition);
      text-align: center;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      user-select: none;
      position: relative;
    }

    .condition-card:hover {
      border-color: var(--primary);
      background: rgba(139, 92, 246, 0.05);
    }

    .condition-card.selected {
      border-color: var(--primary);
      background: rgba(139, 92, 246, 0.1);
      color: var(--primary);
      box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
    }

    .checkmark {
      position: absolute;
      top: -6px;
      right: -6px;
      width: 20px;
      height: 20px;
      background: var(--primary);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 12px;
      opacity: 0;
      transition: var(--transition);
    }

    .condition-card.selected .checkmark {
      opacity: 1;
    }

    /* Pattern Tracking */
    .tracking-card {
      padding: 16px;
      border-radius: var(--radius);
      background: var(--bg-card);
      border: 1px solid var(--border);
      margin-bottom: 12px;
    }

    .tracking-label {
      font-size: 13px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
    }

    .toggle {
      width: 48px;
      height: 28px;
      background: var(--border);
      border: none;
      border-radius: 14px;
      cursor: pointer;
      position: relative;
      transition: var(--transition);
      margin-left: auto;
    }

    .toggle.active {
      background: var(--primary);
    }

    .toggle::after {
      content: '';
      position: absolute;
      width: 24px;
      height: 24px;
      background: white;
      border-radius: 50%;
      top: 2px;
      left: 2px;
      transition: var(--transition);
    }

    .toggle.active::after {
      left: 22px;
    }

    /* Profile Section */
    .profile-item {
      padding: 14px;
      border-radius: var(--radius);
      background: var(--bg-card);
      border: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .profile-label {
      font-size: 14px;
      color: var(--text-muted);
    }

    .profile-value {
      font-size: 13px;
      color: var(--text-primary);
      font-weight: 500;
    }

    .edit-link {
      color: var(--primary);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
    }

    .edit-link:hover {
      color: var(--accent);
    }

    /* Stats */
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 16px;
    }

    .stat-box {
      padding: 16px;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.05) 100%);
      border: 1px solid rgba(139, 92, 246, 0.2);
      border-radius: var(--radius);
      text-align: center;
    }

    .stat-number {
      font-size: 24px;
      font-weight: 700;
      color: var(--primary);
    }

    .stat-label {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 6px;
    }

    /* Buttons */
    .button-group {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 30px;
    }

    .btn {
      padding: 14px;
      border: none;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(139, 92, 246, 0.3);
    }

    .btn-secondary {
      background: var(--border);
      color: var(--text-primary);
    }

    .btn-secondary:hover {
      background: var(--primary);
      color: white;
    }

    .btn-danger {
      background: rgba(239, 68, 68, 0.1);
      color: var(--red-danger);
      border: 1px solid var(--red-danger);
      width: 100%;
      margin-top: 20px;
    }

    .btn-danger:hover {
      background: rgba(239, 68, 68, 0.2);
    }

    /* Modal */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.8);
      z-index: 1000;
      align-items: center;
      justify-content: center;
    }

    .modal.active {
      display: flex;
    }

    .modal-content {
      background: var(--bg-dark);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
      max-width: 400px;
      width: 90%;
      animation: slideUp 0.3s ease;
    }

    @keyframes slideUp {
      from {
        transform: translateY(30px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .modal-header {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--text-primary);
    }

    .modal-input {
      width: 100%;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-card);
      color: var(--text-primary);
      font-size: 14px;
      margin-bottom: 16px;
      font-family: inherit;
    }

    .modal-input:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 10px rgba(139, 92, 246, 0.3);
    }

    .modal-buttons {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    /* Responsive */
    @media (max-width: 480px) {
      .settings-container {
        padding: 0;
      }

      .conditions-grid {
        grid-template-columns: 1fr;
      }

      .button-group {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="settings-container">
    <!-- Header -->
    <div class="header">
      <h1>Settings</h1>
      <button class="back-btn" onclick="history.back()">← </button>
    </div>

    <!-- Profile Section -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">👤</span>
        Profile
      </div>
      <div class="profile-item">
        <div class="profile-label">Email</div>
        <div class="profile-value" id="email-display">—</div>
      </div>
      <div class="profile-item">
        <div class="profile-label">Member Since</div>
        <div class="profile-value" id="joined-display">—</div>
      </div>
    </div>

    <!-- Mental Health Conditions -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">🧠</span>
        Your Conditions
      </div>
      <p style="font-size: 13px; color: var(--text-dim); margin-bottom: 16px;">
        Select the conditions that resonate with you. HoldOff tailors insights based on your selections.
      </p>
      <div class="conditions-grid">
        <div class="condition-card" data-condition="rsd" onclick="toggleCondition('rsd')">
          RSD
          <div class="checkmark">✓</div>
        </div>
        <div class="condition-card" data-condition="anxiety" onclick="toggleCondition('anxiety')">
          Anxiety
          <div class="checkmark">✓</div>
        </div>
        <div class="condition-card" data-condition="depression" onclick="toggleCondition('depression')">
          Depression
          <div class="checkmark">✓</div>
        </div>
        <div class="condition-card" data-condition="addiction" onclick="toggleCondition('addiction')">
          Addiction
          <div class="checkmark">✓</div>
        </div>
        <div class="condition-card" data-condition="autism" onclick="toggleCondition('autism')">
          Autism
          <div class="checkmark">✓</div>
        </div>
        <div class="condition-card" data-condition="adhd" onclick="toggleCondition('adhd')">
          ADHD
          <div class="checkmark">✓</div>
        </div>
      </div>
    </div>

    <!-- Pattern Tracking -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">📊</span>
        Pattern Tracking
      </div>
      <div class="tracking-card">
        <div class="tracking-label">
          Track Message Patterns
          <button class="toggle" id="pattern-toggle" onclick="togglePatternTracking()"></button>
        </div>
        <p style="font-size: 12px; color: var(--text-dim);">
          HoldOff learns your communication style and flags repeated patterns you might not see.
        </p>
      </div>
      <div class="tracking-card">
        <div class="tracking-label">
          Track Spiral Tendencies
          <button class="toggle" id="spiral-toggle" onclick="toggleSpiralTracking()"></button>
        </div>
        <p style="font-size: 12px; color: var(--text-dim);">
          Get alerted when you're slipping into unhealthy communication patterns.
        </p>
      </div>
    </div>

    <!-- Stats -->
    <div class="section">
      <div class="section-title">
        <span class="section-icon">📈</span>
        Your Activity
      </div>
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-number" id="messages-count">0</div>
          <div class="stat-label">Messages Analyzed</div>
        </div>
        <div class="stat-box">
          <div class="stat-number" id="verdicts-count">0</div>
          <div class="stat-label">Verdicts Issued</div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="button-group">
      <button class="btn btn-primary" onclick="saveSettings()">Save Changes</button>
      <button class="btn btn-secondary" onclick="resetSettings()">Reset</button>
    </div>

    <button class="btn btn-danger" onclick="showLogoutModal()">Sign Out</button>
  </div>

  <!-- Logout Modal -->
  <div class="modal" id="logout-modal">
    <div class="modal-content">
      <div class="modal-header">Sign Out</div>
      <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 20px;">
        Are you sure? You'll need to log back in to access your account.
      </p>
      <div class="modal-buttons">
        <button class="btn btn-secondary" onclick="closeLogoutModal()">Cancel</button>
        <button class="btn btn-primary" style="background: var(--red-danger);" onclick="performLogout()">Sign Out</button>
      </div>
    </div>
  </div>

  <script>
    let selectedConditions = [];
    let patternTrackingEnabled = true;
    let spiralTrackingEnabled = true;

    // Load user data
    async function loadSettings() {
      try {
        const response = await fetch('/api/auth/me');
        if (response.ok) {
          const data = await response.json();
          const user = data.user || data;
          
          document.getElementById('email-display').textContent = user.email || '—';
          
          // Format date
          if (user.created_at) {
            const date = new Date(user.created_at);
            const formatted = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            document.getElementById('joined-display').textContent = formatted;
          }

          // Load conditions
          if (user.id) {
            loadUserConditions(user.id);
            loadUserStats(user.id);
          }
        }
      } catch (err) {
        console.error('Error loading settings:', err);
      }
    }

    // Load user conditions from database
    async function loadUserConditions(userId) {
      try {
        const response = await fetch(`/api/questionnaire/user-conditions/${userId}`);
        if (response.ok) {
          const data = await response.json();
          selectedConditions = data.conditions || [];
          
          // Update UI
          document.querySelectorAll('.condition-card').forEach(card => {
            const condition = card.dataset.condition;
            if (selectedConditions.includes(condition)) {
              card.classList.add('selected');
            }
          });
        }
      } catch (err) {
        console.error('Error loading conditions:', err);
      }
    }

    // Load user statistics
    async function loadUserStats(userId) {
      try {
        // Fetch message count
        const msgRes = await fetch(`/api/messaging/count/${userId}`);
        if (msgRes.ok) {
          const msgData = await msgRes.json();
          document.getElementById('messages-count').textContent = msgData.count || 0;
        }

        // Fetch verdict count
        const verdictRes = await fetch(`/api/verdict/count/${userId}`);
        if (verdictRes.ok) {
          const verdictData = verdictRes.json();
          document.getElementById('verdicts-count').textContent = verdictData.count || 0;
        }
      } catch (err) {
        console.error('Error loading stats:', err);
      }
    }

    // Toggle condition selection
    function toggleCondition(condition) {
      const card = document.querySelector(`[data-condition="${condition}"]`);
      if (selectedConditions.includes(condition)) {
        selectedConditions = selectedConditions.filter(c => c !== condition);
        card.classList.remove('selected');
      } else {
        selectedConditions.push(condition);
        card.classList.add('selected');
      }
    }

    // Toggle pattern tracking
    function togglePatternTracking() {
      const btn = document.getElementById('pattern-toggle');
      patternTrackingEnabled = !patternTrackingEnabled;
      btn.classList.toggle('active');
    }

    // Toggle spiral tracking
    function toggleSpiralTracking() {
      const btn = document.getElementById('spiral-toggle');
      spiralTrackingEnabled = !spiralTrackingEnabled;
      btn.classList.toggle('active');
    }

    // Save settings
    async function saveSettings() {
      try {
        const response = await fetch('/api/auth/me');
        const user = await response.json();
        const userId = user.user?.id || user.id;

        // Submit questionnaire with selected conditions
        const res = await fetch('/api/questionnaire/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            userId: userId,
            conditions: selectedConditions,
            attachment_style: localStorage.getItem('attachment_style') || 'secure'
          })
        });

        if (res.ok) {
          alert('Settings saved successfully!');
        } else {
          alert('Failed to save settings. Please try again.');
        }
      } catch (err) {
        console.error('Error saving settings:', err);
        alert('Error saving settings');
      }
    }

    // Reset to last saved
    function resetSettings() {
      location.reload();
    }

    // Logout modal
    function showLogoutModal() {
      document.getElementById('logout-modal').classList.add('active');
    }

    function closeLogoutModal() {
      document.getElementById('logout-modal').classList.remove('active');
    }

    async function performLogout() {
      try {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/';
      } catch (err) {
        console.error('Logout error:', err);
      }
    }

    // Initialize
    window.addEventListener('DOMContentLoaded', () => {
      loadSettings();
      const patternBtn = document.getElementById('pattern-toggle');
      const spiralBtn = document.getElementById('spiral-toggle');
      if (patternTrackingEnabled) patternBtn.classList.add('active');
      if (spiralTrackingEnabled) spiralBtn.classList.add('active');
    });
  </script>
  <script src="/js/floating-companions.js" defer></script>
</body>
</html>
