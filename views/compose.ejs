<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>HoldOff — Compose</title>
  <style>
    .mode-toggle { display:flex; gap:0; margin-bottom:20px; }
    .mode-btn {
      flex:1; padding:14px; text-align:center; font-weight:600; font-size:0.95rem;
      border:1px solid var(--border); background:var(--bg-card); color:var(--text-muted);
      cursor:pointer; transition:var(--transition);
    }
    .mode-btn:first-child { border-radius:var(--radius-sm) 0 0 var(--radius-sm); }
    .mode-btn:last-child { border-radius:0 var(--radius-sm) var(--radius-sm) 0; }
    .mode-btn.active { background:var(--primary); color:white; border-color:var(--primary); }
    
    .compose-area {
      background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius);
      padding:16px; margin-bottom:16px;
    }
    .compose-textarea {
      width:100%; min-height:140px; background:transparent; border:none; color:var(--text);
      font-family:var(--font); font-size:1rem; resize:none; line-height:1.6;
    }
    .compose-textarea:focus { outline:none; }
    .compose-textarea::placeholder { color:var(--text-dim); }
    
    .char-count { text-align:right; font-size:0.75rem; color:var(--text-dim); margin-top:8px; }
    
    .verdict-card {
      background:var(--bg-card); border-radius:var(--radius); padding:20px;
      border:2px solid var(--border); margin-top:16px; display:none;
    }
    .verdict-card.show { display:block; animation:fadeIn 0.4s ease; }
    
    .verdict-send { border-color:var(--success); }
    .verdict-hold { border-color:var(--danger); }
    .verdict-rewrite { border-color:var(--warning); }
    
    .verdict-badge {
      display:inline-flex; padding:6px 16px; border-radius:var(--radius-full);
      font-weight:700; font-size:0.9rem; margin-bottom:12px;
    }
    .verdict-send .verdict-badge { background:rgba(109,206,168,0.15); color:var(--success); }
    .verdict-hold .verdict-badge { background:rgba(232,121,121,0.15); color:var(--danger); }
    .verdict-rewrite .verdict-badge { background:rgba(232,169,91,0.15); color:var(--warning); }

    .interpretation-card {
      background:var(--bg-card); border-radius:var(--radius); padding:20px;
      border:1px solid var(--border); margin-top:16px; display:none;
    }
    .interpretation-card.show { display:block; animation:fadeIn 0.4s ease; }

    .interp-section { margin-bottom:16px; }
    .interp-label { font-size:0.75rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px; }
    .interp-text { color:var(--text); line-height:1.6; font-size:0.95rem; }

    .loading-spinner {
      display:none; text-align:center; padding:30px;
    }
    .loading-spinner.show { display:block; }
    .spinner {
      width:40px; height:40px; border:3px solid var(--border);
      border-top:3px solid var(--primary); border-radius:50%;
      animation:spin 1s linear infinite; margin:0 auto 12px;
    }
    @keyframes spin { to { transform:rotate(360deg); } }

    .lock-overlay {
      display:none; position:fixed; top:0;left:0;right:0;bottom:0;
      background:rgba(13,10,26,0.95); z-index:200;
      flex-direction:column; align-items:center; justify-content:center;
      padding:40px; text-align:center;
    }
    .lock-overlay.show { display:flex; }
  </style>
</head>
<body>
  <div class="app-container">
    <div class="screen-header">
      <a href="/inbox" style="color:var(--text-muted);font-size:1.2rem;" aria-label="Back">←</a>
      <h1>Compose</h1>
      <div style="width:24px;"></div>
    </div>

    <div class="screen-content">
      <!-- Mode Toggle -->
      <div class="mode-toggle">
        <button class="mode-btn active" onclick="setMode('compose')" id="mode-compose">✍️ Compose & Send</button>
        <button class="mode-btn" onclick="setMode('decode')" id="mode-decode">🔍 Decode Incoming</button>
      </div>

      <!-- Contact Selector -->
      <div class="form-group">
        <label class="form-label">Who is this about?</label>
        <input type="text" class="form-input" id="contact-name" placeholder="Their name..." autocomplete="off">
      </div>

      <!-- Relationship Context -->
      <div class="form-group">
        <label class="form-label">Relationship</label>
        <select class="form-select" id="relationship">
          <option value="">Select...</option>
          <option value="romantic">💕 Romantic Partner</option>
          <option value="ex">💔 Ex</option>
          <option value="crush">✨ Crush</option>
          <option value="situationship">🌙 Situationship</option>
          <option value="friend">🫂 Friend</option>
          <option value="family">👨‍👩‍👧 Family</option>
          <option value="coworker">💼 Coworker</option>
        </select>
      </div>

      <!-- COMPOSE MODE -->
      <div id="compose-mode">
        <div class="compose-area">
          <textarea class="compose-textarea" id="message-text" placeholder="Type the message you want to send..." oninput="updateCharCount()"></textarea>
          <div class="char-count"><span id="char-count">0</span> characters</div>
        </div>

        <div class="form-group">
          <label class="form-label">How are you feeling right now?</label>
          <div class="mood-bar">
            <button class="mood-pill" onclick="selectMood(this, 'calm')">😌 Calm</button>
            <button class="mood-pill" onclick="selectMood(this, 'anxious')">😰 Anxious</button>
            <button class="mood-pill" onclick="selectMood(this, 'angry')">😤 Angry</button>
            <button class="mood-pill" onclick="selectMood(this, 'hurt')">😢 Hurt</button>
            <button class="mood-pill" onclick="selectMood(this, 'spiraling')">🌀 Spiraling</button>
          </div>
        </div>

        <button class="btn btn-primary btn-block btn-lg" onclick="getVerdict()" id="verdict-btn">
          🔮 Should I Send This?
        </button>

        <!-- Verdict Result -->
        <div class="loading-spinner" id="compose-loading">
          <div class="spinner"></div>
          <p style="color:var(--text-muted);">Analyzing your message...</p>
        </div>

        <div class="verdict-card" id="verdict-result">
          <div class="verdict-badge" id="verdict-badge"></div>
          <div id="verdict-explanation" style="color:var(--text);line-height:1.6;margin-bottom:16px;"></div>
          
          <div id="verdict-rewrite-section" style="display:none;">
            <div style="font-size:0.8rem;color:var(--text-muted);text-transform:uppercase;margin-bottom:8px;">💡 Suggested Rewrite</div>
            <div id="verdict-rewrite" style="background:var(--bg-input);padding:14px;border-radius:var(--radius-sm);color:var(--text);line-height:1.5;margin-bottom:12px;"></div>
            <button class="btn btn-accent btn-sm" onclick="useRewrite()">Use This Instead</button>
          </div>

          <div style="display:flex;gap:10px;margin-top:16px;">
            <button class="btn btn-ghost btn-sm" style="flex:1;" onclick="copyMessage()">📋 Copy to Clipboard</button>
            <button class="btn btn-ghost btn-sm" style="flex:1;" onclick="resetCompose()">🔄 Start Over</button>
          </div>
        </div>
      </div>

      <!-- DECODE MODE -->
      <div id="decode-mode" style="display:none;">
        <div class="compose-area">
          <textarea class="compose-textarea" id="incoming-text" placeholder="Paste the message they sent you..."></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">Context (optional)</label>
          <input type="text" class="form-input" id="decode-context" placeholder="What happened before this message?">
        </div>

        <button class="btn btn-accent btn-block btn-lg" onclick="decodeMessage()">
          🔍 What Did They Actually Mean?
        </button>

        <div class="loading-spinner" id="decode-loading">
          <div class="spinner"></div>
          <p style="color:var(--text-muted);">Decoding their message...</p>
        </div>

        <div class="interpretation-card" id="decode-result">
          <div class="interp-section">
            <div class="interp-label">💬 What they said</div>
            <div class="interp-text" id="interp-said" style="font-style:italic;"></div>
          </div>
          <div class="interp-section">
            <div class="interp-label">🧠 What they actually meant</div>
            <div class="interp-text" id="interp-meant"></div>
          </div>
          <div class="interp-section">
            <div class="interp-label">🔗 Their likely attachment style</div>
            <div class="interp-text" id="interp-attachment"></div>
          </div>
          <div class="interp-section">
            <div class="interp-label">⚠️ How your anxious brain might read it</div>
            <div class="interp-text" id="interp-anxious" style="color:var(--warning);"></div>
          </div>
          <div class="interp-section" id="interp-flags-section" style="display:none;">
            <div class="interp-label">🚩 Red flags</div>
            <div class="interp-text" id="interp-flags" style="color:var(--danger);"></div>
          </div>
          <div style="margin-top:16px;">
            <button class="btn btn-ghost btn-sm" onclick="resetDecode()">🔄 Decode Another</button>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/bottom_nav') %>
  </div>

  <!-- Spiral Lock Overlay -->
  <div class="lock-overlay" id="spiral-lock">
    <div style="font-size:4rem;margin-bottom:20px;">🔒</div>
    <h2 style="margin-bottom:12px;">Spiral Lock Activated</h2>
    <p style="color:var(--text-muted);margin-bottom:20px;" id="lock-message">You've been sending too fast. Take a breath.</p>
    <p style="font-size:2rem;font-weight:700;color:var(--rose);margin-bottom:24px;" id="lock-timer">5:00</p>
    <div class="card" style="max-width:320px;text-align:left;" id="lock-quiz" style="display:none;">
      <p style="color:var(--text-muted);font-size:0.85rem;margin-bottom:8px;">Answer to unlock early:</p>
      <p style="margin-bottom:12px;" id="quiz-question">What will sending this message actually change?</p>
      <textarea class="form-textarea" id="quiz-answer" placeholder="Be honest with yourself..." style="min-height:80px;"></textarea>
      <button class="btn btn-rose btn-sm btn-block" style="margin-top:10px;" onclick="submitQuiz()">Unlock</button>
    </div>
  </div>

  <script>
    let currentMode = 'compose';
    let selectedMood = '';
    let sendAttempts = [];
    const SPIRAL_THRESHOLD = 5;
    const SPIRAL_WINDOW = 10 * 60 * 1000; // 10 minutes
    const LOCK_DURATION = 5 * 60 * 1000; // 5 minutes

    // Check URL params for mode
    const params = new URLSearchParams(window.location.search);
    if (params.get('mode') === 'decode') setMode('decode');

    function setMode(mode) {
      currentMode = mode;
      document.getElementById('compose-mode').style.display = mode === 'compose' ? 'block' : 'none';
      document.getElementById('decode-mode').style.display = mode === 'decode' ? 'block' : 'none';
      document.getElementById('mode-compose').classList.toggle('active', mode === 'compose');
      document.getElementById('mode-decode').classList.toggle('active', mode === 'decode');
    }

    function selectMood(el, mood) {
      document.querySelectorAll('.mood-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      selectedMood = mood;
    }

    function updateCharCount() {
      document.getElementById('char-count').textContent = document.getElementById('message-text').value.length;
    }

    function checkSpiralLock() {
      const now = Date.now();
      sendAttempts = sendAttempts.filter(t => now - t < SPIRAL_WINDOW);
      if (sendAttempts.length >= SPIRAL_THRESHOLD) {
        activateLock();
        return true;
      }
      return false;
    }

    function activateLock() {
      const overlay = document.getElementById('spiral-lock');
      overlay.classList.add('show');
      let remaining = LOCK_DURATION;
      const timer = setInterval(() => {
        remaining -= 1000;
        if (remaining <= 0) {
          clearInterval(timer);
          overlay.classList.remove('show');
          sendAttempts = [];
          return;
        }
        const m = Math.floor(remaining / 60000);
        const s = Math.floor((remaining % 60000) / 1000);
        document.getElementById('lock-timer').textContent = m + ':' + String(s).padStart(2, '0');
      }, 1000);
    }

    function submitQuiz() {
      const answer = document.getElementById('quiz-answer').value.trim();
      if (answer.length >= 20) {
        document.getElementById('spiral-lock').classList.remove('show');
        sendAttempts = [];
      } else {
        document.getElementById('quiz-answer').style.borderColor = 'var(--danger)';
        document.getElementById('quiz-answer').placeholder = 'Please write a more thoughtful response (at least 20 characters)...';
      }
    }

    async function getVerdict() {
      const message = document.getElementById('message-text').value.trim();
      if (!message) return;

      sendAttempts.push(Date.now());
      if (checkSpiralLock()) return;

      const btn = document.getElementById('verdict-btn');
      btn.disabled = true;
      document.getElementById('compose-loading').classList.add('show');
      document.getElementById('verdict-result').classList.remove('show');

      try {
        const res = await fetch('/api/verdict', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message,
            contactName: document.getElementById('contact-name').value,
            relationship: document.getElementById('relationship').value,
            mood: selectedMood
          })
        });
        const data = await res.json();

        const card = document.getElementById('verdict-result');
        const badge = document.getElementById('verdict-badge');

        card.className = 'verdict-card show';
        if (data.verdict === 'SEND') {
          card.classList.add('verdict-send');
          badge.textContent = '✅ SEND IT';
        } else if (data.verdict === 'HOLD') {
          card.classList.add('verdict-hold');
          badge.textContent = '🛑 HOLD OFF';
        } else {
          card.classList.add('verdict-rewrite');
          badge.textContent = '✏️ REWRITE';
        }

        document.getElementById('verdict-explanation').textContent = data.explanation || data.reasoning || '';

        if (data.rewrite) {
          document.getElementById('verdict-rewrite').textContent = data.rewrite;
          document.getElementById('verdict-rewrite-section').style.display = 'block';
        } else {
          document.getElementById('verdict-rewrite-section').style.display = 'none';
        }
      } catch (err) {
        alert('Something went wrong. Please try again.');
      } finally {
        btn.disabled = false;
        document.getElementById('compose-loading').classList.remove('show');
      }
    }

    async function decodeMessage() {
      const message = document.getElementById('incoming-text').value.trim();
      if (!message) return;

      document.getElementById('decode-loading').classList.add('show');
      document.getElementById('decode-result').classList.remove('show');

      try {
        const res = await fetch('/api/interpret', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            message,
            contactName: document.getElementById('contact-name').value,
            relationship: document.getElementById('relationship').value,
            context: document.getElementById('decode-context').value
          })
        });
        const data = await res.json();

        document.getElementById('interp-said').textContent = message;
        document.getElementById('interp-meant').textContent = data.meaning || data.interpretation || '';
        document.getElementById('interp-attachment').textContent = data.attachmentStyle || data.attachment_style || 'Unknown';
        document.getElementById('interp-anxious').textContent = data.anxiousReading || data.anxious_reading || '';

        if (data.redFlags || data.red_flags) {
          document.getElementById('interp-flags').textContent = data.redFlags || data.red_flags;
          document.getElementById('interp-flags-section').style.display = 'block';
        }

        document.getElementById('decode-result').classList.add('show');
      } catch (err) {
        alert('Something went wrong. Please try again.');
      } finally {
        document.getElementById('decode-loading').classList.remove('show');
      }
    }

    function useRewrite() {
      document.getElementById('message-text').value = document.getElementById('verdict-rewrite').textContent;
      document.getElementById('verdict-result').classList.remove('show');
      updateCharCount();
    }

    function copyMessage() {
      const text = document.getElementById('message-text').value;
      navigator.clipboard.writeText(text).then(() => {
        const btn = event.target;
        btn.textContent = '✅ Copied!';
        setTimeout(() => { btn.textContent = '📋 Copy to Clipboard'; }, 2000);
      });
    }

    function resetCompose() {
      document.getElementById('message-text').value = '';
      document.getElementById('verdict-result').classList.remove('show');
      updateCharCount();
    }

    function resetDecode() {
      document.getElementById('incoming-text').value = '';
      document.getElementById('decode-result').classList.remove('show');
      document.getElementById('decode-context').value = '';
    }
  </script>
</body>
</html>