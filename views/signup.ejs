<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Sign up - HoldOff</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-title" content="HoldOff">
  <meta name="theme-color" content="#0E0C0B">
  <meta name="google-client-id" content="<%= typeof googleClientId !== 'undefined' ? googleClientId : '' %>">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <style>
    .auth-wrap { max-width: 420px; margin: 6rem auto 4rem; padding: 0 1.5rem; }
    .auth-wrap h1 { font-family: var(--font-serif); font-size: 2rem; margin-bottom: .5rem; }
    .auth-wrap .sub { color: #9ca3af; margin-bottom: 2rem; }
    .auth-field { margin-bottom: 1.2rem; }
    .auth-field label { display: block; font-size: .875rem; color: #d1d5db; margin-bottom: .4rem; }
    .auth-field input { width: 100%; padding: .75rem 1rem; background: #1a1a2e; border: 1px solid #374151; border-radius: 8px; color: #fff; font-size: 1rem; box-sizing: border-box; }
    .auth-field input:focus { outline: none; border-color: var(--accent); }
    .auth-submit { width: 100%; padding: .9rem; background: var(--accent); color: #fff; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; margin-top: .5rem; }
    .auth-error { color: #f87171; font-size: .875rem; margin-top: .5rem; display: none; }
    .auth-footer { text-align: center; margin-top: 1.5rem; color: #9ca3af; font-size: .875rem; }
    .auth-footer a { color: var(--accent); }
    .auth-fine { font-size: .75rem; color: #6b7280; margin-top: 1rem; text-align: center; }
    .auth-divider { display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0; color: #6b7280; font-size: .8rem; }
    .auth-divider::before, .auth-divider::after { content: ""; flex: 1; height: 1px; background: #374151; }
    .google-btn-wrap { display: flex; justify-content: center; margin-bottom: .5rem; }
    #googleSignUpBtn { min-height: 44px; }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav__logo">HoldOff</a>
  </nav>

  <div class="auth-wrap">
    <h1>Create your account</h1>
    <p class="sub">Start with 5 free verdicts. No card required.</p>

    <!-- Google Sign-Up -->
    <div class="google-btn-wrap">
      <div id="googleSignUpBtn"></div>
    </div>

    <div class="auth-divider">or</div>

    <form id="signupForm" onsubmit="handleSignup(event)">
      <div class="auth-field">
        <label for="sname">First name</label>
        <input type="text" id="sname" name="name" autocomplete="given-name" placeholder="Your name">
      </div>
      <div class="auth-field">
        <label for="semail">Email</label>
        <input type="email" id="semail" name="email" autocomplete="email" required placeholder="you@example.com">
      </div>
      <div class="auth-field">
        <label for="spassword">Password</label>
        <input type="password" id="spassword" name="password" autocomplete="new-password" required placeholder="At least 8 characters" minlength="8">
      </div>
      <div class="auth-error" id="signupError"></div>
      <button type="submit" class="auth-submit">Create account</button>
      <p class="auth-fine">By signing up you agree to our <a href="/terms" style="color:#a78bfa">Terms</a> and <a href="/privacy" style="color:#a78bfa">Privacy Policy</a>.</p>
    </form>

    <div class="auth-footer">
      Already have an account? <a href="/login">Log in</a>
    </div>
  </div>

  <script>
    // Google Sign-Up initialization
    function handleGoogleCredential(response) {
      const err = document.getElementById("signupError");
      err.style.display = "none";

      fetch("/api/auth/google", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ credential: response.credential })
      })
      .then(r => r.json().then(d => ({ ok: r.ok, data: d })))
      .then(({ ok, data }) => {
        if (ok) {
          window.location = "/filter";
        } else {
          err.textContent = data.error || "Google sign-up failed";
          err.style.display = "block";
        }
      })
      .catch(() => {
        err.textContent = "Network error — try again";
        err.style.display = "block";
      });
    }

    function initGoogleSignIn() {
      if (typeof google === "undefined" || !google.accounts) {
        setTimeout(initGoogleSignIn, 200);
        return;
      }
      const clientId = document.querySelector('meta[name="google-client-id"]')?.content;
      if (!clientId) return;

      google.accounts.id.initialize({
        client_id: clientId,
        callback: handleGoogleCredential,
        ux_mode: "popup",
      });
      google.accounts.id.renderButton(
        document.getElementById("googleSignUpBtn"),
        {
          theme: "filled_black",
          size: "large",
          width: 380,
          text: "signup_with",
          shape: "pill",
          logo_alignment: "left",
        }
      );
    }
    initGoogleSignIn();

    async function handleSignup(e) {
      e.preventDefault();
      const btn = document.querySelector(".auth-submit");
      const err = document.getElementById("signupError");
      btn.textContent = "Creating account...";
      btn.disabled = true;
      err.style.display = "none";
      try {
        const res = await fetch("/api/auth/signup", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name: document.getElementById("sname").value,
            email: document.getElementById("semail").value,
            password: document.getElementById("spassword").value
          })
        });
        const d = await res.json();
        if (res.ok) {
          window.location = "/filter";
        } else {
          err.textContent = d.error || "Signup failed";
          err.style.display = "block";
          btn.textContent = "Create account";
          btn.disabled = false;
        }
      } catch(ex) {
        err.textContent = "Network error. Please try again.";
        err.style.display = "block";
        btn.textContent = "Create account";
        btn.disabled = false;
      }
    }
  </script>
</body>
</html>