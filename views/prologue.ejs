<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Prologue — Meet Sadie | HoldOff</title>
  <meta name="description" content="Before you send that message, meet the part of you that already knows better.">
  <style>
    /* ─── Reset & base ─────────────────────────── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg:            #09070f;
      --bg-mid:        #0f0b1a;
      --purple-hi:     #d4c0f8;
      --purple-mid:    #a78bfa;
      --purple-lo:     rgba(167, 139, 250, 0.55);
      --purple-dim:    rgba(167, 139, 250, 0.18);
      --pink:          #e879a0;
      --text:          #e0d5f0;
      --text-muted:    #a89ab8;
      --border:        rgba(167, 139, 250, 0.18);
      --border-accent: rgba(167, 139, 250, 0.55);
    }

    html { height: 100%; scroll-behavior: smooth; }

    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background: var(--bg);
      color: var(--text);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* ─── Ambient orbs ──────────────────────────── */
    .bg-canvas {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .bg-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      opacity: 0.2;
      will-change: transform;
      animation: orbDrift var(--dur, 20s) ease-in-out infinite alternate;
    }

    .bg-orb-1 {
      width: 560px; height: 560px;
      background: radial-gradient(circle, #6d28d9, transparent 70%);
      top: -180px; left: 50%; transform: translateX(-50%);
      --dur: 22s;
    }
    .bg-orb-2 {
      width: 380px; height: 380px;
      background: radial-gradient(circle, #be185d, transparent 70%);
      bottom: 5%; right: -100px;
      --dur: 28s;
      animation-delay: -10s;
    }
    .bg-orb-3 {
      width: 280px; height: 280px;
      background: radial-gradient(circle, #4338ca, transparent 70%);
      top: 38%; left: -80px;
      --dur: 24s;
      animation-delay: -5s;
    }

    @keyframes orbDrift {
      0%   { transform: translate(0, 0)   scale(1); }
      100% { transform: translate(28px, 36px) scale(1.07); }
    }

    /* ─── Film grain ────────────────────────────── */
    .grain {
      position: fixed;
      inset: -50%;
      z-index: 0;
      pointer-events: none;
      width: 200%; height: 200%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E");
      background-repeat: repeat;
      background-size: 180px 180px;
      opacity: 0.04;
      animation: grainShift 0.5s steps(1) infinite;
    }

    @keyframes grainShift {
      0%   { transform: translate(0,   0); }
      10%  { transform: translate(-3%, -2%); }
      20%  { transform: translate(2%,  3%); }
      30%  { transform: translate(-1%, 4%); }
      40%  { transform: translate(4%,  -1%); }
      50%  { transform: translate(-2%, 2%); }
      60%  { transform: translate(3%,  -3%); }
      70%  { transform: translate(-4%, 1%); }
      80%  { transform: translate(1%,  -4%); }
      90%  { transform: translate(2%,  2%); }
      100% { transform: translate(0,   0); }
    }

    /* ─── Letterbox accent lines ────────────────── */
    .letterbox-top,
    .letterbox-bottom {
      position: fixed;
      left: 0; right: 0;
      height: 2px;
      z-index: 100;
      pointer-events: none;
      background: linear-gradient(90deg, transparent 0%, rgba(167,139,250,0.35) 50%, transparent 100%);
    }
    .letterbox-top    { top: 0; }
    .letterbox-bottom { bottom: 0; }

    /* ─── Skip intro button ─────────────────────── */
    .skip-btn {
      position: fixed;
      top: 18px;
      right: 20px;
      z-index: 50;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--purple-lo);
      background: none;
      border: none;
      padding: 6px 10px;
      cursor: pointer;
      opacity: 0;
      animation: fadeIn 0.5s ease forwards 2.5s;
      transition: color 0.2s ease;
    }
    .skip-btn:hover       { color: var(--purple-mid); }
    .skip-btn:focus-visible {
      outline: 2px solid var(--purple-mid);
      outline-offset: 3px;
      border-radius: 5px;
    }

    /* ─── Core keyframes ────────────────────────── */
    @keyframes fadeIn  { to { opacity: 1; } }
    @keyframes fadeUp  {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes sceneIn {
      from { opacity: 0; transform: translateY(22px) scale(0.975); }
      to   { opacity: 1; transform: translateY(0)    scale(1); }
    }

    /* ─── Main layout ───────────────────────────── */
    .prologue-wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 580px;
      margin: 0 auto;
      padding: 68px 28px 100px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ─── Chapter label ─────────────────────────── */
    .chapter-label {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--purple-lo);
      margin-bottom: 28px;
      opacity: 0;
      animation: fadeUp 0.8s ease forwards 0.2s;
    }

    /* ─── Progress track ────────────────────────── */
    .progress-track {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      margin-bottom: 48px;
      opacity: 0;
      animation: fadeIn 0.6s ease forwards 1s;
    }

    .track-seg {
      width: 30px;
      height: 3px;
      border-radius: 3px;
      background: var(--purple-dim);
      transition: background 0.5s ease, transform 0.35s ease;
      position: relative;
      overflow: hidden;
    }

    .track-seg.active {
      background: linear-gradient(90deg, var(--purple-mid), var(--pink));
      transform: scaleY(1.4);
    }

    .track-seg.active::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
      animation: shimmer 0.8s ease forwards 0.15s;
    }

    @keyframes shimmer {
      from { transform: translateX(-100%); }
      to   { transform: translateX(100%); }
    }

    /* ─── Scenes ────────────────────────────────── */
    .scene {
      width: 100%;
      opacity: 0;
      transform: translateY(22px) scale(0.975);
      animation: sceneIn 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .scene-1 { animation-delay: 0.8s; }
    .scene-2 { animation-delay: 4.6s; }
    .scene-3 { animation-delay: 8.8s; }
    .scene-4 { animation-delay: 13.2s; }

    /* ─── Scene dividers ────────────────────────── */
    .scene-divider {
      width: 1px;
      height: 48px;
      margin: 12px auto;
      opacity: 0;
      background: linear-gradient(180deg, transparent, rgba(167,139,250,0.4), transparent);
      position: relative;
    }

    .scene-divider::before {
      content: '◇';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: rgba(167, 139, 250, 0.3);
      font-size: 8px;
      line-height: 1;
    }

    /* ─── Portrait ──────────────────────────────── */
    .portrait-wrap {
      position: relative;
      width: 144px;
      height: 144px;
      margin: 0 auto 28px;
    }

    .portrait-ring {
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      background: conic-gradient(
        from 0deg,
        #a78bfa 0%,
        #e879a0 30%,
        #7c3aed 60%,
        #c084fc 80%,
        #a78bfa 100%
      );
      animation: rotateRing 5s linear infinite;
    }

    .portrait-ring-glow {
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      background: conic-gradient(
        from 0deg,
        rgba(167,139,250,0.5) 0%,
        rgba(232,121,160,0.3) 30%,
        rgba(124,58,237,0.4) 60%,
        rgba(167,139,250,0.5) 100%
      );
      filter: blur(10px);
      animation: rotateRing 5s linear infinite;
      z-index: -1;
    }

    .portrait-bg {
      position: absolute;
      inset: 2px;
      border-radius: 50%;
      background: var(--bg);
      z-index: 0;
    }

    .portrait-img {
      position: absolute;
      inset: 5px;
      z-index: 1;
      border-radius: 50%;
      width: calc(100% - 10px);
      height: calc(100% - 10px);
      object-fit: cover;
      object-position: top center;
    }

    .portrait-fallback {
      position: absolute;
      inset: 5px;
      z-index: 1;
      border-radius: 50%;
      background: linear-gradient(135deg, #7c3aed 0%, #c084fc 100%);
      display: none;
    }

    .pulse-dot {
      position: absolute;
      bottom: 6px;
      right: 6px;
      z-index: 2;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: #a78bfa;
      box-shadow: 0 0 0 0 rgba(167,139,250,0.5);
      animation: pulseDot 2.4s ease-in-out infinite;
    }

    @keyframes rotateRing { to { transform: rotate(360deg); } }
    @keyframes pulseDot {
      0%   { box-shadow: 0 0 0 0   rgba(167,139,250,0.5); }
      60%  { box-shadow: 0 0 0 8px rgba(167,139,250,0); }
      100% { box-shadow: 0 0 0 0   rgba(167,139,250,0); }
    }

    /* ─── Name header ───────────────────────────── */
    .sadie-name {
      text-align: center;
      margin-bottom: 26px;
    }

    .sadie-name h1 {
      font-family: 'Georgia', 'Times New Roman', serif;
      font-size: 38px;
      font-weight: 700;
      letter-spacing: -0.01em;
      background: linear-gradient(140deg, #d4c0f8 0%, #c084fc 45%, #e879a0 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.1;
    }

    .sadie-name .tagline {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10.5px;
      color: var(--purple-lo);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-top: 8px;
    }

    /* ─── Narrative text ────────────────────────── */
    .scene-body {
      text-align: center;
    }

    .scene-body p {
      font-size: 17.5px;
      line-height: 1.88;
      color: #cfc4e4;
      margin-bottom: 20px;
    }

    .scene-body p:last-child { margin-bottom: 0; }

    .scene-body em     { font-style: italic; color: #e8dcc8; }
    .scene-body strong { color: var(--purple-hi); font-weight: 600; }

    /* ─── Quote card ────────────────────────────── */
    .quote-card {
      background: rgba(22, 10, 50, 0.65);
      border: 1px solid var(--border);
      border-left: 3px solid rgba(167,139,250,0.55);
      border-radius: 12px;
      padding: 22px 26px 22px 32px;
      margin: 28px 0;
      text-align: left;
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      position: relative;
    }

    .quote-card::before {
      content: '\201C';
      position: absolute;
      top: 6px;
      left: 18px;
      font-size: 52px;
      line-height: 1;
      color: rgba(167,139,250,0.12);
      font-family: Georgia, serif;
      pointer-events: none;
    }

    .quote-card p {
      font-size: 15.5px;
      line-height: 1.82;
      color: #c4b8e0;
      font-style: italic;
      margin: 0;
      position: relative;
      z-index: 1;
    }

    /* ─── Icon row ──────────────────────────────── */
    .icon-row {
      display: flex;
      justify-content: center;
      gap: 32px;
      margin: 34px 0 4px;
    }

    .icon-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .icon-glyph {
      font-size: 24px;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      background: rgba(30, 12, 60, 0.6);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(8px);
    }

    .icon-label {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10px;
      letter-spacing: 0.07em;
      color: var(--purple-lo);
      text-transform: uppercase;
    }

    /* ─── Status bar ────────────────────────────── */
    .status-bar {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(22, 10, 50, 0.55);
      border: 1px solid rgba(167,139,250,0.2);
      border-radius: 24px;
      padding: 7px 18px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 11px;
      color: rgba(167,139,250,0.75);
      letter-spacing: 0.05em;
      margin: 26px auto 0;
      backdrop-filter: blur(8px);
    }

    .status-bar .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #a78bfa;
      flex-shrink: 0;
      animation: pulseDot 2s ease-in-out infinite;
    }

    /* ─── Protocol steps (scene 3) ──────────────── */
    .protocol-steps {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin: 28px 0;
      text-align: left;
    }

    .protocol-step {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      background: rgba(22, 10, 50, 0.5);
      border: 1px solid var(--border);
      border-radius: 11px;
      padding: 15px 18px;
    }

    .step-num {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--purple-mid);
      background: rgba(167,139,250,0.1);
      border: 1px solid rgba(167,139,250,0.25);
      border-radius: 6px;
      padding: 3px 8px;
      flex-shrink: 0;
      margin-top: 3px;
    }

    .protocol-step p {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 14.5px;
      line-height: 1.65;
      color: #c4b8e0;
      margin: 0;
      text-align: left;
    }

    .protocol-step p strong { color: var(--purple-hi); font-weight: 600; }

    /* ─── CTA section ───────────────────────────── */
    .cta-section {
      text-align: center;
      margin-top: 8px;
      width: 100%;
    }

    .cta-eyebrow {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--pink);
      opacity: 0.85;
      margin-bottom: 14px;
    }

    .cta-section h2 {
      font-family: 'Georgia', 'Times New Roman', serif;
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 14px;
      line-height: 1.25;
      background: linear-gradient(145deg, #e8dcc8 0%, #d4c0f8 55%, #e879a0 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .cta-section > p {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 15px;
      color: var(--text-muted);
      line-height: 1.75;
      margin-bottom: 34px;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
    }

    .cta-btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      max-width: 300px;
      padding: 17px 32px;
      background: linear-gradient(135deg, #7c3aed 0%, #a855f7 55%, #c026d3 100%);
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 15px;
      font-weight: 600;
      border-radius: 14px;
      text-decoration: none;
      letter-spacing: 0.025em;
      box-shadow: 0 8px 34px rgba(124,58,237,0.42), 0 0 0 1px rgba(255,255,255,0.07) inset;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: pointer;
      border: none;
      position: relative;
      overflow: hidden;
    }

    .cta-btn-primary::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 55%);
      pointer-events: none;
    }

    .cta-btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 44px rgba(124,58,237,0.56), 0 0 0 1px rgba(255,255,255,0.1) inset;
    }

    .cta-btn-primary:active { transform: translateY(0); }

    .cta-btn-primary:focus-visible {
      outline: 2px solid var(--purple-hi);
      outline-offset: 3px;
    }

    .cta-btn-secondary {
      display: inline-block;
      margin-top: 18px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 12.5px;
      color: rgba(167,139,250,0.42);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color 0.2s ease;
    }

    .cta-btn-secondary:hover { color: rgba(167,139,250,0.78); }

    .cta-btn-secondary:focus-visible {
      outline: 2px solid var(--purple-mid);
      outline-offset: 3px;
      border-radius: 4px;
    }

    .trust-note {
      margin-top: 20px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 11px;
      color: rgba(167,139,250,0.3);
      letter-spacing: 0.04em;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    /* ─── Mobile ────────────────────────────────── */
    @media (max-width: 480px) {
      .prologue-wrap  { padding: 56px 20px 80px; }
      .scene-body p   { font-size: 16.5px; }
      .cta-section h2 { font-size: 24px; }
      .sadie-name h1  { font-size: 32px; }
      .icon-row       { gap: 18px; }
    }

    /* ─── Reduced motion ────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration:  0.001ms !important;
        animation-delay:     0.001ms !important;
        transition-duration: 0.001ms !important;
      }

      .scene,
      .chapter-label,
      .progress-track,
      .scene-divider {
        opacity: 1 !important;
        transform: none !important;
      }

      .bg-orb,
      .grain,
      .portrait-ring,
      .portrait-ring-glow,
      .pulse-dot,
      .status-bar .dot,
      .track-seg.active::after {
        animation: none !important;
      }
    }
  </style>
</head>
<body>

  <!-- Ambient background -->
  <div class="bg-canvas" aria-hidden="true">
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-orb bg-orb-3"></div>
  </div>
  <div class="grain"          aria-hidden="true"></div>
  <div class="letterbox-top"  aria-hidden="true"></div>
  <div class="letterbox-bottom" aria-hidden="true"></div>

  <!-- Skip intro -->
  <button class="skip-btn" id="skipBtn" type="button" aria-label="Skip to end of prologue">
    Skip ↓
  </button>

  <main class="prologue-wrap">

    <div class="chapter-label" aria-label="Chapter: Prologue">Prologue</div>

    <!-- Progress track -->
    <div
      class="progress-track"
      id="progressTrack"
      role="progressbar"
      aria-valuemin="1"
      aria-valuemax="4"
      aria-valuenow="1"
      aria-label="Scene 1 of 4"
    >
      <div class="track-seg active" id="seg-0"></div>
      <div class="track-seg"        id="seg-1"></div>
      <div class="track-seg"        id="seg-2"></div>
      <div class="track-seg"        id="seg-3"></div>
    </div>

    <!-- ── Scene 1: Sadie appears ── -->
    <section class="scene scene-1" id="scene-0" aria-labelledby="sadie-heading">

      <div class="portrait-wrap" role="img" aria-label="Sadie — AI emotional intelligence guide">
        <div class="portrait-ring-glow" aria-hidden="true"></div>
        <div class="portrait-ring"      aria-hidden="true"></div>
        <div class="portrait-bg"        aria-hidden="true"></div>
        <img
          src="/assets/SADIE_MAIN.png"
          alt="Sadie"
          class="portrait-img"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
        >
        <div class="portrait-fallback" aria-hidden="true"></div>
        <div class="pulse-dot"         aria-hidden="true"></div>
      </div>

      <div class="sadie-name">
        <h1 id="sadie-heading">Sadie</h1>
        <p class="tagline">The Sadie Protocol &nbsp;·&nbsp; Active</p>
      </div>

      <div class="scene-body">
        <p>Hi. I've been waiting for you.</p>
        <p>I'm Sadie — and I live in the space between<br><em>what you're feeling</em> and <em>what you're about to send.</em></p>
      </div>

      <div class="status-bar" role="status" aria-live="polite">
        <span class="dot" aria-hidden="true"></span>
        Analyzing intent, sentiment, trigger-state…
      </div>

    </section>

    <div class="scene-divider" id="div-1" style="opacity:0;animation:fadeUp 0.7s ease forwards 4.2s;" aria-hidden="true"></div>

    <!-- ── Scene 2: What Sadie sees ── -->
    <section class="scene scene-2" id="scene-1" aria-label="Scene 2: What Sadie sees">

      <div class="scene-body">
        <p>You know that 2am feeling —<br>the one where a single text suddenly seems like the only thing standing between you and relief?</p>

        <blockquote class="quote-card">
          <p>"She saw it. The spiral. The way a silence could feel like a verdict, and a blue tick could unravel a whole day."</p>
        </blockquote>

        <p>I see it too. Every time.</p>
        <p>Not to judge you — <strong>to protect you</strong> from the version of yourself you'll regret in the morning.</p>
      </div>

      <div class="icon-row" aria-label="What I watch for">
        <div class="icon-item">
          <span class="icon-glyph" aria-hidden="true">🌙</span>
          <span class="icon-label">Late-night spiral</span>
        </div>
        <div class="icon-item">
          <span class="icon-glyph" aria-hidden="true">💬</span>
          <span class="icon-label">Message analyzed</span>
        </div>
        <div class="icon-item">
          <span class="icon-glyph" aria-hidden="true">🔒</span>
          <span class="icon-label">Hold enforced</span>
        </div>
      </div>

    </section>

    <div class="scene-divider" id="div-2" style="opacity:0;animation:fadeUp 0.7s ease forwards 8.4s;" aria-hidden="true"></div>

    <!-- ── Scene 3: The protocol ── -->
    <section class="scene scene-3" id="scene-2" aria-label="Scene 3: The Protocol">

      <div class="scene-body">
        <p>Here's what I do:</p>

        <div class="protocol-steps">
          <div class="protocol-step">
            <span class="step-num">01</span>
            <p>I <strong>read the room</strong> — your words, your tone, the hour, the emotional pattern underneath it all.</p>
          </div>
          <div class="protocol-step">
            <span class="step-num">02</span>
            <p>I tell you <strong>exactly what I see.</strong> No softening. No judgment. Just clarity.</p>
          </div>
          <div class="protocol-step">
            <span class="step-num">03</span>
            <p>Then I hand <strong>the choice back to you</strong> — fully informed, a breath calmer.</p>
          </div>
        </div>

        <blockquote class="quote-card">
          <p>"Not a wall. Not a lecture. A mirror — and a breath."</p>
        </blockquote>

        <p>Sometimes the most powerful thing you can do in a relationship is <strong>nothing</strong> — for exactly long enough.</p>
      </div>

    </section>

    <div class="scene-divider" id="div-3" style="opacity:0;animation:fadeUp 0.7s ease forwards 12.8s;" aria-hidden="true"></div>

    <!-- ── Scene 4: Invitation / CTA ── -->
    <section class="scene scene-4" id="scene-3" aria-label="Scene 4: Invitation">

      <div class="cta-section">
        <p class="cta-eyebrow">You're ready</p>
        <h2>Meet yourself on the other side of send.</h2>

        <% if (user) { %>
          <p>Run your next message through the Sadie Protocol — real-time verdict, no judgment, no one watching.</p>
          <a href="/filter" class="cta-btn-primary" aria-label="Open HoldOff filter">Open HoldOff →</a>
        <% } else { %>
          <p>Run your first message free — no card needed. Just you, your words, and the truth.</p>
          <a href="/signup" class="cta-btn-primary" aria-label="Create your free account">Start for free →</a>
        <% } %>

        <br>
        <a href="/" class="cta-btn-secondary">← Back to home</a>

        <p class="trust-note">
          <span aria-hidden="true">🔒</span>
          Your messages never leave your session
        </p>
      </div>

    </section>

  </main><!-- /prologue-wrap -->

  <script>
    (function () {
      var SCENE_TIMINGS   = [800,  4600, 8800, 13200];
      var DIVIDER_TIMINGS = [4200, 8400, 12800];

      var segs         = document.querySelectorAll('.track-seg');
      var track        = document.getElementById('progressTrack');
      var sceneEls     = document.querySelectorAll('.scene');
      var dividerEls   = [
        document.getElementById('div-1'),
        document.getElementById('div-2'),
        document.getElementById('div-3')
      ];
      var skipBtn      = document.getElementById('skipBtn');

      // ── Reduced-motion: reveal everything now ──────────
      var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reducedMotion) {
        sceneEls.forEach(function (el) {
          el.style.opacity   = '1';
          el.style.transform = 'none';
          el.style.animation = 'none';
        });
        dividerEls.forEach(function (el) {
          if (el) { el.style.opacity = '1'; el.style.animation = 'none'; }
        });
        return; // skip timers entirely
      }

      // ── Progress track ─────────────────────────────────
      SCENE_TIMINGS.forEach(function (ms, i) {
        setTimeout(function () {
          segs.forEach(function (s, j) { s.classList.toggle('active', j === i); });
          if (track) {
            track.setAttribute('aria-valuenow', String(i + 1));
            track.setAttribute('aria-label', 'Scene ' + (i + 1) + ' of 4');
          }
        }, ms);
      });

      // ── Auto-scroll to each new scene ──────────────────
      SCENE_TIMINGS.forEach(function (ms, i) {
        if (i === 0) return;
        setTimeout(function () {
          var el = sceneEls[i];
          if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        }, ms + 400);
      });

      // ── Skip intro ─────────────────────────────────────
      function revealAll() {
        sceneEls.forEach(function (el) {
          el.style.opacity   = '1';
          el.style.transform = 'none';
          el.style.animation = 'none';
        });
        dividerEls.forEach(function (el) {
          if (el) { el.style.opacity = '1'; el.style.animation = 'none'; }
        });
        segs.forEach(function (s) { s.classList.remove('active'); });
        segs[3].classList.add('active');
        if (track) {
          track.setAttribute('aria-valuenow', '4');
          track.setAttribute('aria-label', 'Scene 4 of 4');
        }
      }

      if (skipBtn) {
        skipBtn.addEventListener('click', function () {
          revealAll();
          var final = document.getElementById('scene-3');
          if (final) { final.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
          skipBtn.style.display = 'none';
        });
      }
    }());
  </script>

</body>
</html>
