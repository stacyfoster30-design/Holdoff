<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Reset password — HoldOff</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#0E0C0B">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/pwa.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    body {
      background: #0E0C0B;
      color: #F5EFE9;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .card {
      background: #1C1917;
      border: 1px solid #2A2522;
      border-radius: 12px;
      padding: 2.5rem 2rem;
      max-width: 420px;
      width: 100%;
      text-align: center;
    }
    .wordmark {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: #C97B5D;
      text-decoration: none;
      display: block;
      margin-bottom: 2rem;
    }
    h1 {
      font-family: 'Fraunces', serif;
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    p {
      color: #9A8F8A;
      font-size: 0.9rem;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    .field {
      margin-bottom: 1rem;
      text-align: left;
    }
    label {
      display: block;
      font-size: 0.8rem;
      color: #9A8F8A;
      margin-bottom: 0.4rem;
    }
    input {
      width: 100%;
      padding: 0.7rem 0.9rem;
      background: #0E0C0B;
      border: 1px solid #2A2522;
      border-radius: 6px;
      color: #F5EFE9;
      font-family: inherit;
      font-size: 0.95rem;
      box-sizing: border-box;
    }
    input:focus {
      outline: none;
      border-color: #C97B5D;
    }
    .btn {
      width: 100%;
      padding: 0.8rem;
      background: #C97B5D;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-family: inherit;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
    }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .message {
      padding: 0.75rem 1rem;
      border-radius: 6px;
      font-size: 0.85rem;
      margin-bottom: 1rem;
      text-align: left;
    }
    .message.error { background: #2A1515; color: #F5A87A; border: 1px solid #3A2020; }
    .message.success { background: #152A1F; color: #7AC9A8; border: 1px solid #1F3A2A; }
    .back { margin-top: 1.5rem; font-size: 0.8rem; }
    .back a { color: #9A8F8A; text-decoration: none; }
    .back a:hover { color: #C97B5D; }
  </style>
</head>
<body>
  <div class="card">
    <a href="/" class="wordmark">HoldOff</a>

    <div id="msg框"></div>

    <div id="formArea">
      <h1>Set a new password</h1>
      <p>Make sure it's at least 8 characters. After you save, you'll need to log in again on all devices.</p>
      <form id="resetForm" autocomplete="off">
        <input type="hidden" id="tokenField" name="token">
        <div class="field">
          <label for="pw1">New password</label>
          <input type="password" id="pw1" name="new_password" placeholder="At least 8 characters" minlength="8" required>
        </div>
        <div class="field">
          <label for="pw2">Confirm new password</label>
          <input type="password" id="pw2" placeholder="Same as above" minlength="8" required>
        </div>
        <button type="submit" class="btn" id="submitBtn">Save new password</button>
      </form>
    </div>

    <div id="doneArea" style="display:none;">
      <h1>All set</h1>
      <p>Your password has been changed. You can log in now.</p>
      <a href="/filter" class="btn" style="display:inline-block;width:auto;padding:0.8rem 2rem;text-decoration:none;">Log in</a>
    </div>

    <div class="back">
      <a href="/filter">← Back to HoldOff</a>
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    document.getElementById('tokenField').value = token || '';

    if (!token) {
      showMsg('Missing reset token. Use the link from your email.', 'error');
      document.getElementById('formArea').style.display = 'none';
    }

    function showMsg(html, type) {
      document.getElementById('msg框').innerHTML =
        '<div class="message ' + type + '">' + html + '</div>';
    }

    document.getElementById('resetForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const pw1 = document.getElementById('pw1').value;
      const pw2 = document.getElementById('pw2').value;
      const tok = document.getElementById('tokenField').value;

      if (pw1 !== pw2) {
        showMsg('Passwords don\'t match.', 'error');
        return;
      }
      if (pw1.length < 8) {
        showMsg('Password must be at least 8 characters.', 'error');
        return;
      }

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Saving…';

      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: tok, new_password: pw1 }),
        });
        const data = await res.json();
        if (res.ok && data.ok) {
          document.getElementById('formArea').style.display = 'none';
          document.getElementById('doneArea').style.display = 'block';
        } else {
          showMsg(data.error || 'Something went wrong. Please try again.', 'error');
          btn.disabled = false;
          btn.textContent = 'Save new password';
        }
      } catch {
        showMsg('Network error. Please check your connection.', 'error');
        btn.disabled = false;
        btn.textContent = 'Save new password';
      }
    });
  </script>
</body>
</html>
