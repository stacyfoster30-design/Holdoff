<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Reset Password — HoldOff</title>
  <style>
    .auth-container {
      min-height:100vh; display:flex; flex-direction:column;
      align-items:center; justify-content:center; padding:40px 24px;
      position:relative; z-index:1;
    }
    .auth-logo { font-size:3rem; margin-bottom:8px; }
    .auth-title {
      font-size:1.8rem; font-weight:700; margin-bottom:4px;
      background: linear-gradient(135deg, var(--primary), var(--rose));
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
    }
    .auth-subtitle { color:var(--text-muted); font-size:0.95rem; margin-bottom:32px; }
    .auth-card {
      width:100%; max-width:380px; background:var(--bg-card);
      border:1px solid var(--border); border-radius:var(--radius);
      padding:28px 24px;
    }
    .auth-footer { margin-top:20px; text-align:center; font-size:0.9rem; color:var(--text-muted); }
    .message {
      padding:10px 14px; border-radius:var(--radius-sm); font-size:0.9rem;
      margin-bottom:16px;
    }
    .message.error {
      background:rgba(232,121,121,0.1); border:1px solid rgba(232,121,121,0.3);
      color:var(--danger);
    }
    .message.success {
      background:rgba(109,206,168,0.1); border:1px solid rgba(109,206,168,0.3);
      color:var(--success);
    }
    #doneArea { display:none; text-align:center; }
    #doneArea .check-icon { font-size:3rem; margin-bottom:12px; }
  </style>
</head>
<body>
  <div class="auth-container">
    <div class="auth-logo">💜</div>
    <h1 class="auth-title">New Password</h1>
    <p class="auth-subtitle">Choose a strong password for your account</p>

    <div class="auth-card">
      <div id="msgBox"></div>

      <div id="formArea">
        <form id="resetForm" autocomplete="off">
          <input type="hidden" id="tokenField" name="token">
          <div class="form-group">
            <label class="form-label" for="pw1">New password</label>
            <input type="password" id="pw1" name="new_password" class="form-input" placeholder="At least 8 characters" minlength="8" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="pw2">Confirm password</label>
            <input type="password" id="pw2" class="form-input" placeholder="Same as above" minlength="8" required>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg" id="submitBtn">Save New Password</button>
        </form>
      </div>

      <div id="doneArea">
        <div class="check-icon">✅</div>
        <h2 style="margin-bottom:8px;">All set!</h2>
        <p style="color:var(--text-muted);margin-bottom:20px;">Your password has been changed.</p>
        <a href="/login" class="btn btn-primary">Sign In</a>
      </div>

      <div class="auth-footer">
        <a href="/login">← Back to Sign In</a>
      </div>
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    document.getElementById('tokenField').value = token || '';

    if (!token) {
      showMsg('Missing reset token. Use the link from your email.', 'error');
      document.getElementById('formArea').style.display = 'none';
    }

    function showMsg(text, type) {
      document.getElementById('msgBox').innerHTML =
        '<div class="message ' + type + '">' + text + '</div>';
    }

    document.getElementById('resetForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const pw1 = document.getElementById('pw1').value;
      const pw2 = document.getElementById('pw2').value;
      const btn = document.getElementById('submitBtn');

      if (pw1 !== pw2) { showMsg('Passwords don\'t match.', 'error'); return; }
      if (pw1.length < 8) { showMsg('Password must be at least 8 characters.', 'error'); return; }

      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: document.getElementById('tokenField').value, newPassword: pw1 })
        });
        const data = await res.json();
        if (res.ok) {
          document.getElementById('formArea').style.display = 'none';
          document.getElementById('msgBox').innerHTML = '';
          document.getElementById('doneArea').style.display = 'block';
        } else {
          showMsg(data.error || 'Reset failed. Please request a new link.', 'error');
          btn.disabled = false;
          btn.textContent = 'Save New Password';
        }
      } catch (err) {
        showMsg('Something went wrong. Please try again.', 'error');
        btn.disabled = false;
        btn.textContent = 'Save New Password';
      }
    });
  </script>
</body>
</html>
