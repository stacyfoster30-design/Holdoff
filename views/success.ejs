<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>HoldOff — You're in</title>

  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-title" content="HoldOff">
  <meta name="theme-color" content="#0E0C0B">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
  <meta name="description" content="HoldOff Pro — your filter is active.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">

  <style>
    body {
      background: #0E0C0B;
      color: #FAF6F0;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .success-card {
      max-width: 520px;
      margin: 2rem;
      background: #1a1614;
      border: 1px solid #2e2926;
      border-radius: 16px;
      padding: 3rem 2.5rem;
      text-align: center;
    }
    .success-card__icon {
      width: 56px;
      height: 56px;
      background: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .success-card__icon svg {
      width: 28px;
      height: 28px;
      fill: none;
      stroke: #FAF6F0;
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .success-card__eyebrow {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .success-card__headline {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #FAF6F0;
      margin-bottom: 1rem;
      line-height: 1.15;
    }
    .success-card__sub {
      font-size: 1rem;
      color: rgba(250,246,240,0.6);
      line-height: 1.7;
      margin-bottom: 2rem;
    }
    .success-card__tier {
      display: inline-block;
      background: rgba(201,123,93,0.12);
      border: 1px solid rgba(201,123,93,0.3);
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 600;
      padding: 0.35rem 1rem;
      border-radius: 100px;
      margin-bottom: 2rem;
    }
    .success-card__cta {
      display: inline-block;
      background: var(--accent);
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      padding: 0.85rem 2rem;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.15s;
    }
    .success-card__cta:hover {
      background: var(--accent-deep);
    }
    .success-card__footer {
      margin-top: 1.5rem;
      font-size: 0.8rem;
      color: rgba(250,246,240,0.35);
    }
    .success-card__footer a {
      color: rgba(250,246,240,0.5);
      text-decoration: underline;
    }
    /* Loading spinner */
    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid rgba(201,123,93,0.2);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 3rem auto;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

  <div class="success-card" id="successCard" style="display:none;">
    <div class="success-card__icon">
      <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
    <div class="success-card__eyebrow">HoldOff Pro</div>
    <h1 class="success-card__headline">You're in.</h1>
    <p class="success-card__sub" id="tierSub">Your filter is active. Open HoldOff and start using it.</p>
    <span class="success-card__tier" id="tierBadge"></span>
    <br>
    <a href="/filter" class="success-card__cta">Head to /filter →</a>
    <p class="success-card__footer" id="billingFooter"></p>
  </div>

  <div id="loadingState">
    <div class="spinner"></div>
  </div>

  <script>
    async function verifyAndShow() {
      const params = new URLSearchParams(window.location.search);
      const sessionId = params.get('session_id');
      if (!sessionId) {
        showError();
        return;
      }

      try {
        const res = await fetch(`/api/checkout/verify-session?session_id=${encodeURIComponent(sessionId)}`);
        const data = await res.json();

        if (!res.ok || !data.verified) {
          showError();
          return;
        }

        const tier = data.tier || 'Pro';
        const tierDisplay = tier.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

        document.getElementById('tierBadge').textContent = tierDisplay;
        document.getElementById('tierSub').textContent =
          'Your HoldOff ' + tierDisplay + ' is active. Open HoldOff and start using it.';
        document.getElementById('billingFooter').innerHTML =
          'Your receipt: <a href="/api/checkout/portal">View in Stripe billing portal →</a>';

        document.getElementById('loadingState').style.display = 'none';
        document.getElementById('successCard').style.display = 'block';
      } catch {
        showError();
      }
    }

    function showError() {
      document.getElementById('loadingState').innerHTML =
        '<div style="text-align:center;color:rgba(250,246,240,0.5);font-size:1rem;margin-top:3rem;">' +
        'Could not verify payment. <a href="/filter" style="color:var(--accent);">Go to filter</a>' +
        '</div>';
    }

    verifyAndShow();
  </script>

</body>
</html>
