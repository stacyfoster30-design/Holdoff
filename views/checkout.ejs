<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>HoldOff — Start your plan</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-title" content="HoldOff">
  <meta name="theme-color" content="#0E0C0B">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
  <meta name="description" content="Start your HoldOff plan — online or app, monthly or annual.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    .checkout-wrap { max-width: 560px; margin: 5rem auto 4rem; padding: 0 1.5rem; text-align: center; }
    .checkout-wrap h1 { font-family: var(--font-serif); font-size: 2.2rem; margin-bottom: .5rem; }
    .checkout-wrap p { color: #9ca3af; margin-bottom: 2.5rem; }
    .plan-cards { display: grid; gap: 1.2rem; margin-bottom: 2rem; }
    .plan-card { background: #1a1a2e; border: 1px solid #374151; border-radius: 12px; padding: 1.5rem; text-align: left; cursor: pointer; transition: border-color .2s; }
    .plan-card:hover, .plan-card.selected { border-color: var(--accent); }
    .plan-card h3 { margin: 0 0 .3rem; font-size: 1.1rem; }
    .plan-card .price { font-size: 1.6rem; font-weight: 700; color: var(--accent); }
    .plan-card .desc { color: #9ca3af; font-size: .875rem; margin-top: .4rem; }
    .checkout-btn { width: 100%; padding: 1rem; background: var(--accent); color: #fff; border: none; border-radius: 10px; font-size: 1.1rem; font-weight: 600; cursor: pointer; }
    .checkout-btn:hover { opacity: .9; }
    .checkout-btn:disabled { opacity: .5; cursor: not-allowed; }
    .checkout-note { color: #6b7280; font-size: .8rem; margin-top: .75rem; }
  </style>
</head>
<body>
  <nav class="nav">
    <a href="/" class="nav__logo">HoldOff</a>
    <div class="nav__links">
      <a href="/pricing">All plans</a>
    </div>
  </nav>

  <div class="checkout-wrap">
    <h1>Start your plan</h1>
    <p>Pick the plan that fits. Cancel anytime.</p>

    <div class="plan-cards">
      <div class="plan-card selected" id="card-online_monthly" onclick="selectPlan('online_monthly')">
        <h3>HoldOff Online — Monthly</h3>
        <div class="price">$9.99<span style="font-size:1rem;font-weight:400;color:#9ca3af">/mo</span></div>
        <div class="desc">Unlimited web verdicts · All future web features · Email support</div>
      </div>
      <div class="plan-card" id="card-online_annual" onclick="selectPlan('online_annual')">
        <h3>HoldOff Online — Annual</h3>
        <div class="price">$99<span style="font-size:1rem;font-weight:400;color:#9ca3af">/yr</span></div>
        <div class="desc">Save ~17% vs monthly · All online features · Best value</div>
      </div>
      <div class="plan-card" id="card-app_monthly" onclick="selectPlan('app_monthly')">
        <h3>HoldOff App — Monthly</h3>
        <div class="price">$14.99<span style="font-size:1rem;font-weight:400;color:#9ca3af">/mo</span></div>
        <div class="desc">Everything in Online + Android app · Real-time intercept · Spiral Lock</div>
      </div>
    </div>

    <button class="checkout-btn" id="checkoutBtn" onclick="startCheckout()">Continue to payment</button>
    <p class="checkout-note">Powered by Stripe · Secure · Cancel anytime</p>
  </div>

  <script>
    let selectedPlan = "online_monthly";

    function selectPlan(tier) {
      document.querySelectorAll(".plan-card").forEach(c => c.classList.remove("selected"));
      document.getElementById("card-" + tier).classList.add("selected");
      selectedPlan = tier;
    }

    async function startCheckout() {
      const btn = document.getElementById("checkoutBtn");
      btn.textContent = "Loading..."; btn.disabled = true;
      try {
        const res = await fetch("/api/checkout/start", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ tier: selectedPlan })
        });
        const d = await res.json();
        if (d.url) { window.location = d.url; }
        else { alert(d.error || "Something went wrong — try again"); btn.textContent = "Continue to payment"; btn.disabled = false; }
      } catch(e) { alert("Network error — try again"); btn.textContent = "Continue to payment"; btn.disabled = false; }
    }

    // Pre-select from URL param ?tier=
    const urlTier = new URLSearchParams(window.location.search).get("tier");
    if (urlTier && document.getElementById("card-" + urlTier)) selectPlan(urlTier);
  </script>
</body>
</html>
