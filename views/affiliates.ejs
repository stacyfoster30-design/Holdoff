  <style>
    /* Affiliates page styles */
    .aff-page {
      max-width: 720px;
      margin: 0 auto;
      padding: 6rem 1.5rem 5rem;
    }

    /* Hero */
    .aff-hero__eyebrow {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .aff-hero__h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 6vw, 3.2rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.05;
      color: var(--fg);
      margin-bottom: 1.25rem;
    }
    .aff-hero__subhead {
      font-size: 1.05rem;
      color: var(--muted);
      line-height: 1.65;
      max-width: 560px;
      margin-bottom: 3rem;
    }

    /* Section headings */
    .aff-section {
      margin-bottom: 3.5rem;
    }
    .aff-section__heading {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--fg);
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }
    .aff-section__body {
      font-size: 1rem;
      color: #4A3F3A;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    /* Steps */
    .aff-steps {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 1.25rem;
    }
    .aff-step {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
    }
    .aff-step__num {
      flex-shrink: 0;
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--accent);
      color: #fff;
      font-family: var(--font-display);
      font-size: 0.9rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 0.1rem;
    }
    .aff-step__text {
      font-size: 0.95rem;
      color: #4A3F3A;
      line-height: 1.65;
    }
    .aff-step__text strong {
      color: var(--fg);
    }

    /* Commission callout */
    .aff-callout {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem;
      margin: 2rem 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .aff-callout__stat {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
    .aff-callout__number {
      font-family: var(--font-display);
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--accent);
      line-height: 1;
    }
    .aff-callout__label {
      font-size: 0.95rem;
      color: #4A3F3A;
      line-height: 1.4;
    }

    /* Why partner — bullets */
    .aff-why-list {
      list-style: none;
      padding: 0;
      margin: 1.25rem 0 0;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }
    .aff-why-list li {
      font-size: 0.95rem;
      color: #4A3F3A;
      line-height: 1.65;
      padding-left: 1.5rem;
      position: relative;
    }
    .aff-why-list li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--accent);
    }

    /* Signup form */
    .aff-form {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      margin-bottom: 3.5rem;
    }
    .aff-form__heading {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 0.5rem;
    }
    .aff-form__sub {
      font-size: 0.875rem;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }
    .aff-form__fields {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .aff-form__field {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .aff-form__field--full {
      grid-column: 1 / -1;
    }
    .aff-form__label {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: var(--muted);
      text-transform: uppercase;
    }
    .aff-form__input,
    .aff-form__select {
      padding: 0.8rem 1rem;
      border: 2px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.15s;
    }
    .aff-form__input:focus,
    .aff-form__select:focus { border-color: var(--accent); }
    .aff-form__input::placeholder { color: var(--muted); }
    .aff-form__btn {
      margin-top: 1.25rem;
      width: 100%;
      padding: 0.9rem 1.5rem;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    .aff-form__btn:hover { background: var(--accent-deep); }
    .aff-form__btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .aff-form__confirm {
      margin-top: 1.25rem;
      font-size: 0.95rem;
      color: var(--fg);
      font-weight: 500;
      text-align: center;
    }
    .aff-form__confirm em { color: var(--accent); font-style: italic; }
    .aff-form__note {
      margin-top: 0.75rem;
      font-size: 0.8rem;
      color: var(--muted);
      text-align: center;
    }
    @media (max-width: 560px) {
      .aff-form__fields { grid-template-columns: 1fr; }
      .aff-form__field--full { grid-column: 1; }
    }

    /* FAQ */
    .aff-faq {
      margin-bottom: 3.5rem;
    }
    .aff-faq__heading {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 1.5rem;
    }
    .aff-faq__item {
      border-top: 1px solid var(--border);
      padding: 1.25rem 0;
    }
    .aff-faq__item:last-child {
      border-bottom: 1px solid var(--border);
    }
    .aff-faq__q {
      font-size: 0.975rem;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 0.5rem;
    }
    .aff-faq__a {
      font-size: 0.9rem;
      color: #4A3F3A;
      line-height: 1.65;
    }
