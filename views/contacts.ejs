<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contacts - HoldOff</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, #1a0033 0%, #2d0052 100%);
      color: #fff;
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    header {
      margin-bottom: 40px;
    }

    h1 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .contacts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }

    .contact-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(147, 112, 219, 0.3);
      border-radius: 12px;
      padding: 20px;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .contact-card:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(147, 112, 219, 0.6);
      transform: translateY(-2px);
    }

    .contact-name {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 5px;
    }

    .contact-last-message {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.6);
      margin-bottom: 10px;
    }

    .contact-timestamp {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.4);
    }

    .empty-state {
      text-align: center;
      padding: 60px 20px;
    }

    .empty-state h2 {
      font-size: 24px;
      margin-bottom: 10px;
      color: rgba(255, 255, 255, 0.7);
    }

    .empty-state p {
      color: rgba(255, 255, 255, 0.5);
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Contacts</h1>
      <p>Your connections on HoldOff</p>
    </header>

    <div class="contacts-grid" id="contactsList">
      <!-- Contacts will be loaded here -->
    </div>

    <div class="empty-state" id="emptyState" style="display: none;">
      <h2>No contacts yet</h2>
      <p>Start a conversation to add contacts</p>
    </div>
  </div>

  <script>
    // Load contacts from API or display empty state
    fetch('/api/contacts', { method: 'GET' })
      .then(res => res.json())
      .then(data => {
        const list = document.getElementById('contactsList');
        const empty = document.getElementById('emptyState');

        if (data.contacts && data.contacts.length > 0) {
          list.innerHTML = data.contacts.map(contact => `
            <div class="contact-card">
              <div class="contact-name">${contact.name || 'Unknown'}</div>
              <div class="contact-last-message">${contact.lastMessage || 'No messages'}</div>
              <div class="contact-timestamp">${contact.timestamp || ''}</div>
            </div>
          `).join('');
          empty.style.display = 'none';
        } else {
          list.style.display = 'none';
          empty.style.display = 'block';
        }
      })
      .catch(err => {
        console.error('Error loading contacts:', err);
        document.getElementById('emptyState').style.display = 'block';
        document.getElementById('contactsList').style.display = 'none';
      });
  </script>
  <script src="/js/floating-companions.js" defer></script>
</body>
</html>
