  <script>
    // =========================================================
    // Push Notification Settings
    // =========================================================
    (function () {
      var panel        = document.getElementById('pushSettingsPanel');
      var overlay      = document.getElementById('pushSettingsOverlay');
      var closeBtn     = document.getElementById('pushSettingsBtn');
      var settingsClose = document.getElementById('pushSettingsClose');
      var permStatusEl  = document.getElementById('pushPermStatus');
      var toggleBlock  = document.getElementById('pushToggleBlock');
      var timeBlock    = document.getElementById('pushTimeBlock');
      var quietNote    = document.getElementById('pushQuietNote');
      var unsubBlock   = document.getElementById('pushUnsubscribeBlock');
      var toggle        = document.getElementById('pushEnabledToggle');
      var trackEl       = document.getElementById('pushToggleTrack');
      var thumbEl       = document.getElementById('pushToggleThumb');
      var toggleMsg     = document.getElementById('pushToggleMsg');
      var timeBtns      = document.querySelectorAll('.push-time-btn');
      var unsubBtn      = document.getElementById('pushUnsubscribeBtn');

      // Open the panel
      function openPanel() {
        panel.style.display = 'block';
        overlay.style.display = 'block';
        document.body.style.overflow = 'hidden';
        loadPreferences();
      }

      function closePanel() {
        panel.style.display = 'none';
        overlay.style.display = 'none';
        document.body.style.overflow = '';
      }

      if (closeBtn)     closeBtn.addEventListener('click', openPanel);
      if (settingsClose) settingsClose.addEventListener('click', closePanel);
      if (overlay)      overlay.addEventListener('click', closePanel);

      // Show/hide toggle visual
      function updateToggleVisual(enabled) {
        if (enabled) {
          trackEl.style.background = '#C97B5D';
          thumbEl.style.transform = 'translateX(20px)';
        } else {
          trackEl.style.background = '#E5DED4';
          thumbEl.style.transform = 'translateX(0)';
        }
      }

      // Highlight active time button
      function highlightTimeBtn(time) {
        timeBtns.forEach(function (btn) {
          if (btn.dataset.time === time) {
            btn.style.background = '#C97B5D';
            btn.style.color = '#fff';
            btn.style.borderColor = '#C97B5D';
          } else {
            btn.style.background = '#fff';
            btn.style.color = '#2A2522';
            btn.style.borderColor = '#E5DED4';
          }
        });
      }

      // Load preferences and permission state
      var currentEnabled = false;
      var currentTime    = '9am';

      function loadPreferences() {
        // First check push permission
        if (!('Notification' in window) || !('serviceWorker' in navigator)) {
          permStatusEl.innerHTML = '<p style="font-size:0.85rem;color:#8A7F79;margin:0;">Push notifications aren\u2019t supported in this browser.</p>';
          toggleBlock.style.display = 'none';
          timeBlock.style.display    = 'none';
          return;
        }

        var perm = Notification.permission; // 'granted' | 'denied' | 'default'

        if (perm === 'denied') {
          permStatusEl.innerHTML = '<p style="font-size:0.85rem;color:#C97B5D;margin:0;">Notifications are blocked. Enable them in your browser settings to receive reminders.</p>';
          toggleBlock.style.display = 'none';
          timeBlock.style.display    = 'none';
          return;
        }

        if (perm === 'default') {
          permStatusEl.innerHTML = '<p style="font-size:0.85rem;color:#8A7F79;margin:0 0 0.75rem;">Get a daily nudge to check in. One tap to dismiss — no urgency.</p>' +
            '<button id="pushRequestPermBtn" style="width:100%;padding:0.6rem;background:#C97B5D;color:#fff;border:none;border-radius:6px;font-family:inherit;font-size:0.875rem;font-weight:600;cursor:pointer;">Enable notifications</button>';
          toggleBlock.style.display = 'none';
          timeBlock.style.display    = 'none';
          unsubBlock.style.display  = 'none';
          var reqBtn = document.getElementById('pushRequestPermBtn');
          if (reqBtn) reqBtn.addEventListener('click', requestPermission);
          return;
        }

        // perm === 'granted' — show the full settings UI
        permStatusEl.innerHTML = '<p style="font-size:0.8rem;color:#5A8F6A;margin:0;">Notifications enabled.</p>';
        toggleBlock.style.display = 'block';
        quietNote.style.display   = 'block';

        // Fetch server preferences
        fetch('/api/push/preferences', { credentials: 'include' })
          .then(function (r) { return r.json(); })
          .then(function (prefs) {
            currentEnabled = !!prefs.enabled;
            currentTime    = prefs.reminder_time || '9am';
            updateToggleVisual(currentEnabled);
            toggle.checked = currentEnabled;
            highlightTimeBtn(currentTime);
            toggleMsg.textContent = currentEnabled ? 'You\u2019ll get a reminder at ' + currentTime + '.' : 'Reminders are off.';
            if (currentEnabled) {
              timeBlock.style.display = 'block';
              unsubBlock.style.display = 'block';
            }
          })
          .catch(function () {});
      }

      async function requestPermission() {
        var btn = document.getElementById('pushRequestPermBtn');
        if (btn) { btn.disabled = true; btn.textContent = 'Asking...'; }

        var reg = await navigator.serviceWorker.ready;
        var permission = await Notification.requestPermission();
        if (permission === 'granted') {
          // Subscribe to push
          var keyResp = await fetch('/api/push/vapid-key', { credentials: 'include' });
          if (!keyResp.ok) { alert('Push not configured on this site.'); return; }
          var keyData = await keyResp.json();
          var sub = await reg.pushManager.subscribe({
            userVisibleOnly: true,
            applicationServerKey: urlBase64ToUint8Array(keyData.key),
          });
          await fetch('/api/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ subscription: sub.toJSON() }),
          });
          // Reload panel
          openPanel();
        } else {
          if (btn) { btn.disabled = false; btn.textContent = 'Enable notifications'; }
        }
      }

      // Decode VAPID key
      function urlBase64ToUint8Array(base64String) {
        var padding = '='.repeat((4 - base64String.length % 4) % 4);
        var base64  = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
        var rawData = window.atob(base64);
        var outputArray = new Uint8Array(rawData.length);
        for (var i = 0; i < rawData.length; ++i) {
          outputArray[i] = rawData.charCodeAt(i);
        }
        return outputArray;
      }

      // Toggle change handler
      toggle.addEventListener('change', async function () {
        var enabled = toggle.checked;
        updateToggleVisual(enabled);

        if (enabled) {
          toggleMsg.textContent = 'Enabling...';
          try {
            var resp = await fetch('/api/push/preferences', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ enabled: true }),
            });
            var data = await resp.json();
            if (resp.ok) {
              currentEnabled = true;
              toggleMsg.textContent = 'You\u2019ll get a reminder at ' + currentTime + '.';
              timeBlock.style.display = 'block';
              unsubBlock.style.display = 'block';
            } else {
              toggle.checked = false;
              updateToggleVisual(false);
              toggleMsg.textContent = data.error || 'Could not enable.';
            }
          } catch (err) {
            toggle.checked = false;
            updateToggleVisual(false);
            toggleMsg.textContent = 'Network error. Try again.';
          }
        } else {
          toggleMsg.textContent = 'Reminders are off.';
          timeBlock.style.display    = 'none';
          unsubBlock.style.display  = 'none';
          try {
            await fetch('/api/push/preferences', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ enabled: false }),
            });
            currentEnabled = false;
          } catch (_) {}
        }
      });

      // Time button clicks
      timeBtns.forEach(function (btn) {
        btn.addEventListener('click', async function () {
          var time = btn.dataset.time;
          highlightTimeBtn(time);
          currentTime = time;
          toggleMsg.textContent = 'You\u2019ll get a reminder at ' + time + '.';
          try {
            await fetch('/api/push/preferences', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              credentials: 'include',
              body: JSON.stringify({ reminder_time: time }),
            });
          } catch (_) {}
        });
      });

      // Unsubscribe
      if (unsubBtn) {
        unsubBtn.addEventListener('click', async function () {
          if (!confirm('Turn off all reminders? You can re-enable anytime.')) return;
          try {
            await fetch('/api/push/unsubscribe', {
              method: 'DELETE',
              credentials: 'include',
            });
            currentEnabled = false;
            currentTime    = '9am';
            updateToggleVisual(false);
            toggle.checked = false;
            toggleBlock.style.display = 'none';
            timeBlock.style.display    = 'none';
            unsubBlock.style.display  = 'none';
            permStatusEl.innerHTML = '<p style="font-size:0.8rem;color:#8A7F79;margin:0;">Reminders off. <button onclick="location.reload()" style="background:none;border:none;color:#C97B5D;cursor:pointer;font-family:inherit;font-size:inherit;">Re-enable</button></p>';
          } catch (err) {
            alert('Could not turn off reminders. Try again.');
          }
        });
      }
    })();

    // =========================================================
    // Focus textarea on ?focus=1 (notification tap deep-link)
    // =========================================================
    (function () {
      var params = new URLSearchParams(window.location.search);
      if (params.get('focus') === '1') {
        var msgInput = document.getElementById('messageInput');
        if (msgInput) {
          msgInput.focus();
          // Clean the URL without reloading
          history.replaceState({}, '', '/filter');
        }
      }
    })();
  </script>

  <!-- Exit-intent modal — fires when free user has 4+ verdicts and shows exit intent -->
  <div id="exitIntentOverlay" style="display:none;position:fixed;inset:0;z-index:400;background:rgba(14,12,11,0.72);" aria-hidden="true"></div>
  <div id="exitIntentModal" role="dialog" aria-modal="true" aria-labelledby="exitIntentTitle"
    style="display:none;position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);z-index:401;
           background:#1A1410;border:1px solid #3A2E28;border-radius:12px;padding:2rem 1.75rem;
           max-width:380px;width:92%;box-shadow:0 12px 48px rgba(0,0,0,0.5);">
    <button id="exitIntentClose" aria-label="Dismiss"
      style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:none;
             font-size:1.1rem;cursor:pointer;color:#6A5F59;line-height:1;">✕</button>

    <h2 id="exitIntentTitle"
      style="font-family:'Fraunces',Georgia,serif;font-size:1.35rem;font-weight:600;
             color:#FAF6F0;margin:0 0 0.5rem;letter-spacing:-0.02em;line-height:1.2;">
      Out of verdicts. Not out of moments.
    </h2>
    <p style="font-size:0.875rem;color:#9A8F8A;margin:0 0 1.25rem;line-height:1.5;">
      Get the 5-day text detox. Free. We'll send the first one tonight.
    </p>

    <div id="exitIntentForm">
      <input type="email" id="exitIntentEmail" autocomplete="email"
        placeholder="your@email.com"
        style="width:100%;padding:0.65rem 0.75rem;border:1px solid #3A2E28;border-radius:6px;
               background:#0E0C0B;color:#FAF6F0;font-family:inherit;font-size:0.95rem;
               box-sizing:border-box;margin-bottom:0.65rem;outline:none;" />
      <button id="exitIntentSubmit"
        style="width:100%;padding:0.7rem;background:#C97B5D;color:#fff;border:none;
               border-radius:6px;font-family:inherit;font-size:0.95rem;font-weight:600;
               cursor:pointer;letter-spacing:0.01em;">
        Send it.
      </button>
      <p id="exitIntentError" style="display:none;font-size:0.8rem;color:#C97B5D;margin-top:0.4rem;"></p>
    </div>
    <div id="exitIntentDone" style="display:none;text-align:center;padding:0.5rem 0;">
      <p style="font-size:0.9rem;color:#9A8F8A;margin:0;">Check your inbox. Day 1 is on its way.</p>
    </div>
  </div>

  <script>
    // =========================================================
    // Exit-intent modal — fires once per 7 days for free users
    // with 4+ verdicts who show exit intent.
    // Suppressed for: paid users, already-on-detox-list, anonymous (0 verdicts).
    // =========================================================
    (function () {
      var EI_KEY = 'hf_ei_shown'; // localStorage key — stores last shown timestamp
      var EI_COOLDOWN_MS = 7 * 24 * 60 * 60 * 1000; // 7 days
      var VERDICT_THRESHOLD = 4; // must have used 4+ verdicts

      var modal   = document.getElementById('exitIntentModal');
      var overlay = document.getElementById('exitIntentOverlay');
      var closeBtn = document.getElementById('exitIntentClose');
      var emailEl = document.getElementById('exitIntentEmail');
      var submitBtn = document.getElementById('exitIntentSubmit');
      var formEl  = document.getElementById('exitIntentForm');
      var doneEl  = document.getElementById('exitIntentDone');
      var errEl   = document.getElementById('exitIntentError');

      var _shown = false;
      var _submitted = false;

      // ---------- Suppression checks ----------

      // pro_token cookie: base64url-encoded JSON { email, membership }. Present for active Pro subscribers.
      function isPaidUser() {
        try {
          var cookies = document.cookie.split('; ');
          var match = cookies.find(function(c) { return c.startsWith('pro_token='); });
          if (!match) return false;
          var token = match.split('=')[1];
          var payload = JSON.parse(atob(token));
          return !!(payload && payload.email);
        } catch (e) { return false; }
      }

      // hf_vc cookie: authoritative server-set verdict counter for the current device.
      function hasExceededVerdictThreshold() {
        try {
          var cookies = document.cookie.split('; ');
          var match = cookies.find(function(c) { return c.startsWith('hf_vc='); });
          if (!match) return false;
          var count = parseInt(match.split('=')[1], 10);
          return count >= VERDICT_THRESHOLD;
        } catch (e) { return false; }
      }

      function isOnCooldown() {
        try {
          var last = parseInt(localStorage.getItem(EI_KEY) || '0', 10);
          return Date.now() - last < EI_COOLDOWN_MS;
        } catch (e) { return false; }
      }

      // Logged-in users see the nav Sign up free button hidden (pro users + full subscribers).
      // Anonymous users see it visible.
      function isLoggedIn() {
        var navSignupBtn = document.getElementById('openSignupBtn');
        return !navSignupBtn;
      }

      function shouldShow() {
        if (_shown || _submitted) return false;
        if (isPaidUser()) return false;
        if (isLoggedIn()) return false;
        if (!hasExceededVerdictThreshold()) return false;
        if (isOnCooldown()) return false;
        return true;
      }

      // ---------- Show / hide ----------
      function showModal() {
        if (!shouldShow()) return;
        _shown = true;
        try { localStorage.setItem(EI_KEY, String(Date.now())); } catch (e) {}
        modal.style.display = 'block';
        overlay.style.display = 'block';
        document.body.style.overflow = 'hidden';
        // Log modal_shown event
        var deviceId = getDeviceId();
        fetch('/api/detox/exit-intent-event', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ event_type: 'modal_shown', device_id: deviceId }),
        }).catch(function () {});
      }

      function hideModal(dismissed) {
        modal.style.display = 'none';
        overlay.style.display = 'none';
        document.body.style.overflow = '';
        if (dismissed && !_submitted) {
          var deviceId = getDeviceId();
          fetch('/api/detox/exit-intent-event', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ event_type: 'modal_dismissed', device_id: deviceId }),
          }).catch(function () {});
        }
      }

      // ---------- Device ID ----------
      function getDeviceId() {
        try {
          var id = localStorage.getItem('hf_device_id');
          if (!id) {
            id = Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2);
            localStorage.setItem('hf_device_id', id);
          }
          return id;
        } catch (e) { return null; }
      }

      // ---------- Submit ----------
      submitBtn.addEventListener('click', async function () {
        var email = (emailEl.value || '').trim();
        if (!email || !email.includes('@')) {
          errEl.textContent = 'Enter a valid email.';
          errEl.style.display = 'block';
          return;
        }
        errEl.style.display = 'none';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
        try {
          var resp = await fetch('/api/detox/exit-intent-signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, device_id: getDeviceId() }),
          });
          var data = await resp.json();
          if (resp.ok && (data.ok || data.already)) {
            _submitted = true;
            formEl.style.display = 'none';
            doneEl.style.display = 'block';
            if (typeof fbq !== 'undefined') fbq('track', 'Lead', { content_name: 'exit_intent_detox' });
            setTimeout(function () { hideModal(false); }, 2800);
          } else {
            errEl.textContent = (data && data.error) || 'Something went wrong. Try again.';
            errEl.style.display = 'block';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Send it.';
          }
        } catch (err) {
          errEl.textContent = 'Network error. Try again.';
          errEl.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send it.';
        }
      });

      // Also submit on Enter in the email field
      emailEl.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { e.preventDefault(); submitBtn.click(); }
      });

      // ---------- Dismiss ----------
      closeBtn.addEventListener('click', function () { hideModal(true); });
      overlay.addEventListener('click', function () { hideModal(true); });

      // ---------- Exit-intent triggers ----------

      // Desktop: mouse moves toward top of page (tab-bar area)
      document.addEventListener('mouseleave', function (e) {
        if (e.clientY <= 20) showModal();
      });

      // Mobile: scroll up quickly + idle (user going back to top to leave)
      var lastScrollY = window.scrollY;
      var scrollUpVelocity = 0;
      var mobileIdleTimer = null;

      window.addEventListener('scroll', function () {
        var currentY = window.scrollY;
        var delta = lastScrollY - currentY; // positive = scrolling up
        lastScrollY = currentY;

        if (delta > 30) {
          // Fast scroll up — candidate for exit intent on mobile
          scrollUpVelocity += delta;
          clearTimeout(mobileIdleTimer);
          mobileIdleTimer = setTimeout(function () {
            if (scrollUpVelocity > 80) showModal();
            scrollUpVelocity = 0;
          }, 400);
        } else {
          scrollUpVelocity = Math.max(0, scrollUpVelocity - 10);
        }
      }, { passive: true });

      // Note: beforeunload removed — it fires on all navigation away (internal links,
      // refresh, tab switches), causing false triggers. _shown guard in shouldShow()
      // and the mouseleave + mobile-scroll triggers handle the real exit-intent cases.

      // Also expose for programmatic trigger from paywall screen
      window.__hf_showExitIntent = showModal;
    })();
  </script>

  <!-- Global error boundary — prevents blank screen on uncaught JS error -->
  <script>
    (function () {
      var fallbackDiv = document.createElement('div');
      fallbackDiv.style.cssText = 'position:fixed;inset:0;background:#FAF6F0;color:#2A2522;display:none;flex-direction:column;align-items:center;justify-content:center;z-index:99999;font-family:sans-serif;text-align:center;padding:2rem;';
      fallbackDiv.innerHTML = '<div style="font-size:2rem;margin-bottom:0.5rem;">⚠</div><div style="font-size:1.2rem;font-weight:600;margin-bottom:0.5rem;">HoldOff</div><div style="font-size:0.9rem;color:#6B5E55;">Something went wrong. <a href="/filter" style="color:#C97B5D;">Refresh</a> to try again.</div>';
      document.body.appendChild(fallbackDiv);
      window.addEventListener('error', function (e) {
        var src = e.filename || '';
        if (src.includes('fbevents') || src.includes('connect.facebook.net') ||
            src.includes('resend') || src.includes('analytics') || ) return;
        fallbackDiv.style.display = 'flex';
      });
      window.addEventListener('unhandledrejection', function () {
        fallbackDiv.style.display = 'flex';
      });
    })();
  </script>
</body>
</html>
