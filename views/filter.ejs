  <!-- Auth Modals -->
  <div id="authModal" style="display:none;position:fixed;inset:0;z-index:200;align-items:center;justify-content:center;background:rgba(14,12,11,0.6);">
    <div style="background:#FAF6F0;border-radius:12px;padding:2rem;max-width:400px;width:90%;position:relative;">
      <button id="authModalClose" style="position:absolute;top:0.75rem;right:0.75rem;background:none;border:none;font-size:1.25rem;cursor:pointer;color:#8A7F79;">✕</button>
      <h2 id="authModalTitle" style="font-family:'Fraunces',Georgia,serif;font-size:1.5rem;margin-bottom:1.5rem;color:#2A2522;"></h2>
      <form id="authForm" novalidate>
        <div id="authFormFields"></div>
        <div id="authFormError" style="color:#C97B5D;font-size:0.875rem;margin-top:0.5rem;display:none;"></div>
        <button type="submit" id="authSubmitBtn" style="width:100%;margin-top:1rem;padding:0.75rem;background:#C97B5D;color:#fff;border:none;border-radius:6px;font-weight:600;cursor:pointer;font-family:inherit;font-size:1rem;"></button>
      </form>
      <p id="authTogglePrompt" style="text-align:center;margin-top:1rem;font-size:0.875rem;color:#8A7F79;"></p>
    </div>
  </div>

  <script>
    // =========================================================
    // Current user membership type (null = not logged in / free user)
    // =========================================================
    var _holdoffUserTier = '<%= userTier %>';
    var _holdoffIsPro = _holdoffUserTier === 'online' || _holdoffUserTier === 'app' || _holdoffUserTier === 'lifetime';
    // Expose email so other IIFEs can detect login state without re-parsing cookies
    window.__hf_user_email = '<%= user ? user.email : "" %>';

    // Restore draft text after returning from quiz redirect
    (function () {
      var draft = sessionStorage.getItem('holdoff_draft');
      var msgInput = document.getElementById('messageInput') || document.getElementById('msgInput');
      if (draft && msgInput && !msgInput.value) {
        msgInput.value = draft;
        var charCount = document.getElementById('charCount');
        if (charCount) charCount.textContent = draft.length;
      }
      // Also restore emergency backup as fallback
      var emergency = sessionStorage.getItem('holdoff_emergency_backup');
      if (emergency && msgInput && !msgInput.value) {
        msgInput.value = emergency;
      }
    })();

    // =========================================================
    // Auth modal — sign-up / log in / log out
    // =========================================================
    (function () {
      var modal = document.getElementById('authModal');
      var modalTitle = document.getElementById('authModalTitle');
      var formFields = document.getElementById('authFormFields');
      var formError = document.getElementById('authFormError');
      var submitBtn = document.getElementById('authSubmitBtn');
      var togglePrompt = document.getElementById('authTogglePrompt');
      var authForm = document.getElementById('authForm');

      var currentMode = 'login'; // 'login' or 'signup'

      function openModal(mode) {
        currentMode = mode;
        formError.style.display = 'none';
        formError.textContent = '';
        if (mode === 'login') {
          modalTitle.textContent = 'Log in to HoldOff';
          formFields.innerHTML =
            '<div style="margin-bottom:0.75rem;">' +
              '<label style="display:block;font-size:0.8rem;color:#8A7F79;margin-bottom:0.25rem;">Email</label>' +
              '<input type="email" id="authEmail" required autocomplete="email" style="width:100%;padding:0.6rem;border:1px solid #E5DED4;border-radius:6px;font-family:inherit;font-size:1rem;box-sizing:border-box;">' +
            '</div>' +
            '<div style="margin-bottom:0.75rem;">' +
              '<label style="display:block;font-size:0.8rem;color:#8A7F79;margin-bottom:0.25rem;">Password</label>' +
              '<input type="password" id="authPassword" required autocomplete="current-password" style="width:100%;padding:0.6rem;border:1px solid #E5DED4;border-radius:6px;font-family:inherit;font-size:1rem;box-sizing:border-box;">' +
            '</div>' +
            '<div style="margin-bottom:0.5rem;">' +
              '<label style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;color:#8A7F79;cursor:pointer;">' +
                '<input type="checkbox" id="authRemember" style="cursor:pointer;">' +
                'Remember me for 90 days' +
              '</label>' +
            '</div>';
          submitBtn.textContent = 'Log in';
          togglePrompt.innerHTML = 'No account? <a href="#" id="authSwitchSignup" style="color:#C97B5D;font-weight:600;">Sign up free</a>';
        } else {
          modalTitle.textContent = 'Create your account';
          formFields.innerHTML =
            '<div style="margin-bottom:0.75rem;">' +
              '<label style="display:block;font-size:0.8rem;color:#8A7F79;margin-bottom:0.25rem;">Your name (optional)</label>' +
              '<input type="text" id="authName" autocomplete="name" style="width:100%;padding:0.6rem;border:1px solid #E5DED4;border-radius:6px;font-family:inherit;font-size:1rem;box-sizing:border-box;">' +
            '</div>' +
            '<div style="margin-bottom:0.75rem;">' +
              '<label style="display:block;font-size:0.8rem;color:#8A7F79;margin-bottom:0.25rem;">Email</label>' +
              '<input type="email" id="authEmail" required autocomplete="email" style="width:100%;padding:0.6rem;border:1px solid #E5DED4;border-radius:6px;font-family:inherit;font-size:1rem;box-sizing:border-box;">' +
            '</div>' +
            '<div style="margin-bottom:0.5rem;">' +
              '<label style="display:block;font-size:0.8rem;color:#8A7F79;margin-bottom:0.25rem;">Password (min 8 characters)</label>' +
              '<input type="password" id="authPassword" required minlength="8" autocomplete="new-password" style="width:100%;padding:0.6rem;border:1px solid #E5DED4;border-radius:6px;font-family:inherit;font-size:1rem;box-sizing:border-box;">' +
            '</div>';
          submitBtn.textContent = 'Create account';
          togglePrompt.innerHTML = 'Have an account? <a href="#" id="authSwitchLogin" style="color:#C97B5D;font-weight:600;">Log in</a>';
        }
        modal.style.display = 'flex';
      }

      function closeModal() {
        modal.style.display = 'none';
        formFields.innerHTML = '';
        formError.style.display = 'none';
      }

      function showError(msg) {
        formError.textContent = msg;
        formError.style.display = 'block';
      }

      document.getElementById('authModalClose').addEventListener('click', closeModal);
      modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

      // Open triggers in nav
      var openSignupBtn = document.getElementById('openSignupBtn');
      var openLoginBtn = document.getElementById('openLoginBtn');
      if (openSignupBtn) openSignupBtn.addEventListener('click', function (e) { e.preventDefault(); openModal('signup'); });
      if (openLoginBtn) openLoginBtn.addEventListener('click', function (e) { e.preventDefault(); openModal('login'); });

      // Toggle between modes
      document.addEventListener('click', function (e) {
        if (e.target.id === 'authSwitchSignup') { e.preventDefault(); openModal('signup'); }
        if (e.target.id === 'authSwitchLogin')   { e.preventDefault(); openModal('login'); }
      });

      // Submit handler
      authForm.addEventListener('submit', async function (e) {
        e.preventDefault();
        var email = document.getElementById('authEmail').value.trim();
        var password = document.getElementById('authPassword').value;
        var remember = document.getElementById('authRemember') && document.getElementById('authRemember').checked;
        var name = document.getElementById('authName') ? document.getElementById('authName').value.trim() : '';

        if (!email || !email.includes('@')) { showError('Enter a valid email.'); return; }
        if (!password) { showError('Enter your password.'); return; }
        if (currentMode === 'signup' && password.length < 8) { showError('Password must be at least 8 characters.'); return; }

        submitBtn.disabled = true;
        submitBtn.textContent = currentMode === 'signup' ? 'Creating account...' : 'Logging in...';

        var endpoint = currentMode === 'signup' ? '/api/auth/signup' : '/api/auth/login';
        var body = { email, password };
        if (currentMode === 'signup') body.name = name;
        if (currentMode === 'login') body.remember = remember;

        try {
          var resp = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          var data = await resp.json();

          if (!resp.ok) {
            showError(data.error || 'Something went wrong.');
            submitBtn.disabled = false;
            submitBtn.textContent = currentMode === 'signup' ? 'Create account' : 'Log in';
            return;
          }

          // Success — reload to pick up new JWT cookie and show logged-in state
          closeModal();
          window.location.reload();
        } catch (err) {
          showError('Something went wrong. Check your connection.');
          submitBtn.disabled = false;
          submitBtn.textContent = currentMode === 'signup' ? 'Create account' : 'Log in';
        }
      });

      // Logout
      var logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async function () {
          try {
            await fetch('/api/auth/logout', { method: 'POST' });
          } catch (_) {}
          window.location.reload();
        });
      }

      // Open modal on ?signup=1 query param (from landing page CTA)
      var params = new URLSearchParams(window.location.search);
      if (params.get('signup') === '1') openModal('signup');

      // Show email verification success banner if present
      if (params.get('verify_success') === '1') {
        var banner = document.createElement('div');
        banner.style.cssText = 'background:#D4EDDA;color:#155724;padding:0.75rem 1.5rem;text-align:center;font-size:0.9rem;';
        banner.textContent = 'Email confirmed — you\u2019re all set.';
        document.querySelector('.filter-main').insertBefore(banner, document.querySelector('.filter-main').firstChild);
      }
      if (params.get('verify_error') === 'invalid') {
        var banner2 = document.createElement('div');
        banner2.style.cssText = 'background:#F8D7DA;color:#721C24;padding:0.75rem 1.5rem;text-align:center;font-size:0.9rem;';
        banner2.textContent = 'Verification link invalid or expired. Try logging in.';
      }

      // Open modal on paywall if anonymous
      if (params.get('paywall') === '1') {
        var isLoggedIn = document.getElementById('openSignupBtn') === null; // hide nav means logged in
      }
    })();
  </script>

