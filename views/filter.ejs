  <script>
    // =========================================================
    // Verdict history + streak — 100% localStorage, no backend
    // =========================================================
    (function () {
      var HISTORY_KEY = 'hf_history';
      var STREAK_KEY  = 'hf_streak';

      // -- Storage helpers --
      function loadHistory() {
        try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch(e) { return []; }
      }
      function saveHistory(arr) {
        try { localStorage.setItem(HISTORY_KEY, JSON.stringify(arr)); } catch(e) {}
      }
      function loadStreak() {
        return parseInt(localStorage.getItem(STREAK_KEY) || '0', 10) || 0;
      }
      function saveStreak(n) {
        try { localStorage.setItem(STREAK_KEY, String(n)); } catch(e) {}
      }

      // -- Streak subtitles --
      var subtitles = [
        "That\u2019s {n} fires you didn\u2019t start.",
        "Every one of those was the right call.",
        "{n} moments you chose yourself.",
        "Silence can be the loudest answer.",
        "You\u2019re better at this than you think.",
        "The spiral didn\u2019t win this time.",
        "{n} texts that didn\u2019t need sending.",
      ];
      function getSubtitle(n) {
        var s = subtitles[Math.min(n - 1, subtitles.length - 1)];
        return s.replace('{n}', n);
      }

      // -- Render streak on input screen --
      function renderStreak() {
        var n = loadStreak();
        var block = document.getElementById('streakBlock');
        var countEl = document.getElementById('streakCount');
        var subEl = document.getElementById('streakSubtitle');
        if (n > 0) {
          countEl.textContent = n;
          subEl.textContent = getSubtitle(n);
          block.classList.remove('filter-streak--hidden');
        } else {
          block.classList.add('filter-streak--hidden');
        }
      }

      // -- Relative time --
      function relativeTime(ts) {
        var diff = Date.now() - ts;
        var m = Math.floor(diff / 60000);
        var h = Math.floor(diff / 3600000);
        var d = Math.floor(diff / 86400000);
        if (m < 1)  return 'just now';
        if (m < 60) return m + 'm ago';
        if (h < 24) return h + 'h ago';
        if (d < 7)  return d + 'd ago';
        return new Date(ts).toLocaleDateString();
      }

      // -- Render history panel --
      function renderHistory() {
        var list = document.getElementById('historyList');
        var history = loadHistory();
        list.innerHTML = '';

        if (history.length === 0) {
          var empty = document.createElement('li');
          empty.className = 'filter-history-empty';
          empty.innerHTML = 'No verdicts yet.<br>The first one\u2019s the hardest.';
          list.appendChild(empty);
          return;
        }

        history.forEach(function (entry, i) {
          var li = document.createElement('li');
          li.className = 'filter-history-item';

          var vClass = 'filter-history-item__verdict--' + entry.verdict.toLowerCase();
          var preview = entry.message.length > 60
            ? entry.message.slice(0, 60) + '\u2026'
            : entry.message;

          li.innerHTML =
            '<div class="filter-history-item__header">' +
              '<span class="filter-history-item__verdict ' + vClass + '">' + entry.verdict + '</span>' +
              '<span class="filter-history-item__preview">' + escapeHtml(preview) + '</span>' +
              '<span class="filter-history-item__time">' + relativeTime(entry.ts) + '</span>' +
              '<span class="filter-history-item__chevron">&#9660;</span>' +
            '</div>' +
            '<div class="filter-history-item__body">' +
              '<div class="filter-history-item__message">\u201c' + escapeHtml(entry.message) + '\u201d</div>' +
              (entry.reframe
                ? '<div class="filter-history-item__reframe-label">The honest read</div>' +
                  '<div class="filter-history-item__reframe">' + escapeHtml(entry.reframe) + '</div>'
                : '') +
            '</div>';

          li.querySelector('.filter-history-item__header').addEventListener('click', function () {
            li.classList.toggle('filter-history-item--expanded');
          });

          list.appendChild(li);
        });
      }

      function escapeHtml(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      // -- Open / close panel --
      var overlay = document.getElementById('historyOverlay');
      var panel   = document.getElementById('historyPanel');

      function openHistory() {
        // Pro paywall: logged-in free users see upsell; anonymous users get auth modal
        if (_holdoffUserTier !== '' && !_holdoffIsPro) {
          overlay.classList.add('filter-history-overlay--open');
          panel.classList.add('filter-history-panel--open');
          document.body.style.overflow = 'hidden';
          showHistoryPaywall();
          return;
        }
        renderHistory();
        overlay.classList.add('filter-history-overlay--open');
        panel.classList.add('filter-history-panel--open');
        document.body.style.overflow = 'hidden';
      }

      function showHistoryPaywall() {
        var historyList = document.getElementById('historyList');
        var historyClearBtn = document.getElementById('historyClearBtn');
        if (historyClearBtn) historyClearBtn.style.display = 'none';
        if (historyList) {
          historyList.innerHTML =
            '<li style="padding:2rem 1.5rem;text-align:center;">' +
            '<p style="font-family:\'Fraunces\',serif;font-size:1.2rem;font-weight:700;margin-bottom:0.75rem;color:#2A2522;">Verdict history is a Pro feature.</p>' +
            '<p style="font-size:0.9rem;color:#8A7F79;margin-bottom:1.5rem;line-height:1.6;">Upgrade to unlock your full history, streak tracking, and all future Pro features.</p>' +
            '<a href="/upgrade" style="display:inline-block;background:#C97B5D;color:#fff;font-weight:600;padding:0.65rem 1.5rem;border-radius:6px;text-decoration:none;font-size:0.9rem;">Upgrade to Pro →</a>' +
            '</li>';
        }
      }
      function closeHistory() {
        overlay.classList.remove('filter-history-overlay--open');
        panel.classList.remove('filter-history-panel--open');
        document.body.style.overflow = '';
      }

      overlay.addEventListener('click', closeHistory);
      document.getElementById('historyCloseBtn').addEventListener('click', closeHistory);
      document.getElementById('navHistoryBtn').addEventListener('click', openHistory);
      document.getElementById('resultHistoryBtn').addEventListener('click', openHistory);

      // -- Clear with confirmation --
      document.getElementById('historyClearBtn').addEventListener('click', function () {
        if (!confirm('Clear all verdict history? This can\u2019t be undone.')) return;
        saveHistory([]);
        renderHistory();
        // Don't reset streak — that's opt-in only
      });

      // -- Hook into the existing renderResult to save history + update streak --
      // We monkey-patch after the page script runs by listening on a custom event.
      // The main script fires window.dispatchEvent(new CustomEvent('hf:verdict', { detail: data }))
      window.addEventListener('hf:verdict', function (e) {
        var data = e.detail;
        // Save to history
        var history = loadHistory();
        history.unshift({
          ts:      Date.now(),
          message: data.message || '',
          verdict: data.verdict || '',
          reframe: data.whats_happening || '',
          pattern: data.pattern || '',
        });
        // Keep last 100 entries
        if (history.length > 100) history = history.slice(0, 100);
        saveHistory(history);

        // Update streak on HOLD or DO NOT SEND
        var v = (data.verdict || '').toUpperCase();
        if (v === 'HOLD' || v === 'DO NOT SEND' || v === 'REWRITE') {
          // "Not sent" = HOLD or REWRITE (user was persuaded to wait or rewrite)
          // Task says WAIT or DO NOT SEND — HOLD maps to WAIT here
          var n = loadStreak() + 1;
          saveStreak(n);
          renderStreak();
          // Sync streak to Android widget
          if (typeof Android !== 'undefined' && typeof Android.updateStreak === 'function') {
            Android.updateStreak(n);
          }
        }
      });

      // -- Init streak on load --
      renderStreak();
    })();
  </script>

  <script>
    // =========================================================
    // Referral modal — send HoldOff link to a friend
    // =========================================================
    (function () {
      var referralModal = document.getElementById('referralModal');
      var referralCtaBanner = document.getElementById('referralCtaBanner');
      var referralCtaBtn = document.getElementById('referralCtaBtn');
      var referralModalClose = document.getElementById('referralModalClose');
      var referralSendBtn = document.getElementById('referralSendBtn');
      var referralMsg = document.getElementById('referralMsg');

      function openReferralModal() {
        referralModal.style.display = 'flex';
        document.getElementById('referralRecipientEmail').value = '';
        document.getElementById('referralNote').value = '';
        referralMsg.style.display = 'none';
        referralSendBtn.disabled = false;
        referralSendBtn.textContent = 'Send it \u2192';
        setTimeout(function () { document.getElementById('referralRecipientEmail').focus(); }, 100);
      }

      function closeReferralModal() {
        referralModal.style.display = 'none';
      }

      if (referralCtaBtn) referralCtaBtn.addEventListener('click', openReferralModal);
      if (referralModalClose) referralModalClose.addEventListener('click', closeReferralModal);
      referralModal.addEventListener('click', function (e) { if (e.target === referralModal) closeReferralModal(); });

      if (referralSendBtn) {
        referralSendBtn.addEventListener('click', async function () {
          var email = document.getElementById('referralRecipientEmail').value.trim();
          var note = document.getElementById('referralNote').value.trim();

          if (!email || !email.includes('@') || !email.includes('.')) {
            referralMsg.textContent = 'Enter a valid email address.';
            referralMsg.style.color = '#C97B5D';
            referralMsg.style.display = 'block';
            return;
          }

          referralSendBtn.disabled = true;
          referralSendBtn.textContent = 'Sending\u2026';
          referralMsg.style.display = 'none';

          var streakCount = parseInt(localStorage.getItem('hf_streak') || '0', 10) || 0;

          try {
            var resp = await fetch('/api/referral/send', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ recipientEmail: email, note: note || null, streakCount: streakCount }),
            });
            var data = await resp.json();

            if (resp.status === 429) {
              referralMsg.textContent = 'You\u2019ve sent 10 referrals today. Check back tomorrow.';
              referralMsg.style.color = '#8A7F79';
              referralMsg.style.display = 'block';
              referralSendBtn.disabled = false;
              referralSendBtn.textContent = 'Send it \u2192';
              return;
            }

            if (!resp.ok || !data.ok) {
              referralMsg.textContent = data.error || 'Something went wrong. Try again.';
              referralMsg.style.color = '#C97B5D';
              referralMsg.style.display = 'block';
              referralSendBtn.disabled = false;
              referralSendBtn.textContent = 'Send it \u2192';
              return;
            }

            // Success
            referralMsg.textContent = 'Sent. They\u2019ll get it in a few seconds.';
            referralMsg.style.color = '#5A8F6A';
            referralMsg.style.display = 'block';
            referralSendBtn.textContent = 'Sent \u2713';
            setTimeout(closeReferralModal, 2200);

          } catch (err) {
            referralMsg.textContent = 'Network error. Try again.';
            referralMsg.style.color = '#C97B5D';
            referralMsg.style.display = 'block';
            referralSendBtn.disabled = false;
            referralSendBtn.textContent = 'Send it \u2192';
          }
        });
      }

      // Show referral CTA when a HOLD or REWRITE verdict is rendered
      window.addEventListener('hf:verdict', function (e) {
        var v = (e.detail.verdict || '').toUpperCase();
        if (referralCtaBanner) {
          referralCtaBanner.style.display = (v === 'HOLD' || v === 'REWRITE') ? 'block' : 'none';
        }
      });

      // Hide referral banner when user goes back to input screen
      var tryAnotherBtn2 = document.getElementById('tryAnotherBtn');
      if (tryAnotherBtn2) {
        tryAnotherBtn2.addEventListener('click', function () {
          if (referralCtaBanner) referralCtaBanner.style.display = 'none';
        }, true); // capture so it fires before the existing listener
      }
    })();
  </script>

  <script>
    // Global error boundary — prevents blank screen on any uncaught JS error.
    // Shows a minimal fallback instead of silent white-out.
    (function () {
      var fallbackDiv = document.createElement('div');
      fallbackDiv.id = 'hf-error-boundary';
      fallbackDiv.style.cssText = 'position:fixed;inset:0;background:#0E0C0B;color:#F2EDE5;display:none;flex-direction:column;align-items:center;justify-content:center;z-index:99999;font-family:sans-serif;text-align:center;padding:2rem;';
      fallbackDiv.innerHTML = '<div style="font-size:2rem;margin-bottom:0.5rem;">⚠</div><div style="font-size:1rem;font-weight:600;margin-bottom:0.5rem;">HoldOff</div><div style="font-size:0.9rem;color:#9E948E;">Something went wrong. Please <a href="/filter" style="color:#C97B5D;">refresh the page</a>.</div>';
      document.body.appendChild(fallbackDiv);
      window.addEventListener('error', function (e) {
        // Catch only top-level errors — let expected console.warn/silent failures pass.
        // Errors from third-party scripts (Meta Pixel, Resend) are exempt.
        var src = e.filename || '';
        if (src.includes('fbevents') || src.includes('connect.facebook.net') ||
            src.includes('resend') || src.includes('analytics')) return;
        fallbackDiv.style.display = 'flex';
      });
      window.addEventListener('unhandledrejection', function (e) {
        fallbackDiv.style.display = 'flex';
      });
    })();

    // Service worker registration
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', function () {
        navigator.serviceWorker.register('/sw.js')
          .then(function (reg) {
            // Activate new SW immediately — don't wait for all tabs to close.
            // Users with the old SW would otherwise see stale cached pages indefinitely.
            reg.waiting && reg.waiting.postMessage({ type: 'skipWaiting' });
            window.__hf_sw_ready = true;
            window.dispatchEvent(new CustomEvent('hf:sw-ready'));
          })
          .catch(function (err) {
            console.warn('SW registration failed:', err);
          });
      });
    }

    // ── Android beforeinstallprompt — captured here (not in SW) so page can fire install UI ──
    window.addEventListener('beforeinstallprompt', function (evt) {
      evt.preventDefault();
      window.__hf_install_prompt = evt;
      window.dispatchEvent(new CustomEvent('hf:install-ready'));
    });

    // iOS install prompt logic
    (function () {
      const COOKIE_KEY = 'hf_install_dismissed';
      const sheet = document.getElementById('pwaInstallSheet');
      const closeBtn = document.getElementById('pwaInstallClose');

      function getCookie(name) {
        return document.cookie.split('; ').some(function (c) { return c.startsWith(name + '='); });
      }

      function setCookie(name, days) {
        const d = new Date();
        d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
        document.cookie = name + '=1; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
      }

      // Only show on iOS Safari and only when NOT already installed
      const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
      const isStandalone = window.matchMedia('(display-mode: standalone)').matches ||
                           window.navigator.standalone === true;

      if (isIOS && !isStandalone && !getCookie(COOKIE_KEY)) {
        // Delay 3s before showing — let the user engage first
        setTimeout(function () {
          sheet.style.display = 'flex';
          sheet.classList.add('pwa-install-sheet--visible');
        }, 3000);
      }

      closeBtn.addEventListener('click', function () {
        sheet.classList.remove('pwa-install-sheet--visible');
        setCookie(COOKIE_KEY, 30); // Don't show again for 30 days
        setTimeout(function () { sheet.style.display = 'none'; }, 300);
      });
    })();
  </script>

