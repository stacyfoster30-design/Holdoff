  <style>
    /* Detox page styles */
    .detox-page {
      max-width: 680px;
      margin: 0 auto;
      padding: 6rem 1.5rem 5rem;
    }

    /* Hero */
    .detox-hero__eyebrow {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .detox-hero__h1 {
      font-family: var(--font-display);
      font-size: clamp(2.2rem, 6vw, 3.5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.05;
      color: var(--fg);
      margin-bottom: 1.25rem;
    }
    .detox-hero__subhead {
      font-size: 1.1rem;
      color: var(--muted);
      line-height: 1.65;
      max-width: 520px;
      margin-bottom: 2.5rem;
    }

    /* Signup form */
    .detox-signup {
      margin-bottom: 3rem;
    }
    .detox-signup__form {
      display: flex;
      gap: 0.5rem;
      max-width: 480px;
    }
    .detox-signup__input {
      flex: 1;
      padding: 0.875rem 1rem;
      border: 2px solid var(--border);
      border-radius: 8px;
      background: #fff;
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 1rem;
      outline: none;
      transition: border-color 0.15s;
    }
    .detox-signup__input:focus { border-color: var(--accent); }
    .detox-signup__input::placeholder { color: var(--muted); }
    .detox-signup__btn {
      padding: 0.875rem 1.5rem;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s;
    }
    .detox-signup__btn:hover { background: var(--accent-deep); }
    .detox-signup__btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .detox-signup__confirm {
      margin-top: 1rem;
      font-size: 0.95rem;
      color: var(--fg);
      font-weight: 500;
    }
    .detox-signup__confirm em {
      color: var(--accent);
      font-style: italic;
    }
    .detox-signup__note {
      margin-top: 0.5rem;
      font-size: 0.8rem;
      color: var(--muted);
    }
    @media (max-width: 480px) {
      .detox-signup__form { flex-direction: column; }
    }

    /* Day cards */
    .detox-days {
      margin-bottom: 3.5rem;
    }
    .detox-days__heading {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.03em;
      margin-bottom: 1.5rem;
    }
    .detox-day {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1rem;
      background: #fff;
      position: relative;
    }
    .detox-day:last-child { margin-bottom: 0; }
    .detox-day__badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .detox-day__title {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 0.5rem;
      line-height: 1.2;
    }
    .detox-day__example {
      font-size: 0.875rem;
      font-style: italic;
      color: var(--muted);
      background: var(--surface);
      border-left: 3px solid var(--accent);
      padding: 0.5rem 0.75rem;
      border-radius: 0 6px 6px 0;
      margin-bottom: 0.75rem;
      line-height: 1.5;
    }
    .detox-day__body {
      font-size: 0.9rem;
      color: #4A3F3A;
      line-height: 1.65;
    }

    /* Verdict widget section */
    .detox-widget-section {
      margin: 3rem 0;
      padding: 2rem;
      background: var(--surface);
      border-radius: 16px;
    }
    .detox-widget-section__heading {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--fg);
      margin-bottom: 0.5rem;
    }
    .detox-widget-section__sub {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 1.25rem;
    }

    /* Internal links section */
    .detox-links {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .detox-links__heading {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1rem;
    }
    .detox-links__grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .detox-links__link {
      font-size: 0.875rem;
      color: var(--accent);
      text-decoration: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.4rem 0.75rem;
      transition: border-color 0.15s, background 0.15s;
    }
    .detox-links__link:hover {
      border-color: var(--accent);
      background: #fff7f3;
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="detox-page">

    <!-- Hero -->
    <p class="detox-hero__eyebrow">Free 5-day email course</p>
    <h1 class="detox-hero__h1">The 5-Day Anxious<br>Texting Detox.</h1>
    <p class="detox-hero__subhead">
      One pattern a day. Why you do it, what to do instead, and the grounded version
      of every text you almost send. Free, in your inbox.
    </p>

    <!-- Signup form -->
    <div class="detox-signup">
      <form class="detox-signup__form" id="detoxSignupForm">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          class="detox-signup__input"
          required
          autocomplete="email"
        />
        <button type="submit" class="detox-signup__btn" id="detoxSubmitBtn">
          Start the detox →
        </button>
      </form>
      <p class="detox-signup__confirm" id="detoxConfirm" hidden>
        Day 0 is on its way. <em>Check your inbox.</em>
      </p>
      <p class="detox-signup__note">5 emails, 5 days. No spam. Unsubscribe any time.</p>
    </div>

    <!-- Day cards -->
    <div class="detox-days">
      <p class="detox-days__heading">What's in the course</p>

      <div class="detox-day">
        <span class="detox-day__badge">Day 0</span>
        <h2 class="detox-day__title">The double text</h2>
        <p class="detox-day__example">"Hey just wanted to make sure you got this 😅"</p>
        <p class="detox-day__body">Why silence feels like threat. What protest behavior actually is. And why the second text almost always makes things worse.</p>
      </div>

      <div class="detox-day">
        <span class="detox-day__badge">Day 1</span>
        <h2 class="detox-day__title">The 11 PM spiral</h2>
        <p class="detox-day__example">"I know it's late but I just needed to say something…"</p>
        <p class="detox-day__body">Why your brain catastrophizes after dark. The science behind why nothing drafted after 10 PM should ever be sent before 9 AM.</p>
      </div>

      <div class="detox-day">
        <span class="detox-day__badge">Day 2</span>
        <h2 class="detox-day__title">The "are you mad at me?" probe</h2>
        <p class="detox-day__example">"You seem kind of distant. Did I do something?"</p>
        <p class="detox-day__body">The anxiety check disguised as concern. What you're actually asking — and why handing him your emotional state backfires every time.</p>
      </div>

      <div class="detox-day">
        <span class="detox-day__badge">Day 3</span>
        <h2 class="detox-day__title">The reassurance bid</h2>
        <p class="detox-day__example">"Do you actually want to hang out, or are you just being nice?"</p>
        <p class="detox-day__body">Why asking for proof makes you need more proof. Behavioral evidence vs. verbal reassurance — and why one of them actually works.</p>
      </div>

      <div class="detox-day">
        <span class="detox-day__badge">Day 4</span>
        <h2 class="detox-day__title">The apology loop</h2>
        <p class="detox-day__example">"I'm sorry for being weird. I know I'm probably overthinking this."</p>
        <p class="detox-day__body">The preemptive rejection. Why you apologize for yourself before anyone rejects you — and how to close the loop instead of reopening it.</p>
      </div>
    </div>

    <!-- Live verdict widget demo -->
    <div class="detox-widget-section">
      <h2 class="detox-widget-section__heading">Try it right now</h2>
      <p class="detox-widget-section__sub">Paste the text you're about to send. Get the verdict before you make it worse.</p>
      <%- include('partials/seo-verdict-widget') %>
    </div>

    <!-- Internal links -->
    <div class="detox-links">
      <p class="detox-links__heading">Go deeper</p>
      <div class="detox-links__grid">
        <a href="/filter" class="detox-links__link">Try HoldOff free →</a>
        <a href="/why-do-i-keep-double-texting" class="detox-links__link">Why do I keep double texting?</a>
        <a href="/anxious-attachment-texting-rules" class="detox-links__link">Anxious attachment texting rules</a>
        <a href="/11pm-text-anxious-attachment" class="detox-links__link">The 11 PM text</a>
        <a href="/why-am-i-obsessing-over-his-last-text" class="detox-links__link">Why am I obsessing over his last text?</a>
        <a href="/should-i-text-him-good-morning" class="detox-links__link">Should I text him good morning?</a>
      </div>
    </div>

  </main>

  <%- include('partials/footer') %>

  <!-- Analytics removed -->

  <script>
  (function () {
    var form = document.getElementById('detoxSignupForm');
    var confirmEl = document.getElementById('detoxConfirm');
    var submitBtn = document.getElementById('detoxSubmitBtn');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var email = form.querySelector('input[name="email"]').value.trim();
      if (!email) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      fetch('/api/detox/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      })
        .then(function (r) { return r.json(); })
        .then(function () {
          form.hidden = true;
          confirmEl.hidden = false;
          if (typeof fbq !== 'undefined') fbq('track', 'Lead', { content_name: 'detox_signup' });
        })
        .catch(function () {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Start the detox →';
          alert('Something went wrong. Please try again.');
        });
    });
  })();
  </script>
</body>
</html>
