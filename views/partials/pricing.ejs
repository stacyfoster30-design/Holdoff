<script>
  var _pricingSelectedTier = 'online';

  function pricingSelectTier(tier) {
    _pricingSelectedTier = tier;
    document.getElementById('pricingModalOverlay').style.display = 'flex';
    document.getElementById('pricingEmailInput').focus();
  }

  function closePricingModal() {
    document.getElementById('pricingModalOverlay').style.display = 'none';
  }

  async function submitPricingCheckout() {
    var email = document.getElementById('pricingEmailInput').value.trim();
    var err = document.getElementById('pricingEmailError');
    var btn = document.getElementById('pricingCheckoutBtn');
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      err.style.display = 'block';
      return;
    }
    err.style.display = 'none';
    btn.textContent = 'Loading...';
    btn.disabled = true;
    try {
      var resp = await fetch('/api/checkout/session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tier: _pricingSelectedTier, email: email })
      });
      var data = await resp.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        btn.textContent = 'Continue to checkout →';
        btn.disabled = false;
        alert(data.error || 'Something went wrong. Try again.');
      }
    } catch(e) {
      btn.textContent = 'Continue to checkout →';
      btn.disabled = false;
    }
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closePricingModal();
  });
</script>
