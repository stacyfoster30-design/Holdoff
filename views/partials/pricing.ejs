<script>
  var pricingBilling = 'monthly';
  var pricingPrices = {
    weekly:  { online: '$4.99<span>/wk</span>', app: '$7.49<span>/wk</span>', save: false },
    monthly: { online: '$9.99<span>/mo</span>', app: '$14.99<span>/mo</span>', save: false },
    annual:  { online: '$99<span>/yr</span>', app: '$149<span>/yr</span>', save: true },
  };
  window.setPricingBilling = function(billing) {
    pricingBilling = billing;
    var btns = ['pricingWeeklyBtn','pricingMonthlyBtn','pricingAnnualBtn'];
    btns.forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('pricing-toggle__btn--active');
    });
    var activeId = billing === 'weekly' ? 'pricingWeeklyBtn' : billing === 'annual' ? 'pricingAnnualBtn' : 'pricingMonthlyBtn';
    var activeEl = document.getElementById(activeId);
    if (activeEl) activeEl.classList.add('pricing-toggle__btn--active');

    var p = pricingPrices[billing] || pricingPrices.monthly;
    var onlinePrice = document.getElementById('pricingOnlinePrice');
    var appPrice = document.getElementById('pricingAppPrice');
    var onlineSavings = document.getElementById('pricingOnlineSavings');
    var appSavings = document.getElementById('pricingAppSavings');
    if (onlinePrice) onlinePrice.innerHTML = p.online;
    if (appPrice) appPrice.innerHTML = p.app;
    if (onlineSavings) onlineSavings.style.display = p.save ? 'block' : 'none';
    if (appSavings) appSavings.style.display = p.save ? 'block' : 'none';
  };
  window.pricingSelectTier = async function(tier) {
    var fullTier = tier === 'lifetime' ? 'lifetime' : tier + '_' + pricingBilling;
    var btn = event.target;
    btn.disabled = true;
    btn.textContent = 'Loading...';
    try {
      var checkoutEmail = (localStorage.getItem('holdoff_checkout_email') || '').trim();
      if (!checkoutEmail) checkoutEmail = (prompt('What email should HoldOff use to activate your subscription?') || '').trim();
      if (!checkoutEmail) throw new Error('Enter your email to continue to checkout.');
      localStorage.setItem('holdoff_checkout_email', checkoutEmail.toLowerCase());
      var resp = await fetch('/api/checkout/session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tier: fullTier, email: checkoutEmail }),
      });
      var data = await resp.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        btn.disabled = false;
        btn.textContent = tier === 'lifetime' ? 'Get Lifetime →' :
                         tier === 'app' ? 'Get App →' : 'Get Online';
        alert(data.error || 'Could not start checkout.');
      }
    } catch (err) {
      btn.disabled = false;
      btn.textContent = tier === 'lifetime' ? 'Get Lifetime →' :
                       tier === 'app' ? 'Get App →' : 'Get Online';
      alert('Could not start checkout. Try again.');
    }
  };
</script>