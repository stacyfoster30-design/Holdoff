<section style="background:linear-gradient(135deg,#ff6b35,#f7c59f);padding:32px 20px;text-align:center;margin-bottom:0;">
  <div style="max-width:560px;margin:0 auto;">
    <div style="font-size:0.85em;letter-spacing:2px;text-transform:uppercase;font-weight:700;color:#7a2d00;margin-bottom:8px;">🔥 Limited Beta Offer</div>
    <h2 style="font-size:2em;font-weight:800;color:#1a1a1a;margin:0 0 10px;">$3/month. Forever.</h2>
    <p style="color:#3d1a00;font-size:1.1em;margin-bottom:20px;">First 50 founding members lock in this price for life. <strong>48 spots left.</strong></p>
    <a href="https://app.base44.com/apps/6a2a90559f878225e8a7a50f"
       style="background:#1a1a1a;color:#fff;padding:16px 40px;border-radius:40px;font-weight:700;font-size:1.1em;text-decoration:none;display:inline-block;box-shadow:0 4px 16px rgba(0,0,0,0.2);">
      Open HoldOff App →
    </a>
    <div style="margin-top:12px;font-size:0.85em;color:#3d1a00;">CashApp &amp; all major cards accepted</div>
  </div>
</section>

<section class="pricing-section">
  <div class="pricing-section__inner">
    <p class="section-eyebrow">HoldOff plans</p>
    <h2 class="pricing-section__headline">Two tiers. One goal.</h2>
    <p class="pricing-section__sub">Cancel anytime. CashApp accepted.</p>

    <!-- Weekly/Monthly/Annual toggle -->
    <div class="pricing-toggle">
      <button class="pricing-toggle__btn" id="pricingWeeklyBtn" onclick="setPricingBilling('weekly')">Weekly</button>
      <button class="pricing-toggle__btn pricing-toggle__btn--active" id="pricingMonthlyBtn" onclick="setPricingBilling('monthly')">Monthly</button>
      <button class="pricing-toggle__btn" id="pricingAnnualBtn" onclick="setPricingBilling('annual')">Annual <span class="pricing-toggle__save">Save ~17%</span></button>
    </div>

    <div class="pricing-cards">
      <!-- Online tier -->
      <div class="pricing-card">
        <div class="pricing-card__name">HoldOff Online</div>
        <div class="pricing-card__price" id="pricingOnlinePrice">$9.99<span>/mo</span></div>
        <div class="pricing-card__savings" id="pricingOnlineSavings" style="display:none">Save ~17% vs monthly</div>
        <ul class="pricing-card__features">
          <li>Unlimited web verdicts</li>
          <li>All future web features</li>
          <li>Email support</li>
        </ul>
        <button class="pricing-card__btn" onclick="pricingSelectTier('online')">Get Online</button>
      </div>

      <!-- App tier -->
      <div class="pricing-card pricing-card--featured">
        <div class="pricing-card__badge">Most popular</div>
        <div class="pricing-card__name">HoldOff App</div>
        <div class="pricing-card__price" id="pricingAppPrice">$14.99<span>/mo</span></div>
        <div class="pricing-card__savings" id="pricingAppSavings" style="display:none">Save ~17% vs monthly</div>
        <ul class="pricing-card__features">
          <li>Everything in Online</li>
          <li>Android SMS auto-intercept</li>
          <li>App-exclusive features</li>
          <li>Priority support</li>
        </ul>
        <button class="pricing-card__btn pricing-card__btn--primary" onclick="pricingSelectTier('app')">Get App →</button>
      </div>
    </div>

    <!-- Lifetime option -->
    <div class="pricing-lifetime">
      <div class="pricing-lifetime__inner">
        <div class="pricing-lifetime__left">
          <div class="pricing-lifetime__name">HoldOff Lifetime</div>
          <div class="pricing-lifetime__price">$299 <span>once</span></div>
        </div>
        <ul class="pricing-lifetime__features">
          <li>Everything in App</li>
          <li>No recurring — ever</li>
          <li>Lifetime + all future features free</li>
        </ul>
        <button class="pricing-lifetime__btn" onclick="pricingSelectTier('lifetime')">Get Lifetime →</button>
      </div>
    </div>

    <p class="pricing-cashapp">CashApp accepted. Refunds automatic within 1–5 business days.</p>
  </div>
</section>

