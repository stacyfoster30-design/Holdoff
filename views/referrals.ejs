<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Your Referrals — HoldOff</title>
  <meta name="description" content="Share HoldOff with friends and unlock free verdicts, Pro trials, and Lifetime access.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/referrals.css">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
</head>
<body class="ref-body">

  <nav class="ref-nav">
    <a href="/" class="ref-nav__wordmark">HoldOff</a>
    <a href="/filter" class="ref-nav__back">← Back to filter</a>
  </nav>

  <main class="ref-main">

    <div class="ref-header">
      <h1 class="ref-title">Your Referrals</h1>
      <p class="ref-subtitle">Share HoldOff with people who need it. Earn rewards for every friend who signs up.</p>
    </div>

    <!-- Referral link card -->
    <div class="ref-link-card">
      <div class="ref-link-label">Your referral link</div>
      <div class="ref-link-row">
        <input class="ref-link-input" type="text" id="refLink" readonly value="" />
        <button class="ref-copy-btn" id="copyBtn" onclick="copyLink()">Copy</button>
      </div>
      <div class="ref-share-btns">
        <button class="ref-share-btn ref-share-btn--twitter" onclick="shareTwitter()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.258 5.629 5.906-5.629Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X (Twitter)
        </button>
        <button class="ref-share-btn ref-share-btn--sms" onclick="shareSMS()">SMS</button>
        <button class="ref-share-btn ref-share-btn--copy" onclick="copyLink()">Copy Link</button>
      </div>
    </div>

    <!-- Stats row -->
    <div class="ref-stats-row" id="statsRow">
      <div class="ref-stat">
        <div class="ref-stat__num" id="statConverted">—</div>
        <div class="ref-stat__label">Friends joined</div>
      </div>
      <div class="ref-stat">
        <div class="ref-stat__num" id="statCredits">—</div>
        <div class="ref-stat__label">Free verdicts earned</div>
      </div>
      <div class="ref-stat">
        <div class="ref-stat__num" id="statTrial">—</div>
        <div class="ref-stat__label">Trial days</div>
      </div>
    </div>

    <!-- Progress to next tier -->
    <div class="ref-progress-section" id="progressSection">
      <div class="ref-progress-header">
        <span id="progressLabel">Loading...</span>
        <span id="progressCount"></span>
      </div>
      <div class="ref-progress-bar">
        <div class="ref-progress-fill" id="progressFill" style="width:0%"></div>
      </div>
      <div class="ref-progress-reward" id="progressReward"></div>
    </div>

    <!-- Tier list -->
    <div class="ref-tiers" id="tierList">
      <div class="ref-tier ref-tier--locked" id="tier1">
        <div class="ref-tier__icon">1</div>
        <div class="ref-tier__body">
          <div class="ref-tier__name">1 Referral</div>
          <div class="ref-tier__reward">+1 free verdict</div>
        </div>
        <div class="ref-tier__status" id="tier1Status">🔒</div>
      </div>
      <div class="ref-tier ref-tier--locked" id="tier2">
        <div class="ref-tier__icon">5</div>
        <div class="ref-tier__body">
          <div class="ref-tier__name">5 Referrals</div>
          <div class="ref-tier__reward">+5 free verdicts</div>
        </div>
        <div class="ref-tier__status" id="tier2Status">🔒</div>
      </div>
      <div class="ref-tier ref-tier--locked" id="tier3">
        <div class="ref-tier__icon">10</div>
        <div class="ref-tier__body">
          <div class="ref-tier__name">10 Referrals</div>
          <div class="ref-tier__reward">+30 free verdicts or 1-week Pro trial</div>
        </div>
        <div class="ref-tier__status" id="tier3Status">🔒</div>
      </div>
      <div class="ref-tier ref-tier--locked" id="tier4">
        <div class="ref-tier__icon">25</div>
        <div class="ref-tier__body">
          <div class="ref-tier__name">25 Referrals</div>
          <div class="ref-tier__reward">Lifetime HoldOff Pro</div>
        </div>
        <div class="ref-tier__status" id="tier4Status">🔒</div>
      </div>
    </div>

    <!-- Reward history -->
    <div id="rewardHistorySection" style="display:none;">
      <div class="ref-history-header">Your unlocked rewards</div>
      <div id="rewardHistory"></div>
    </div>

    <!-- Unlocked reward banner -->
    <div class="ref-unlocked-banner" id="unlockedBanner" style="display:none;">
      <span id="unlockedMsg"></span>
    </div>

    <!-- How it works -->
    <div class="ref-how">
      <h2 class="ref-how__title">How it works</h2>
      <div class="ref-how__steps">
        <div class="ref-how__step">
          <div class="ref-how__num">1</div>
          <div>Copy your link and share it with a friend who's texted someone at midnight and regretted it.</div>
        </div>
        <div class="ref-how__step">
          <div class="ref-how__num">2</div>
          <div>They sign up for free. That's a converted referral.</div>
        </div>
        <div class="ref-how__step">
          <div class="ref-how__num">3</div>
          <div>You earn a reward. They get a better app experience. Everyone wins.</div>
        </div>
      </div>
    </div>

  </main>

  <script>
    async function loadDashboard() {
      try {
        const res = await fetch('/api/referral/dashboard');
        if (!res.ok) {
          window.location.href = '/filter';
          return;
        }
        const data = await res.json();

        // Set referral link
        document.getElementById('refLink').value = data.referralUrl;

        // Stats
        document.getElementById('statConverted').textContent = data.stats.totalConverted;
        document.getElementById('statCredits').textContent = data.stats.rewardCredits;
        document.getElementById('statTrial').textContent = data.stats.trialDaysGranted || '0';

        if (data.stats.lifetimeUnlocked) {
          document.getElementById('statTrial').textContent = '∞';
        }

        // Tiers
        data.tiers.forEach(t => {
          const el = document.getElementById(t.id + 'Status');
          if (el) el.textContent = t.unlocked ? '✓ Unlocked' : '🔒';
          const row = document.getElementById(t.id);
          if (row) {
            row.classList.remove('ref-tier--locked', 'ref-tier--unlocked', 'ref-tier--active');
            row.classList.add(t.unlocked ? 'ref-tier--unlocked' : 'ref-tier--locked');
          }
        });

        // Progress
        const next = data.nextTier;
        if (next) {
          const total = next.remaining + data.stats.totalConverted;
          const pct = Math.min(100, Math.round((data.stats.totalConverted / next.threshold) * 100));
          document.getElementById('progressLabel').textContent = next.label;
          document.getElementById('progressCount').textContent = `${data.stats.totalConverted} / ${next.threshold} friends`;
          document.getElementById('progressFill').style.width = pct + '%';
          document.getElementById('progressReward').textContent = next.rewardLabel;
          document.getElementById('progressSection').style.display = 'block';
        } else if (data.stats.lifetimeUnlocked) {
          document.getElementById('progressLabel').textContent = 'All rewards unlocked!';
          document.getElementById('progressCount').textContent = '';
          document.getElementById('progressFill').style.width = '100%';
          document.getElementById('progressReward').textContent = 'Lifetime HoldOff Pro';
          document.getElementById('progressSection').style.display = 'block';
        }

        // History
        if (data.history && data.history.length > 0) {
          const container = document.getElementById('rewardHistory');
          data.history.forEach(h => {
            const tierLabels = { tier1:'1 Referral', tier2:'5 Referrals', tier3:'10 Referrals', tier4:'25 Referrals' };
            let rewardText = '';
            if (h.rewardType === 'verdict_credits') rewardText = `+${h.rewardValue} free verdicts`;
            else if (h.rewardType === 'trial_days') rewardText = `+${h.rewardValue} trial days`;
            else if (h.rewardType === 'lifetime') rewardText = 'Lifetime Pro';
            const row = document.createElement('div');
            row.className = 'ref-history-row';
            row.innerHTML = `<span>${tierLabels[h.tier] || h.tier}</span><span class="ref-history-reward">${rewardText}</span>`;
            container.appendChild(row);
          });
          document.getElementById('rewardHistorySection').style.display = 'block';
        }

      } catch(e) {
        console.error('[referrals] load error:', e);
      }
    }

    function copyLink() {
      const input = document.getElementById('refLink');
      navigator.clipboard.writeText(input.value).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    }

    function shareTwitter() {
      const text = encodeURIComponent("I use HoldOff to stop texting things I regret. AI-powered message filter for anxious attachment. Get it free:");
      const url = encodeURIComponent(document.getElementById('refLink').value);
      window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`, '_blank', 'width=600,height=400');
    }

    function shareSMS() {
      const url = document.getElementById('refLink').value;
      const text = encodeURIComponent("Check out HoldOff — it stops you from texting things you'll regret at midnight. " + url);
      window.location.href = `sms:?body=${text}`;
    }

    loadDashboard();

    // Track detox_day5 referral click when source param is present
    (function trackSource() {
      const params = new URLSearchParams(window.location.search);
      if (params.get('source') === 'detox_day5') {
        fetch('/api/detox/referral-click', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ source: 'detox_day5' }) }).catch(() => {});
      }
    })();
  </script>

</body>
</html>