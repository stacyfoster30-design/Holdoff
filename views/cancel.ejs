<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>HoldOff — Purchase Cancelled</title>

  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="apple-mobile-web-app-title" content="HoldOff">
  <meta name="theme-color" content="#0E0C0B">
  <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png">
  <meta name="description" content="Purchase cancelled — your HoldOff filter is still available.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">

  <style>
    body {
      background: #0E0C0B;
      color: #FAF6F0;
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cancel-card {
      max-width: 480px;
      margin: 2rem;
      text-align: center;
    }
    .cancel-card__headline {
      font-family: 'Fraunces', serif;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      color: #FAF6F0;
      margin-bottom: 1rem;
      line-height: 1.15;
    }
    .cancel-card__sub {
      font-size: 1rem;
      color: rgba(250,246,240,0.55);
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }
    .cancel-card__cta {
      display: inline-block;
      background: var(--accent);
      color: #fff;
      font-size: 1rem;
      font-weight: 600;
      padding: 0.85rem 2rem;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.15s;
    }
    .cancel-card__cta:hover {
      background: var(--accent-deep);
    }
  </style>
</head>
<body>

  <div class="cancel-card">
    <h1 class="cancel-card__headline">Purchase cancelled.</h1>
    <p class="cancel-card__sub">No worries — your filter is still available at /filter whenever you're ready.</p>
    <a href="/filter" class="cancel-card__cta">Open HoldOff →</a>
  </div>

</body>
</html>
