<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>HoldOff — Community</title>
  <style>
    .community-post {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 18px; margin-bottom: 12px;
      transition: var(--transition);
    }
    .community-post:hover { border-color: var(--border-light); }
    .post-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .post-author { font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 8px; }
    .post-avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--accent), var(--primary)); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
    .post-content { color: var(--text); line-height: 1.6; font-size: 0.95rem; margin-bottom: 12px; }
    .post-actions { display: flex; gap: 16px; }
    .post-action { display: flex; align-items: center; gap: 4px; font-size: 0.8rem; color: var(--text-dim); cursor: pointer; transition: var(--transition); background: none; border: none; font-family: var(--font); }
    .post-action:hover { color: var(--primary); }
    .event-card { background: linear-gradient(135deg, rgba(232,121,168,0.1), rgba(124,92,191,0.1)); border: 1px solid rgba(232,121,168,0.3); border-radius: var(--radius); padding: 18px; margin-bottom: 20px; text-align: center; }
    .compose-post { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-bottom: 20px; }
    .post-textarea { width: 100%; min-height: 80px; background: transparent; border: none; color: var(--text); font-family: var(--font); font-size: 1rem; resize: none; line-height: 1.5; }
    .post-textarea:focus { outline: none; }
    .post-textarea::placeholder { color: var(--text-dim); }
  </style>
</head>
<body>
  <div class="app-container">
    <div class="screen-header">
      <h1>🫂 Community</h1>
      <span class="badge badge-rose">Anonymous</span>
    </div>

    <div class="screen-content">
      <!-- Event Banner -->
      <div class="event-card fade-in">
        <div style="font-size:1.5rem;margin-bottom:8px;">🎤</div>
        <h3 style="margin-bottom:4px;">Open Mic Night</h3>
        <p style="color:var(--text-muted);font-size:0.85rem;">Every Friday — Share your tangled thoughts</p>
      </div>

      <!-- Mood Filter -->
      <div class="mood-bar" style="margin-bottom:16px;">
        <button class="mood-pill active" onclick="filterPosts(this, 'all')">All</button>
        <button class="mood-pill" onclick="filterPosts(this, 'calm')">😌 Calm</button>
        <button class="mood-pill" onclick="filterPosts(this, 'anxious')">😰 Anxious</button>
        <button class="mood-pill" onclick="filterPosts(this, 'spiraling')">🌀 Spiraling</button>
        <button class="mood-pill" onclick="filterPosts(this, 'victory')">🏆 Victory</button>
      </div>

      <!-- Compose Post -->
      <div class="compose-post">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
          <div class="post-avatar">🫧</div>
          <span style="color:var(--text-muted);font-size:0.85rem;">Post anonymously</span>
        </div>
        <textarea class="post-textarea" id="post-text" placeholder="Share what you're going through..."></textarea>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;">
          <select class="form-select" style="width:auto;padding:6px 12px;font-size:0.85rem;" id="post-mood">
            <option value="calm">😌 Calm</option>
            <option value="anxious">😰 Anxious</option>
            <option value="spiraling">🌀 Spiraling</option>
            <option value="victory">🏆 Victory</option>
          </select>
          <button class="btn btn-primary btn-sm" onclick="submitPost()">Share</button>
        </div>
      </div>

      <!-- Posts -->
      <div id="posts-list"></div>
    </div>

    <%- include('partials/bottom_nav') %>
  </div>

  <script>
    function filterPosts(el, mood) {
      document.querySelectorAll('.mood-bar .mood-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
      applyMoodFilter(mood);
    }

    let activeMood = 'all';

    function escHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function moodIcon(mood) {
      if (mood === 'spiraling') return '🌀';
      if (mood === 'anxious') return '😰';
      if (mood === 'victory') return '🏆';
      if (mood === 'calm') return '😌';
      return '🫧';
    }

    function timeAgo(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return '';
      const diffMs = Date.now() - d.getTime();
      const mins = Math.floor(diffMs / 60000);
      if (mins < 1) return 'just now';
      if (mins < 60) return `${mins}m ago`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}h ago`;
      const days = Math.floor(hrs / 24);
      return `${days}d ago`;
    }

    function renderPosts(posts) {
      const list = document.getElementById('posts-list');
      if (!Array.isArray(posts) || posts.length === 0) {
        list.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">🫂</div>
            <div class="empty-text">Be the first to share.<br>Everything here is anonymous and judgment-free.</div>
          </div>`;
        return;
      }
      list.innerHTML = posts.map(post => {
        const mood = post.mood_label || 'all';
        return `
          <div class="community-post" data-mood="${escHtml(mood)}">
            <div class="post-header">
              <div class="post-author">
                <div class="post-avatar">${moodIcon(mood)}</div>
                <span>${escHtml(post.display_name || 'Anonymous')}</span>
              </div>
              <span style="font-size:0.75rem;color:var(--text-dim);">${escHtml(timeAgo(post.created_at))}</span>
            </div>
            <div class="post-content">${escHtml(post.content)}</div>
            <div class="post-actions">
              <button class="post-action" onclick="reactPost(this, '${escHtml(post.id)}')">🫂 <span>${Number(post.reactions) || 0}</span></button>
            </div>
          </div>`;
      }).join('');
      applyMoodFilter(activeMood);
    }

    function applyMoodFilter(mood) {
      activeMood = mood;
      document.querySelectorAll('.community-post').forEach(post => {
        post.style.display = (mood === 'all' || post.dataset.mood === mood) ? '' : 'none';
      });
    }

    async function loadPosts() {
      try {
        const res = await fetch('/api/community/feed?limit=50');
        const payload = await res.json();
        renderPosts(payload?.posts || []);
      } catch (_) {
        renderPosts([]);
      }
    }

    async function submitPost() {
      const content = document.getElementById('post-text').value.trim();
      if (!content) return;
      try {
        const mood = document.getElementById('post-mood').value;
        const moodLevelMap = { calm: 25, anxious: 75, spiraling: 95, victory: 10 };
        await fetch('/api/community/post', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            content,
            mood_label: mood,
            mood_level: moodLevelMap[mood] || null
          })
        });
        document.getElementById('post-text').value = '';
        await loadPosts();
      } catch(e) { alert('Could not post. Try again.'); }
    }

    async function reactPost(btn, postId) {
      try {
        const res = await fetch('/api/community/react', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ post_id: postId })
        });
        if (!res.ok) return;
        const span = btn.querySelector('span');
        if (span) span.textContent = String((Number(span.textContent) || 0) + 1);
        btn.style.color = 'var(--primary)';
      } catch (_) {}
    }

    loadPosts();
  </script>
</body>
</html>
