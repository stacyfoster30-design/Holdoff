    <!-- Permissions -->
    <string name="perm_rationale_phone">HoldOff needs phone permission to work as your default dialer and run the AI filter on calls.</string>
    <string name="perm_rationale_sms">HoldOff needs SMS permission to work as your default messaging app and run the AI filter before you send messages.</string>
    <string name="perm_rationale_contacts">HoldOff needs contacts access to show caller names and let you message your contacts.</string>
    <string name="perm_rationale_notifications">HoldOff needs notification permission to alert you to incoming calls and messages.</string>

    <!-- AI Disclosure -->
    <string name="ai_disclosure_title">How HoldOff uses AI</string>
    <string name="ai_disclosure_body">When you choose to analyze a message, HoldOff reads its content to generate a verdict. In on-device mode, this happens entirely on your phone — nothing leaves your device. In cloud mode, the message text is sent to HoldOff\'s secure servers for processing and is not stored after analysis. You can always choose not to analyze a message.</string>
    <string name="ai_disclosure_agree">I understand</string>

