<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Midnight Velvet — deep purples + romantic blues. Never coral. Never peach. -->
    <style name="Theme.HoldOff" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <item name="android:colorPrimary">#7B35C1</item>
        <item name="android:colorPrimaryDark">#2D1257</item>
        <item name="android:colorAccent">#7B35C1</item>
        <item name="android:statusBarColor">#0A0A1A</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#0A0A1A</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">#0A0A1A</item>
    </style>

    <!-- Android 12+ splash screen — midnight navy, no white flash -->
    <style name="Theme.HoldOff.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0A0A1A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.HoldOff</item>
    </style>

    <style name="Theme.HoldOff.Overlay">
        <item name="android:windowBackground">#0A0A1A</item>
    </style>
</resources>
