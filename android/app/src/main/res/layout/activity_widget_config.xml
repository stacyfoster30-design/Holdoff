<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_config_title"
        android:textColor="#1A1A1A"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/widget_size_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radio_2x2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_size_2x2"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:padding="8dp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radio_4x2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_size_4x2"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:padding="8dp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:backgroundTint="#E5E7EB"
            android:textColor="#6B7280"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_ok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OK"
            android:backgroundTint="#C97B5D"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>