<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_margin="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add HoldOff to your home screen"
        android:textColor="#1A1A1A"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quick-access widget lets you check texts before sending, right from your home screen."
        android:textColor="#6B7280"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_skip_widget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not now"
            android:backgroundTint="#E5E7EB"
            android:textColor="#6B7280"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_add_widget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Widget"
            android:backgroundTint="#C97B5D"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</LinearLayout>