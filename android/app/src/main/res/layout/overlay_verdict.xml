<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0E0C0B"
    android:elevation="8dp"
    android:padding="16dp">

    <!-- Close button top-right -->
    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Dismiss"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#6B7280" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="36dp"
        android:orientation="vertical">

        <!-- Relief title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/holdoff_relief_title"
            android:textColor="#F2EDE5"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Verdict badge -->
        <TextView
            android:id="@+id/tv_verdict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Message prefix -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/holdoff_relief_message_prefix"
            android:textColor="#9B9487"
            android:textSize="12sp" />

        <!-- User's captured message text -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#1A1714"
            android:padding="12dp"
            android:textColor="#F2EDE5"
            android:textSize="14sp"
            android:textStyle="italic"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3" />

        <!-- Grounded reframe -->
        <TextView
            android:id="@+id/tv_reframe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#C9BFB0"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_hold"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/holdoff_btn_hold"
                android:textSize="15sp"
                android:backgroundTint="#C97B5D"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="16dp" />

            <Button
                android:id="@+id/btn_send_anyway"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/holdoff_btn_send_anyway"
                android:textSize="15sp"
                android:backgroundTint="#2E2924"
                android:textColor="#9B9487"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
