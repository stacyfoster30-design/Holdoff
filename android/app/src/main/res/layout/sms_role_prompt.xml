<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FAF6F0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="#C97B5D"
                android:contentDescription="SMS icon" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/holdoff_sms_role_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:gravity="center"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/holdoff_sms_role_description"
                android:textSize="15sp"
                android:textColor="#4B5563"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btn_enable_sms_role"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/holdoff_sms_role_enable"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#C97B5D"
                android:textColor="#FFFFFF"
                android:layout_marginTop="20dp" />

            <Button
                android:id="@+id/btn_skip_sms_role"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/holdoff_sms_role_skip"
                android:textSize="14sp"
                android:backgroundTint="#E5E7EB"
                android:textColor="#6B7280"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
